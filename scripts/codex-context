#!/usr/bin/env python3
"""Print the current Codex-native project context."""

from __future__ import annotations

import argparse
from datetime import datetime

from codex_support import (
    PROJECT_ROOT,
    collect_artifacts,
    collect_db,
    collect_git,
    collect_guardian_health,
    collect_guardian_runtime_state,
    collect_meta_runtime_state,
    collect_versions,
    count_known_failures,
    print_kv,
    safety_risks,
)


def main() -> int:
    parser = argparse.ArgumentParser(description="Print edu-cloud Codex context.")
    parser.add_argument("--no-network", action="store_true", help="Skip curl checks to mcu.asia/backend.")
    args = parser.parse_args()

    git_info = collect_git()
    versions = collect_versions(no_network=args.no_network)
    db = collect_db()
    artifacts = collect_artifacts()
    risks = safety_risks(no_network=args.no_network)
    guardian = collect_guardian_health()
    meta_runtime = collect_meta_runtime_state()
    guardian_runtime = collect_guardian_runtime_state()

    print(f"Codex Context  {datetime.now().isoformat(timespec='seconds')}")
    print_kv("project", PROJECT_ROOT, 0)
    print()

    print("双核治理")
    print_kv(
        "Meta Core / 元控核",
        "direction, facts, task boundaries, context, Claude read-only counter-review, completion evidence routing",
    )
    print_kv(
        "Guardian Core / 守护核",
        "dirty state, truthline, DB/migration gates, safety scanning, frontend/backend build-runtime consistency, environment hygiene",
    )
    print()

    print("Git")
    for key in ("branch", "head", "upstream", "ahead", "status_entries"):
        print_kv(key, git_info[key])
    print()

    print("Dirty Summary")
    for key in ("backend_dirty", "frontend_dirty", "tests_dirty", "docs_dirty"):
        print_kv(key, git_info[key])
    print()

    print("Truthline")
    for key in ("dist_hash", "dist_source_dirty", "dist_build_time", "nginx_hash", "backend_hash", "backend_source_dirty", "backend_pid", "backend_boot_time", "worker_hash", "worker_source_dirty", "worker_pid", "worker_boot_time", "worker_status", "worker_service_pid", "network"):
        if key in versions:
            print_kv(key, versions[key])
    print()

    print("Verification Baseline (Reference)")
    print_kv("authority", "local verification reference, not completion acceptance authority")
    print_kv("known_pytest_failures", count_known_failures())
    print_kv("db_doctor", db.get("status"))
    if db.get("status") == "ok":
        print_kv("alembic_version", db.get("alembic_version"))
        print_kv("db_hard", db.get("hard"))
        print_kv("db_warn", db.get("warn"))
    print()

    print("Safety Risks")
    if risks:
        for risk in risks:
            print(f"  - {risk}")
    else:
        print("  - none detected")
    print()

    print("Completion Authority")
    print_kv("required_check", "GitHub CI required check / governance gate")
    print_kv("approval", "CODEOWNERS approval")
    print_kv("live_doctor", "current scripts/truth-doctor.sh and scripts/db_doctor.py --strict output")
    print_kv("state_snapshots", "diagnostic cache only; not a trust baseline")
    print()

    print("Meta Runtime Advisory")
    print_kv("authority", "advisory task-state cache; not completion evidence")
    print_kv("state", meta_runtime.get("status"))
    if meta_runtime.get("status") == "ok":
        stale = bool(meta_runtime.get("stale"))
        age_label = meta_runtime.get("age_label") or "unknown"
        freshness = "STALE — advisory snapshot, not completion authority/current truth" if stale else "fresh"
        print_kv("snapshot_at", f"{meta_runtime.get('snapshot_at')} ({age_label} ago, {freshness})")
        if stale:
            print_kv("overall", f"{meta_runtime.get('overall')} (stale advisory snapshot — run scripts/meta-check for diagnostics)")
        else:
            print_kv("overall", meta_runtime.get("overall"))
        print_kv("issues", meta_runtime.get("issue_count"))
        print_kv("obligations", meta_runtime.get("obligation_count"))
    else:
        print_kv("state_file", meta_runtime.get("state_file"))
    print()

    print("Guardian Health Advisory")
    print_kv("authority", "advisory diagnostics; completion authority is CI required check + CODEOWNERS + live doctor")
    print_kv("overall", guardian.get("overall", guardian.get("status")))
    print_kv("issues", guardian.get("issue_count", "unknown"))
    if guardian.get("status") == "ok":
        for issue in list(guardian.get("issues", []))[:5]:
            if not isinstance(issue, dict):
                continue
            code = issue.get("issue_code", "UNKNOWN")
            summary = issue.get("summary", "")
            signal = " advisory_signal" if issue.get("blocks_completion") else ""
            print(f"  - {code}{signal}: {summary}")
        if int(guardian.get("issue_count") or 0) > 5:
            print(f"  ... and {int(guardian.get('issue_count') or 0) - 5} more")
    print()

    print("Guardian Runtime Advisory")
    print_kv("service", guardian_runtime.get("service"))
    print_kv("authority", "advisory runtime cache; not completion evidence")
    print_kv("state", guardian_runtime.get("status"))
    if guardian_runtime.get("status") == "ok":
        print_kv("snapshot_at", guardian_runtime.get("snapshot_at"))
        print_kv("overall", guardian_runtime.get("overall"))
        print_kv("issues", guardian_runtime.get("issue_count"))
        print_kv("fingerprint", guardian_runtime.get("fingerprint"))
        model_review = guardian_runtime.get("model_review")
        if isinstance(model_review, dict):
            print_kv("model_review", model_review.get("status"))
    else:
        print_kv("state_file", guardian_runtime.get("state_file"))
    print()

    print("Artifacts")
    print_kv("risky_paths", ", ".join(artifacts["risky_paths"]) or "none")
    print_kv("runtime_paths", ", ".join(artifacts.get("runtime_paths", [])) or "none")
    print_kv("backups_exists", artifacts["backups_exists"])
    print_kv("screenshots_exists", artifacts["screenshots_exists"])
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
