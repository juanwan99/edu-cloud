#!/usr/bin/env python3
"""DB Migrate — safe Alembic migration wrapper.

Enforces: backup → dry-run on temp DB → db_doctor --strict → real upgrade.

Usage:
    scripts/db_migrate                    # upgrade to head
    scripts/db_migrate <revision>         # upgrade to specific revision
    scripts/db_migrate --current          # show current version (read-only)
    scripts/db_migrate --history          # show migration history (read-only)
"""
from __future__ import annotations

import argparse
import fcntl
import os
import shutil
import sqlite3
import subprocess
import sys
import tempfile
from datetime import datetime
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
LOCK_FILE = PROJECT_ROOT / "data" / ".db_migrate.lock"
BACKUP_DIR = PROJECT_ROOT / "backups"

os.chdir(PROJECT_ROOT)
sys.path.insert(0, str(PROJECT_ROOT / "src"))


def get_db_path() -> str:
    try:
        from edu_cloud.config import settings
        url = settings.DATABASE_URL
        if "sqlite" in url:
            return url.split("///")[-1]
    except Exception:
        pass
    return "edu_cloud.db"


def run_alembic(*args, env_override: dict | None = None) -> subprocess.CompletedProcess:
    env = os.environ.copy()
    env["EDU_CLOUD_MIGRATION_WRAPPER"] = "1"
    if env_override:
        env.update(env_override)
    return subprocess.run(
        [str(PROJECT_ROOT / ".venv" / "bin" / "alembic"), *args],
        capture_output=True, text=True, cwd=str(PROJECT_ROOT), env=env,
    )


def safe_backup(db_path: str) -> str:
    """Backup using sqlite3 backup API."""
    BACKUP_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    dst = str(BACKUP_DIR / f"edu_cloud_{ts}_pre_migrate.db")

    src_conn = sqlite3.connect(db_path)
    dst_conn = sqlite3.connect(dst)
    src_conn.backup(dst_conn)
    dst_conn.close()

    # Integrity check
    check_conn = sqlite3.connect(dst)
    result = check_conn.execute("PRAGMA integrity_check").fetchone()
    check_conn.close()
    src_conn.close()

    if result[0] != "ok":
        print(f"ERROR: Backup integrity check failed: {result[0]}", file=sys.stderr)
        sys.exit(1)

    print(f"  Backup: {dst} ({os.path.getsize(dst):,} bytes, integrity ok)")
    return dst


def dry_run_upgrade(db_path: str, target: str) -> bool:
    """Copy DB to temp, run upgrade there, then db_doctor --strict."""
    with tempfile.TemporaryDirectory() as tmpdir:
        tmp_db = os.path.join(tmpdir, "test.db")

        # Clone via backup API
        src = sqlite3.connect(db_path)
        dst = sqlite3.connect(tmp_db)
        src.backup(dst)
        dst.close()
        src.close()

        # Run upgrade on temp DB (use sync sqlite driver for alembic)
        result = run_alembic(
            "upgrade", target,
            env_override={"DATABASE_URL": f"sqlite+aiosqlite:///{tmp_db}"},
        )
        if result.returncode != 0:
            print(f"  DRY-RUN FAILED: alembic upgrade exit {result.returncode}", file=sys.stderr)
            print(f"  stderr: {result.stderr}", file=sys.stderr)
            return False

        # Run db_doctor --strict on temp DB
        doctor = subprocess.run(
            [str(PROJECT_ROOT / ".venv" / "bin" / "python"),
             str(PROJECT_ROOT / "scripts" / "db_doctor.py"),
             "--strict", "--db", tmp_db],
            capture_output=True, text=True, cwd=str(PROJECT_ROOT),
        )
        if doctor.returncode != 0:
            print(f"  DRY-RUN DOCTOR FAILED:", file=sys.stderr)
            print(doctor.stdout, file=sys.stderr)
            return False

        print("  Dry-run: upgrade + doctor --strict PASS")
        return True


def main():
    parser = argparse.ArgumentParser(description="Safe Alembic migration wrapper")
    parser.add_argument("target", nargs="?", default="head", help="Migration target (default: head)")
    parser.add_argument("--current", action="store_true", help="Show current version")
    parser.add_argument("--history", action="store_true", help="Show migration history")
    args = parser.parse_args()

    # Read-only commands pass through directly
    if args.current:
        result = run_alembic("current")
        print(result.stdout)
        sys.exit(result.returncode)

    if args.history:
        result = run_alembic("history", "--verbose", "-r", "-5:head")
        print(result.stdout)
        sys.exit(result.returncode)

    db_path = get_db_path()
    if not os.path.exists(db_path):
        print(f"ERROR: DB not found: {db_path}", file=sys.stderr)
        sys.exit(1)

    # Check if already at target
    current = run_alembic("current")
    if args.target == "head":
        heads = run_alembic("heads")
        head_rev = heads.stdout.strip().split()[0] if heads.stdout.strip() else ""
        current_rev = current.stdout.strip().split()[0] if current.stdout.strip() else ""
        if head_rev and current_rev == head_rev:
            print(f"Already at head ({head_rev}). Running doctor check...")
            doctor = subprocess.run(
                [str(PROJECT_ROOT / ".venv" / "bin" / "python"),
                 str(PROJECT_ROOT / "scripts" / "db_doctor.py"), "--strict"],
                capture_output=True, text=True, cwd=str(PROJECT_ROOT),
            )
            print(doctor.stdout)
            if doctor.returncode != 0:
                print("WARNING: At head but schema has drift!", file=sys.stderr)
                sys.exit(doctor.returncode)
            sys.exit(0)

    print(f"DB Migrate — {db_path} → {args.target}")
    print(f"  Current: {current.stdout.strip()}")

    # Acquire exclusive lock
    LOCK_FILE.parent.mkdir(parents=True, exist_ok=True)
    lock_fd = open(LOCK_FILE, "w")
    try:
        fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        print("ERROR: Another migration is in progress", file=sys.stderr)
        sys.exit(1)

    try:
        # Step 1: Backup
        print("\n[1/4] Backing up...")
        backup_path = safe_backup(db_path)

        # Step 2: Dry-run
        print("\n[2/4] Dry-run upgrade on temp DB...")
        if not dry_run_upgrade(db_path, args.target):
            print("\nABORTED: Dry-run failed. Prod DB untouched.", file=sys.stderr)
            sys.exit(1)

        # Step 3: Real upgrade
        print(f"\n[3/4] Upgrading real DB to {args.target}...")
        result = run_alembic("upgrade", args.target)
        if result.returncode != 0:
            print(f"ERROR: Real upgrade failed (exit {result.returncode})", file=sys.stderr)
            print(f"  stderr: {result.stderr}", file=sys.stderr)
            print(f"  Backup available: {backup_path}", file=sys.stderr)
            sys.exit(1)
        print(f"  Upgrade complete")

        # Step 4: Post-upgrade doctor
        print("\n[4/4] Post-upgrade doctor check...")
        doctor = subprocess.run(
            [str(PROJECT_ROOT / ".venv" / "bin" / "python"),
             str(PROJECT_ROOT / "scripts" / "db_doctor.py"), "--strict"],
            capture_output=True, text=True, cwd=str(PROJECT_ROOT),
        )
        print(doctor.stdout)
        if doctor.returncode != 0:
            print(f"WARNING: Post-upgrade doctor found issues", file=sys.stderr)
            print(f"  Backup available: {backup_path}", file=sys.stderr)
            sys.exit(doctor.returncode)

        print("Migration complete.")

    finally:
        fcntl.flock(lock_fd, fcntl.LOCK_UN)
        lock_fd.close()


if __name__ == "__main__":
    main()
