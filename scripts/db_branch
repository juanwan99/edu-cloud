#!/usr/bin/env python3
"""DB Branch — branch-level DB isolation for development.

Manages per-branch SQLite DB copies so feature branches don't pollute
the prod DB with their migrations.

Usage:
    scripts/db_branch init [branch]     # Clone prod DB for branch, write .env.branch
    scripts/db_branch refresh [branch]  # Re-clone from prod (destroys branch data)
    scripts/db_branch prune [--days N]  # Remove branch DBs older than N days (default 14)
    scripts/db_branch list              # Show all branch DBs
    scripts/db_branch status            # Show current branch DB mapping

The branch DB lives at: data/db/branches/<slug>/edu_cloud.db
To use it, set DATABASE_URL in your worktree's .env or export it:
    export DATABASE_URL=sqlite+aiosqlite:///data/db/branches/<slug>/edu_cloud.db
"""
from __future__ import annotations

import argparse
import os
import re
import shutil
import sqlite3
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
DB_BRANCH_DIR = PROJECT_ROOT / "data" / "db" / "branches"
PROD_DB = PROJECT_ROOT / "edu_cloud.db"


def slugify(branch: str) -> str:
    return re.sub(r"[^a-zA-Z0-9_-]", "_", branch.replace("/", "_"))


def current_branch() -> str:
    result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True, text=True, cwd=str(PROJECT_ROOT),
    )
    return result.stdout.strip()


def safe_clone(src: Path, dst: Path) -> None:
    """Clone DB using sqlite3 backup API."""
    dst.parent.mkdir(parents=True, exist_ok=True)
    src_conn = sqlite3.connect(str(src))
    dst_conn = sqlite3.connect(str(dst))
    src_conn.backup(dst_conn)
    dst_conn.close()
    src_conn.close()


def cmd_init(args):
    branch = args.branch or current_branch()
    slug = slugify(branch)
    branch_dir = DB_BRANCH_DIR / slug
    branch_db = branch_dir / "edu_cloud.db"

    if branch_db.exists() and not args.force:
        print(f"Branch DB already exists: {branch_db}")
        print(f"  Use --force to overwrite, or 'refresh' to re-clone from prod")
        sys.exit(1)

    if not PROD_DB.exists():
        print(f"ERROR: Prod DB not found: {PROD_DB}", file=sys.stderr)
        sys.exit(1)

    print(f"Cloning prod DB for branch '{branch}'...")
    safe_clone(PROD_DB, branch_db)

    # Write .env.branch hint
    env_hint = branch_dir / ".env.branch"
    env_hint.write_text(
        f"# Auto-generated by db_branch init\n"
        f"# Branch: {branch}\n"
        f"# Created: {datetime.now().isoformat(timespec='seconds')}\n"
        f"DATABASE_URL=sqlite+aiosqlite:///{branch_db}\n"
    )

    size = branch_db.stat().st_size
    print(f"  Branch DB: {branch_db} ({size:,} bytes)")
    print(f"  Env hint:  {env_hint}")
    print(f"\nTo use: export DATABASE_URL=sqlite+aiosqlite:///{branch_db}")


def cmd_refresh(args):
    branch = args.branch or current_branch()
    slug = slugify(branch)
    branch_db = DB_BRANCH_DIR / slug / "edu_cloud.db"

    if not branch_db.exists():
        print(f"No branch DB for '{branch}'. Use 'init' first.")
        sys.exit(1)

    print(f"Re-cloning prod DB for branch '{branch}'...")
    safe_clone(PROD_DB, branch_db)
    print(f"  Refreshed: {branch_db} ({branch_db.stat().st_size:,} bytes)")


def cmd_prune(args):
    if not DB_BRANCH_DIR.exists():
        print("No branch DBs to prune.")
        return

    cutoff = time.time() - (args.days * 86400)
    pruned = 0

    for d in DB_BRANCH_DIR.iterdir():
        if not d.is_dir():
            continue
        db_file = d / "edu_cloud.db"
        if not db_file.exists():
            continue
        mtime = db_file.stat().st_mtime
        if mtime < cutoff:
            size = db_file.stat().st_size
            shutil.rmtree(d)
            print(f"  Pruned: {d.name} (last modified {datetime.fromtimestamp(mtime):%Y-%m-%d}, {size:,} bytes)")
            pruned += 1

    print(f"Pruned {pruned} branch DB(s)." if pruned else "Nothing to prune.")


def cmd_list(args):
    if not DB_BRANCH_DIR.exists():
        print("No branch DBs.")
        return

    for d in sorted(DB_BRANCH_DIR.iterdir()):
        if not d.is_dir():
            continue
        db_file = d / "edu_cloud.db"
        if db_file.exists():
            size = db_file.stat().st_size
            mtime = datetime.fromtimestamp(db_file.stat().st_mtime)
            print(f"  {d.name:40s}  {size:>12,} bytes  {mtime:%Y-%m-%d %H:%M}")
        else:
            print(f"  {d.name:40s}  (no db)")


def cmd_status(args):
    branch = current_branch()
    slug = slugify(branch)
    branch_db = DB_BRANCH_DIR / slug / "edu_cloud.db"

    print(f"Current branch: {branch}")
    print(f"Prod DB:        {PROD_DB} ({'exists' if PROD_DB.exists() else 'MISSING'})")
    print(f"Branch DB:      {branch_db} ({'exists' if branch_db.exists() else 'not initialized'})")

    if branch_db.exists():
        conn = sqlite3.connect(str(branch_db))
        ver = conn.execute("SELECT version_num FROM alembic_version").fetchone()
        conn.close()
        print(f"Branch alembic: {ver[0] if ver else 'none'}")

    if PROD_DB.exists():
        conn = sqlite3.connect(str(PROD_DB))
        ver = conn.execute("SELECT version_num FROM alembic_version").fetchone()
        conn.close()
        print(f"Prod alembic:   {ver[0] if ver else 'none'}")


def main():
    parser = argparse.ArgumentParser(description="DB Branch — branch-level DB isolation")
    sub = parser.add_subparsers(dest="command")

    p_init = sub.add_parser("init", help="Clone prod DB for a branch")
    p_init.add_argument("branch", nargs="?", help="Branch name (default: current)")
    p_init.add_argument("--force", action="store_true", help="Overwrite existing")
    p_init.set_defaults(func=cmd_init)

    p_refresh = sub.add_parser("refresh", help="Re-clone prod DB for a branch")
    p_refresh.add_argument("branch", nargs="?", help="Branch name (default: current)")
    p_refresh.set_defaults(func=cmd_refresh)

    p_prune = sub.add_parser("prune", help="Remove old branch DBs")
    p_prune.add_argument("--days", type=int, default=14, help="Max age in days (default: 14)")
    p_prune.set_defaults(func=cmd_prune)

    p_list = sub.add_parser("list", help="List branch DBs")
    p_list.set_defaults(func=cmd_list)

    p_status = sub.add_parser("status", help="Show current branch DB mapping")
    p_status.set_defaults(func=cmd_status)

    args = parser.parse_args()
    if not hasattr(args, "func"):
        parser.print_help()
        sys.exit(1)
    args.func(args)


if __name__ == "__main__":
    main()
