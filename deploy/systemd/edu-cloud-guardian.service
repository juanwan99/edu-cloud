[Unit]
Description=edu-cloud Guardian realtime watcher
After=network.target edu-cloud.service edu-cloud-worker.service llm-proxy.service
Wants=network.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=ops
Group=ops
WorkingDirectory=/home/ops/projects/edu-cloud
EnvironmentFile=-/home/ops/projects/edu-cloud/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ops/projects/edu-cloud/.venv/bin/python /home/ops/projects/edu-cloud/scripts/guardian-watch --watch --interval 15 --state-file /home/ops/projects/edu-cloud/logs/guardian-state.json --jsonl-file /home/ops/projects/edu-cloud/logs/guardian-watch.jsonl --no-model-review
Restart=on-failure
RestartSec=10
CPUQuota=25%
MemoryMax=512M
NoNewPrivileges=true
StandardOutput=append:/home/ops/logs/edu-cloud-guardian.log
StandardError=append:/home/ops/logs/edu-cloud-guardian.log

[Install]
WantedBy=multi-user.target
