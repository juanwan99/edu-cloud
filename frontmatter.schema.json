{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "owner", "last_review_date", "expiration_in_days"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "last_review_date": {
      "type": "string",
      "format": "date"
    },
    "expiration_in_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365
    }
  },
  "additionalProperties": false
}
