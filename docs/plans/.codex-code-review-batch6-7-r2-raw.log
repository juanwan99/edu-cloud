import edu_cloud.models.audit_log  # noqa: F401
import edu_cloud.models.agent_profile  # noqa: F401
import edu_cloud.modules.homework.models  # noqa: F401

from edu_cloud.api.app import create_app
from edu_cloud.database import get_db
from edu_cloud.models.user import User
from edu_cloud.models.user_role import UserRole
from edu_cloud.models.school import School
from edu_cloud.shared.storage import get_storage, StorageService
from edu_cloud.modules.scan.service import get_storage as get_scan_storage
import edu_cloud.database as _db_mod
from edu_cloud.ai.llm_adapter import LLMResponse, TokenUsage

seen = []

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:', echo=False)
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    session_factory = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

    async with session_factory() as db:
        user = User(username='teacher1', display_name='张老师')
        user.set_password('123456')
        db.add(user)
        await db.flush()
        school = School(name='测试校', code='TEST01', district='测试区', api_key_hash='placeholder')
        db.add(school)
        await db.flush()
        db.add(UserRole(user_id=user.id, role='homeroom_teacher', school_id=school.id, class_ids=['class-7-2'], is_primary=True))
        await db.commit()

    app = create_app()
    async def override_get_db():
        async with session_factory() as session:
            yield session
    app.dependency_overrides[get_db] = override_get_db
    app.dependency_overrides[get_storage] = lambda: StorageService(root='.')
    app.dependency_overrides[get_scan_storage] = lambda: StorageService(root='.')
    _orig_session = _db_mod.async_session
    _db_mod.async_session = session_factory

    async def mock_chat(self, request):
        seen.append([(m.role, m.content, bool(m.tool_calls)) for m in request.messages])
        return LLMResponse(content='ok', usage=TokenUsage(1,1), stop_reason='end_turn')

    async def mock_determine_tier(self, adapter):
        return 3

    transport = ASGITransport(app=app)
    try:
        async with AsyncClient(transport=transport, base_url='http://test') as client:
            login = await client.post('/api/v1/auth/login', json={'username':'teacher1','password':'123456'})
            headers = {'Authorization': f\"Bearer {login.json()['access_token']}\"}
            with patch('edu_cloud.ai.llm_adapter.LLMProxyAdapter.chat', mock_chat), \\
                 patch('edu_cloud.ai.capability_probe.CapabilityProbe.determine_tier', mock_determine_tier):
                sid = 'r2-history-check'
                r1 = await client.post('/api/v1/ai/chat', json={'message':'第一问','session_id':sid}, headers=headers)
                r2 = await client.post('/api/v1/ai/chat', json={'message':'第二问','session_id':sid}, headers=headers)
                print('status', r1.status_code, r2.status_code)
                print('call_count', len(seen))
                for i, msgs in enumerate(seen, 1):
                    print('request', i, msgs)
    finally:
        _db_mod.async_session = _orig_session
        await engine.dispose()

asyncio.run(main())
