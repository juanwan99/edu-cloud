import asyncio
from edu_cloud.ai.agent_loop import AgentLoop
from edu_cloud.ai.llm_adapter import LLMProxyAdapter, LLMResponse, TokenUsage
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_context import ToolContext, ToolResult
from edu_cloud.ai.capability_probe import LoopStrategy
from edu_cloud.ai.schemas import ToolCall
from edu_cloud.ai.anonymizer import Anonymizer

seen = []

async def main():
    reg = ToolRegistry()
    @reg.register(name='get_roster', description='Get roster', parameters={}, is_read_only=True, sensitivity='student')
    async def get_roster(input: dict, ctx: ToolContext) -> ToolResult:
        return ToolResult(success=True, data={'students':[{'student_name':'张三','student_number':'T001','id':'s1'}]})

    anon = Anonymizer()
    ctx = ToolContext(db=None, school_id='S1', user_id='U1', role='teacher', anonymizer=anon)
    adapter = LLMProxyAdapter(base_url='http://test:8100', slot='primary')
    call_count = 0
    async def mock_chat(request):
        nonlocal call_count
        call_count += 1
        seen.append([m.to_dict() for m in request.messages])
        if call_count == 1:
            return LLMResponse(tool_calls=[ToolCall(id='tc1', name='get_roster', arguments={}, _raw={})], usage=TokenUsage(1,1), stop_reason='tool_use')
        return LLMResponse(content='S001 的成绩很好', usage=TokenUsage(1,1), stop_reason='end_turn')
    adapter.chat = mock_chat
    loop = AgentLoop(registry=reg, adapter=adapter, strategy=LoopStrategy.for_tier(3))
    events = []
    async for e in loop.run('查名单', ctx, tool_specs=reg.get_all_specs()):
        events.append(e.to_dict())
    print('second_request_messages', seen[1])
    print('events', events)

asyncio.run(main())
