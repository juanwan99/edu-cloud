from edu_cloud.database import get_db
from edu_cloud.shared.auth import create_access_token
from edu_cloud.models.user import User
from edu_cloud.models.user_role import UserRole
from edu_cloud.models.school import School
from edu_cloud.modules.exam.models import Exam

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:')
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

    async with Session() as db:
        s1 = School(name='S1', code='S1', district='d', api_key_hash='x')
        db.add(s1)
        await db.flush()
        u = User(username='director', display_name='Director')
        u.set_password('pw')
        db.add(u)
        await db.flush()
        role = UserRole(user_id=u.id, role='academic_director', school_id=s1.id, is_primary=True)
        db.add(role)
        exam = Exam(name='E', status='completed', school_id=s1.id)
        db.add(exam)
        await db.commit()
        token = create_access_token({'sub': u.id, 'active_role_id': role.id})
        exam_id = exam.id

    app = create_app()
    async def override_get_db():
        async with Session() as session:
            yield session
    app.dependency_overrides[get_db] = override_get_db
    import edu_cloud.database as _db_mod
    _orig = _db_mod.async_session
    _db_mod.async_session = Session
    try:
        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url='http://test') as client:
            resp = await client.post(f'/api/v1/exams/{exam_id}/publish', headers={'Authorization': f'Bearer {token}'})
            print('status=', resp.status_code)
            print('body=', resp.json())
        async with Session() as db:
            exam = await db.get(Exam, exam_id)
            print('persisted_status=', exam.status)
    finally:
        _db_mod.async_session = _orig
        await engine.dispose()

asyncio.run(main())
