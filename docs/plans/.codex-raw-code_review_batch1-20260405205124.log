import asyncio
from unittest.mock import AsyncMock, patch
from edu_cloud.ai.tools.analytics_report import compare_exams
from edu_cloud.ai.tool_context import ToolContext

async def main():
    ctx = ToolContext(db=AsyncMock(), school_id='school-1', user_id='u1', role='homeroom_teacher', class_ids=['class-1'])
    with patch('edu_cloud.modules.analytics.report_service.get_student_trend', new=AsyncMock(return_value={'points': []})) as mocked:
        result = await compare_exams({'exam_ids': ['e1'], 'target_type': 'student', 'target_id': 'stu-other'}, ctx)
        print('success=', result.success)
        print('called=', mocked.await_count)
        print('args=', mocked.await_args)

asyncio.run(main())
