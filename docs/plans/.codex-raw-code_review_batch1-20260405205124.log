import asyncio
from types import SimpleNamespace
from unittest.mock import AsyncMock
from fastapi import HTTPException
from edu_cloud.modules.analytics.router import student_trend_api

class FakeResult:
    def __init__(self, first_value=None, scalar=None):
        self._first_value = first_value
        self._scalar = scalar
    def first(self):
        return self._first_value
    def scalar_one_or_none(self):
        return self._scalar

async def main():
