            self.history = []\n        if not self.last_access:\n            import time\n            self.last_access = time.time()\n\n    def touch(self):\n        import time\n        self.last_access = time.time()\n\n\n_sessions: dict[str, _SessionState] = {}\n\n\ndef _purge_expired_sessions():\n    \"\"\"Remove sessions older than AI_SESSION_TTL.\"\"\"\n    import time\n    ttl = settings.AI_SESSION_TTL\n    now = time.time()\n    expired = [sid for sid, s in _sessions.items() if now - s.last_access > ttl]\n    for sid in expired:\n        del _sessions[sid]\n\n\n# ── Request model ────────────────────────────────────────────────────────\nclass ChatRequest(BaseModel):\n    message: str\n    session_id: str | None = None\n\n    @property\n    def validated_message(self) -> str:\n        msg = self.message.strip()\n        if not msg:\n            raise ValueError(\"消息不能为空\")\n        if len(msg) > 2000:\n            raise ValueError(\"消息长度不能超过 2000 字��\")\n        return msg\n\n\n# ── Endpoints ─────────────────────────────────────────────────────────────\n@router.get(\"/health\")\nasync def ai_health():\n    tool_count = len(tools.list_tools())\n    return {\"status\": \"available\", \"tools\": tool_count}\n\n\n@router.post(\"/chat\")\nasync def ai_chat(\n    req: ChatRequest,\n    current=Depends(require_permission(Permission.USE_AI_CHAT)),\n    db: AsyncSession = Depends(get_db),\n):\n    try:\n        message = req.validated_message\n    except ValueError as e:\n        return {\"error\": str(e)}\n\n    user = current[\"user\"]\n    role_obj = current[\"current_role\"]\n    role = role_obj.role if hasattr(role_obj, \"role\") else \"unknown\"\n\n    # DataScope computation (best-effort: failure falls back to manual scope)\n    data_scope = None\n    try:\n        from edu_cloud.ai.data_scope import DataScopeBuilder\n        data_scope = await DataScopeBuilder(db).build(user.id, role_id=role_obj.id)\n    except Exception as scope_exc:\n        logger.warning(\"DataScope build failed, using manual scope: %s\", scope_exc)\n\n    scope = {}\n    if hasattr(role_obj, \"school_id\") and role_obj.school_id:\n        scope[\"school\"] = role_obj.school_id\n    if hasattr(role_obj, \"class_ids\") and role_obj.class_ids:\n        scope[\"classes\"] = role_obj.class_ids\n    if hasattr(role_obj, \"grade_ids\") and role_obj.grade_ids:\n        scope[\"grades\"] = role_obj.grade_ids\n    if hasattr(role_obj, \"subject_codes\") and role_obj.subject_codes:\n        scope[\"subjects\"] = role_obj.subject_codes\n\n    # DB audit\n    audit = AuditLogger(db)\n    session_id = req.session_id or str(uuid.uuid4())\n\n    # Create audit session for new conversations\n    if session_id not in _sessions:\n        try:\n            await audit.create_session(user.id, role, context=scope)\n        except Exception as e:\n            logger.warning(\"Failed to create audit session: %s\", e)\n\n    school_id = getattr(role_obj, \"school_id\", None)\n\n    # === New Agent Pipeline (AgentLoop) ===\n    # Pre-init variables that fallback branch needs\n    enabled_modules = None\n    capabilities = {}\n    available_tools = tools.get_all_specs()\n    profile = None\n\n    try:\n        # 1. Agent 身份\n        profile = await AgentProfileService.get_or_create(\n            db, user_id=user.id, school_id=school_id or \"\", display_name=user.display_name,\n        )\n\n        # 2. 三重权限过滤 (ToolAccessResolver)\n        all_specs = tools.get_all_specs()\n        enabled_modules = await get_enabled_modules(db, school_id=school_id) if school_id else None\n        caps_list = await get_capabilities(db, school_id=school_id, role=role) if school_id else []\n        capabilities = {(c.domain, c.action): c.enabled for c in caps_list}\n\n        resolver = ToolAccessResolver()\n        available_tools = resolver.resolve(\n            all_specs=all_specs, role=role,\n            enabled_modules=enabled_modules, capabilities=capabilities,\n        )\n\n        # 3. CapabilityProbe → tier + strategy\n        primary_adapter = LLMProxyAdapter(\n            base_url=settings.LLM_API_URL or \"http://localhost:8100\",\n            slot=\"ai-chat\",\n        )\n        probe = CapabilityProbe()\n        tier = await probe.determine_tier(primary_adapter)\n        strategy = LoopStrategy.for_tier(tier)\n\n        # 4. SensitivityRouter (dual-channel)\n        sensitivity_router = SensitivityRouter(primary=primary_adapter, enhanced=None)\n\n        model_tier = f\"tier{tier}\"\n    except Exception as pipeline_exc:\n        logger.warning(\"Agent Pipeline failed, falling back: %s\", pipeline_exc)\n        primary_adapter = LLMProxyAdapter(\n            base_url=settings.LLM_API_URL or \"http://localhost:8100\",\n            slot=\"ai-chat\",\n        )\n        strategy = LoopStrategy.for_tier(3)\n        sensitivity_router = None\n        model_tier = \"tier3\"\n\n    # Build ToolContext\n    tool_ctx = ToolContext(\n        db=db,\n        school_id=school_id or \"\",\n        user_id=user.id,\n        role=role,\n        class_ids=getattr(role_obj, \"class_ids\", None),\n        subject_codes=getattr(role_obj, \"subject_codes\", None),\n        grade_ids=getattr(role_obj, \"grade_ids\", None),\n        capabilities=capabilities,\n        enabled_modules=list(enabled_modules) if enabled_modules else [],\n        anonymizer=_sessions.setdefault(\n            session_id, _SessionState(anonymizer=Anonymizer(), owner_id=user.id)\n        ).anonymizer,\n        data_scope=data_scope,\n    )\n    session_state = _sessions[session_id]\n    session_state.touch()\n    _purge_expired_sessions()\n\n    # IntentRouter classification (best-effort)\n    intent_result = None\n    try:\n        from edu_cloud.ai.intent_router import IntentRouter\n        available_wfs = [\"post_exam_analysis\", \"student_profile\", \"patrol\"]\n        intent_result = IntentRouter().classify(message, available_workflows=available_wfs)\n    except Exception as intent_exc:\n        logger.warning(\"IntentRouter failed: %s\", intent_exc)\n\n    # Build system prompt (parent override when DataScope available)\n    if data_scope and data_scope.persona == \"parent_advisor\":\n        from edu_cloud.ai.prompts import build_parent_prompt\n        system_prompt = build_parent_prompt(\n            child_name=\"您的孩子\",\n            school_name=scope.get(\"school\", \"\"),\n            can_see_rankings=data_scope.can_see_rankings,\n        )\n    else:\n        system_prompt = build_teacher_prompt(\n            role=role,\n            display_name=user.display_name,\n            school_name=scope.get(\"school\", \"\"),\n            tool_names=[t.name for t in available_tools],\n            tier=strategy.tier,\n        )\n\n    # Enrich system prompt with intent classification (B6-F2: consume IntentRouter result)\n    # NOTE: Full workflow-mode routing (IntentRouter → AgentLoop workflow execution)\n    # is deferred to Phase 2. For now, we inject the detected intent as context\n    # so the LLM can leverage it for better tool selection.\n    if intent_result and intent_result.domains:\n        system_prompt += f\"\\n\\n[检测到的用户意图领域: {', '.join(intent_result.domains)}]\"\n    if intent_result and intent_result.workflow:\n        system_prompt += f\"\\n[匹配工作流: {intent_result.workflow}, 置信度: {intent_result.confidence:.1f}]\"\n\n    # Create Supervisor (replaces AgentLoop — backward compatible for simple requests)\n    supervisor = Supervisor(\n        registry=tools,\n        adapter=primary_adapter,\n        strategy=strategy,\n        team_registry=team_registry,\n        sensitivity_router=sensitivity_router,\n    )\n\n    async def event_stream():\n        try:\n            async for event in supervisor.handle(\n                message=message,\n                ctx=tool_ctx,\n                tool_specs=available_tools,\n                system_prompt=system_prompt,\n                history=session_state.history,\n            ):\n            