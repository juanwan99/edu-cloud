import asyncio
from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker, AsyncSession
from edu_cloud.models.base import Base
import edu_cloud.models.user
import edu_cloud.models.user_role
import edu_cloud.models.school
import edu_cloud.models.guardian
import edu_cloud.models.school_settings
from edu_cloud.models.user import User
from edu_cloud.models.user_role import UserRole
from edu_cloud.models.school import School
from edu_cloud.models.guardian import GuardianStudentLink
from edu_cloud.ai.data_scope import DataScopeBuilder

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:')
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with Session() as db:
        user = User(username='p', display_name='parent')
        user.set_password('x')
        db.add(user)
        await db.flush()
        s1 = School(name='s1', code='S1', district='d', api_key_hash='x')
        s2 = School(name='s2', code='S2', district='d', api_key_hash='x')
        db.add_all([s1, s2])
        await db.flush()
        role = UserRole(user_id=user.id, role='parent', school_id=s1.id, is_primary=True)
        db.add(role)
        db.add_all([
            GuardianStudentLink(guardian_user_id=user.id, student_id='stu-s1', relationship='father', school_id=s1.id),
            GuardianStudentLink(guardian_user_id=user.id, student_id='stu-s2', relationship='father', school_id=s2.id),
        ])
        await db.commit()
        scope = await DataScopeBuilder(db).build(user.id, role.id)
        print(scope.visible_student_ids)
    await engine.dispose()

asyncio.run(main())
