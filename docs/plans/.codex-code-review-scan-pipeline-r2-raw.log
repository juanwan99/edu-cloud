ata(client, db)\n        exam.status = \"completed\"\n        await db.commit()\n\n        resp = await client.post(\"/api/v1/card/publish\", json={\n            \"exam_id\": \"pe1\", \"subject_id\": \"psub1\",\n            \"html\": \"<html></html>\", \"paper_size\": \"A3\",\n        }, headers=headers)\n        assert resp.status_code == 400\n        assert \"completed\" in resp.json()[\"detail\"]\n"
