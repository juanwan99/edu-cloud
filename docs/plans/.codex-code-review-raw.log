from edu_cloud.database import get_db

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:', echo=False)
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    session_factory = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with session_factory() as db:
        school = RegisteredSchool(name='测试校', code='T1', district='测试区', api_key_hash='x')
        db.add(school)
        await db.flush()

        teacher = User(username='teacher1', display_name='张老师')
        teacher.set_password('123456')
        db.add(teacher)
        await db.flush()
        db.add(UserRole(user_id=teacher.id, role='homeroom_teacher', school_id=school.id, is_primary=True))

        subject = User(username='subject1', display_name='李老师')
        subject.set_password('123456')
        db.add(subject)
        await db.flush()
        db.add(UserRole(user_id=subject.id, role='subject_teacher', school_id=school.id, is_primary=True))
        await db.commit()

        app = create_app()
        async def override_get_db():
            yield db
        app.dependency_overrides[get_db] = override_get_db

        teacher_token = create_access_token({'sub': teacher.id, 'role': 'homeroom_teacher'})
        subject_token = create_access_token({'sub': subject.id, 'role': 'subject_teacher'})
        teacher_headers = {'Authorization': f'Bearer {teacher_token}'}
        subject_headers = {'Authorization': f'Bearer {subject_token}'}

        transport = ASGITransport(app=app)
        async with AsyncClient(transport=transport, base_url='http://test') as client:
            # 1) 删除后是否仍出现在列表中
            resp = await client.post('/api/v1/calendar/events', json={'type':'exam','title':'删除后检查','event_date':'2026-06-01'}, headers=teacher_headers)
            event_id = resp.json()['id']
            await client.delete(f'/api/v1/calendar/events/{event_id}', headers=teacher_headers)
            list_resp = await client.get('/api/v1/calendar/events', headers=teacher_headers)
            print('calendar_after_delete', list_resp.json())

            # 2) 非法日期是否返回 500
            bad_resp = await client.post('/api/v1/calendar/events', json={'type':'holiday','title':'坏日期','event_date':'2026-99-99'}, headers=teacher_headers)
            print('bad_date_status', bad_resp.status_code, bad_resp.text)

            # 3) subject_teacher 是否能创建 notification
            notif_resp = await client.post('/api/v1/studio/documents', json={'type':'notification','title':'越权通知','content_json':{}}, headers=subject_headers)
            print('subject_create_notification', notif_resp.status_code, notif_resp.text)

    await engine.dispose()

asyncio.run(main())
