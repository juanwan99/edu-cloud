"C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import asyncio, sys
from pathlib import Path
from collections import defaultdict
sys.path.insert(0, str(Path('src').resolve()))
sys.path.insert(0, str(Path('.').resolve()))
from scripts.import_mcu_planning_weights import load_mcu_patterns_and_weights, match_mcu_to_kb
from edu_cloud.database import async_session
from scripts.import_mcu_planning_weights import load_kb_concepts

async def main():
    patterns, weights = load_mcu_patterns_and_weights()
    async with async_session() as session:
        kb_concepts = await load_kb_concepts(session)
    mapping = match_mcu_to_kb(patterns, kb_concepts)
    weights_by_kb = {}
    chosen = {}
    for mcu_id, (kb_id, score) in mapping.items():
        if mcu_id in weights:
            weights_by_kb[kb_id] = weights[mcu_id]
            chosen[kb_id] = (mcu_id, score)
    rev = defaultdict(list)
    for mcu, (kb, score) in mapping.items():
        rev[kb].append((mcu, score))
    for kb, vals in rev.items():
        if len(vals) > 1:
            best = max(vals, key=lambda x: x[1])
            print('KB', kb)
            print('  all', sorted(vals))
            print('  chosen_by_current', chosen[kb])
            print('  expected_best', best)

asyncio.run(main())
