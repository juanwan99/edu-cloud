import sqlite3, json, os
from pathlib import Path
kb = os.environ.get('KNOWLEDGE_DB_PATH', str(Path.home() / 'edu-knowledge-base' / 'knowledge.db'))
conn = sqlite3.connect(kb)
conn.row_factory = sqlite3.Row

# Build DA -> concepts
mapping = {}
for row in conn.execute(\"SELECT id, linked_concept_ids FROM diagnostic_attributes WHERE linked_concept_ids IS NOT NULL\"):
    try:
        ids = json.loads(row['linked_concept_ids'])
        if isinstance(ids, list):
            mapping[row['id']] = ids
    except Exception:
        pass

from collections import defaultdict
pairs = defaultdict(set)
for row in conn.execute(\"SELECT item_id, attribute_id, transfer_band FROM q_matrix\"):
    for cid in mapping.get(row['attribute_id'], []):
        pairs[(cid, row['item_id'])].add(row['transfer_band'])

mixed = [(cid, item, bands) for (cid,item), bands in pairs.items() if len(bands) > 1]
print('concept-item pairs with multiple transfer bands:', len(mixed))
print('sample:', mixed[:10])

# specifically for photosynthesis
photo = [x for x in mixed if x[0]=='BIO_SR_CP_M1_PHOTOSYNTHESIS']
print('photosynthesis mixed pairs:', len(photo))
print('photo sample:', photo[:10])
conn.close()
