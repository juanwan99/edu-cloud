{
  "content": [
    {
      "type": "text",
      "text": "\"\"\"knowledge-base MCP Server — 教育知识库 5 工具。\r\n启动：python server.py --db /path/to/knowledge.db [--transport stdio|sse] [--port 9106]\r\n\"\"\"\r\nfrom __future__ import annotations\r\n\r\nimport argparse\r\nimport json\r\nimport logging\r\nimport os\r\nimport sys\r\n\r\nlogging.basicConfig(level=logging.INFO,\r\n                    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\")\r\nlogger = logging.getLogger(\"knowledge-mcp\")\r\n\r\ntry:\r\n    from mcp.server.fastmcp import FastMCP\r\nexcept ImportError:\r\n    FastMCP = None\r\n\r\ntry:\r\n    from .db import open_readonly, check_asset_health\r\n    from .richtext import rich_elements_to_plain, options_to_plain\r\nexcept ImportError:\r\n    from db import open_readonly, check_asset_health\r\n    from richtext import rich_elements_to_plain, options_to_plain\r\n\r\n\r\ndef _parse_args() -> argparse.Namespace:\r\n    parser = argparse.ArgumentParser(description=\"Knowledge-base MCP Server\")\r\n    parser.add_argument(\"--db\", default=os.environ.get(\"KNOWLEDGE_DB\", \"knowledge.db\"))\r\n    parser.add_argument(\"--transport\", default=\"stdio\", choices=[\"stdio\", \"sse\"])\r\n    parser.add_argument(\"--host\", default=os.environ.get(\"MCP_HOST\", \"127.0.0.1\"))\r\n    parser.add_argument(\"--port\", type=int, default=int(os.environ.get(\"MCP_PORT\", \"9106\")))\r\n    if __name__ == \"__main__\":\r\n        return parser.parse_args()\r\n    return parser.parse_args([])\r\n\r\n\r\n_args = _parse_args()\r\n\r\nif FastMCP:\r\n    mcp_app = FastMCP(\"knowledge-base\", host=_args.host, port=_args.port)\r\nelse:\r\n    mcp_app = None\r\n\r\n_conn = None\r\n\r\n\r\ndef _get_conn():\r\n    global _conn\r\n    if _conn is None:\r\n        _conn = open_readonly(_args.db)\r\n        health = check_asset_health(_conn)\r\n        if not health[\"passed\"]:\r\n            failures = {k: v for k, v in health[\"details\"].items() if not v[\"ok\"]}\r\n            raise RuntimeError(f\"Asset health check failed: {failures}\")\r\n        logger.info(\"Health check passed: %s\",\r\n                    {k: v[\"count\"] for k, v in health[\"details\"].items()})\r\n    return _conn\r\n\r\n\r\n# ── helpers ──\r\n\r\ndef _parse_exam_year(exam_id: str) -> int | None:\r\n    \"\"\"GK_2023_GD_04 → 2023\"\"\"\r\n    try:\r\n        return int(exam_id.split('_')[1])\r\n    except (IndexError, ValueError):\r\n        return None\r\n\r\n\r\n# ── resolve_topic ──\r\n\r\n_SUBJECT_ALIASES = {\r\n    \"生物\": \"biology_senior\", \"高中生物\": \"biology_senior\",\r\n    \"biology\": \"biology_senior\", \"bio\": \"biology_senior\",\r\n}\r\n\r\ndef _resolve_topic(conn, query=None, subject=\"biology_senior\",\r\n                   module=None, da_ids=None, candidate_limit=5):\r\n    candidate_limit = min(candidate_limit or 5, 10)\r\n    # 标准化 subject（Agent 可能传中文\"生物\"或英文别名）\r\n    if subject:\r\n        subject = _SUBJECT_ALIASES.get(subject, subject)\r\n    conditions, params = [], []\r\n\r\n    if query:\r\n        # 拆关键词，任一匹配即可（Agent 常传多词查询如\"渗透作用 植物吸水\"）\r\n        keywords = [kw.strip() for kw in query.split() if kw.strip()]\r\n        if keywords:\r\n            kw_conds = []\r\n            for kw in keywords:\r\n                kw_conds.append(\"(su.name LIKE ? OR su.description LIKE ?)\")\r\n                params.extend([f'%{kw}%', f'%{kw}%'])\r\n            conditions.append(f\"({' OR '.join(kw_conds)})\")\r\n    if module:\r\n        conditions.append(\"su.module = ?\")\r\n        params.append(module)\r\n\r\n    where = \" AND \".join(conditions) if conditions else \"1=1\"\r\n    rows = conn.execute(f\"\"\"\r\n        SELECT su.id, su.name, su.module, su.linked_da_ids,\r\n               su.exemplar_item_ids, su.textbook_anchor_ids\r\n        FROM study_units su WHERE {where} ORDER BY su.id\r\n    \"\"\", params).fetchall()\r\n\r\n    candidates = []\r\n    for row in rows:\r\n        linked_das = json.loads(row[\"linked_da_ids\"] or \"[]\")\r\n        if da_ids and not any(d in linked_das for d in da_ids):\r\n            continue\r\n        candidates.append({\r\n            \"study_unit_id\": row[\"id\"], \"name\": row[\"name\"], \"module\": row[\"module\"],\r\n            \"linked_da_ids\": linked_das,\r\n            \"exemplar_item_count\": len(json.loads(row[\"exemplar_item_ids\"] or \"[]\")),\r\n            \"textbook_anchor_count\": len(json.loads(row[\"textbook_anchor_ids\"] or \"[]\")),\r\n        })\r\n        if len(candidates) >= candidate_limit:\r\n            break\r\n\r\n    asset_health = {}\r\n    for table in [\"assessment_items\", \"content_blocks\", \"curriculum_requirements\", \"concepts\"]:\r\n        try:\r\n            asset_health[table] = conn.execute(f\"SELECT COUNT(*) FROM [{table}]\").fetchone()[0]\r\n        except Exception:\r\n            asset_health[table] = 0\r\n\r\n    return {\"candidates\": candidates, \"asset_health\": asset_health}\r\n\r\n\r\nif mcp_app:\r\n    @mcp_app.tool()\r\n    async def resolve_topic(query: str = None, subject: str = \"biology_senior\",\r\n                            module: str = None, da_ids: list[str] = None,\r\n                            candidate_limit: int = 5) -> str:\r\n        \"\"\"把教师自然语言映射成可挖掘的 StudyUnit 候选。\"\"\"\r\n        return json.dumps(_resolve_topic(\r\n            _get_conn(), query, subject, module, da_ids, min(candidate_limit or 5, 10)\r\n        ), ensure_ascii=False, indent=2)\r\n\r\n\r\n# ── get_unit_snapshot ──\r\n\r\ndef _get_unit_snapshot(conn, study_unit_id, include=None):\r\n    include = include or []\r\n    row = conn.execute(\"SELECT * FROM study_units WHERE id = ?\", (study_unit_id,)).fetchone()\r\n    if not row:\r\n        return {\"error\": \"not_found\", \"study_unit_id\": study_unit_id}\r\n\r\n    su = {\r\n        \"id\": row[\"id\"], \"name\": row[\"name\"], \"module\": row[\"module\"],\r\n        \"linked_da_ids\": json.loads(row[\"linked_da_ids\"] or \"[]\"),\r\n        \"textbook_anchor_ids\": json.loads(row[\"textbook_anchor_ids\"] or \"[]\"),\r\n        \"exemplar_item_ids\": json.loads(row[\"exemplar_item_ids\"] or \"[]\"),\r\n        \"prerequisite_unit_ids\": json.loads(row[\"prerequisite_unit_ids\"] or \"[]\"),\r\n        \"estimated_minutes\": row[\"estimated_minutes\"],\r\n    }\r\n    result = {\"study_unit\": su}\r\n\r\n    if \"da\" in include:\r\n        result[\"da_summaries\"] = []\r\n        for da_id in su[\"linked_da_ids\"]:\r\n            da = conn.execute(\"SELECT id,name,description,required_evidence_modes FROM diagnostic_attributes WHERE id=?\", (da_id,)).fetchone()\r\n            if da:\r\n                result[\"da_summaries\"].append({\"id\": da[\"id\"], \"name\": da[\"name\"],\r\n                    \"description\": da[\"description\"],\r\n                    \"required_evidence_modes\": json.loads(da[\"required_evidence_modes\"] or \"[]\")})\r\n\r\n    if \"exemplar_items\" in include:\r\n        result[\"exemplar_items\"] = []\r\n        for item_id in su[\"exemplar_item_ids\"]:\r\n            it = conn.execute(\"SELECT id,question_number,question_type,task_model_id FROM assessment_items WHERE id=?\", (item_id,)).fetchone()\r\n            if it:\r\n                result[\"exemplar_items\"].append(dict(it))\r\n\r\n    if \"textbook_anchor_stats\" in include:\r\n        aids = su[\"textbook_anchor_ids\"]\r\n        if aids:\r\n            ph = \",\".join(\"?\" * len(aids))\r\n            blocks = conn.execute(f\"SELECT type FROM content_blocks WHERE id IN ({ph})\", aids).fetchall()\r\n            tc = {}\r\n            for b in blocks:\r\n                tc[b[\"type\"]] = tc.get(b[\"type\"], 0) + 1\r\n            result[\"anchor_stats\"] = {\"total_blocks\": len(blocks), \"block_type_counts\": tc}\r\n        else:\r\n            result[\"anchor_stats\"] = {\"total_blocks\": 0, \"block_type_counts\": {}}\r\n\r\n    return result\r\n\r\n\r\nif mcp_app:\r\n    @mcp_app.tool()\r\n    async def get_unit_snapshot(study_unit_id: str, include: list[str] = None) -> str:\r\n        \"\"\"快速判断一个教学单元值不值得深挖。\"\"\"\r\n        return json.dumps(_get_unit_snapshot(_get_conn(), study_unit_id, include), ensure_ascii=False, indent=2)\r\n\r\n\r\n# ── sample_exam_evidence ──\r\n\r\ndef _sample_exam_evidence(conn, study_unit_id=None, da_ids=None,\r\n                          task_model_ids=None, year_start=None, year_end=None,\r\n                          transfer_band=None, question_type=None, limit=3, view=\"snippet\"):\r\n    limit = min(limit or 3, 5)\r\n    empty = {\"items\": [], \"retrieval_meta\": {\"total_hits\": 0, \"truncated\": False, \"filters_applied\": []}}\r\n\r\n    # 确定 DA IDs\r\n    target_das = list(da_ids) if da_ids else []\r\n    if study_unit_id and not target_das:\r\n        su = conn.execute(\"SELECT linked_da_ids FROM study_units WHERE id=?\", (study_unit_id,)).fetchone()\r\n        if su:\r\n            target_das = json.loads(su[\"linked_da_ids\"] or \"[]\")\r\n    if not target_das:\r\n        return empty\r\n\r\n    # q_matrix → item_ids\r\n    ph = \",\".join(\"?\" * len(target_das))\r\n    qparams = list(target_das)\r\n    band_sql = \"\"\r\n    filters = []\r\n    if transfer_band:\r\n        band_sql = \" AND qm.transfer_band = ?\"\r\n        qparams.append(transfer_band)\r\n        filters.append(f\"transfer_band={transfer_band}\")\r\n\r\n    item_ids = [r[0] for r in conn.execute(\r\n        f\"SELECT DISTINCT qm.item_id FROM q_matrix qm WHERE qm.attribute_id IN ({ph}){band_sql}\", qparams\r\n    ).fetchall()]\r\n    if not item_ids:\r\n        return empty\r\n\r\n    # assessment_items\r\n    ip = \",\".join(\"?\" * len(item_ids))\r\n    conds = [f\"ai.id IN ({ip})\"]\r\n    aparams = list(item_ids)\r\n    if question_type:\r\n        conds.append(\"ai.question_type = ?\"); aparams.append(question_type); filters.append(f\"question_type={question_type}\")\r\n    if task_model_ids:\r\n        tp = \",\".join(\"?\" * len(task_model_ids))\r\n        conds.append(f\"ai.task_model_id IN ({tp})\"); aparams.extend(task_model_ids)\r\n\r\n    all_rows = conn.execute(f\"\"\"\r\n        SELECT ai.id, ai.exam_id, ai.question_type, ai.stem, ai.options,\r\n               ai.answer, ai.explanation, ai.task_model_id, ai.option_diagnosis\r\n        FROM assessment_items ai WHERE {\" AND \".join(conds)} ORDER BY ai.exam_id DESC\r\n    \"\"\", aparams).fetchall()\r\n\r\n    # year 过滤（从 exam_id 解析）\r\n    has_year_filter = year_start or year_end\r\n    filtered = []\r\n    for row in all_rows:\r\n        year = _parse_exam_year(row[\"exam_id\"])\r\n        if has_year_filter and year is None:\r\n            continue  # F-002: 有年份过滤时排除无法解析年份的记录\r\n        if year_start and year and year < year_start: continue\r\n        if year_end and year and year > year_end: continue\r\n        filtered.append((row, year))\r\n\r\n    total = len(filtered)\r\n    filtered = filtered[:limit]\r\n\r\n    items = []\r\n    for row, year in filtered:\r\n        stem_el = json.loads(row[\"stem\"]) if isinstance(row[\"stem\"], str) else (row[\"stem\"] or [])\r\n        opts_d = json.loads(row[\"options\"]) if isinstance(row[\"options\"], str) else row[\"options\"]\r\n        expl_el = json.loads(row[\"explanation\"]) if isinstance(row[\"explanation\"], str) else (row[\"explanation\"] or [])\r\n\r\n        da_links = [{\"da_id\": d[\"attribute_id\"], \"transfer_band\": d[\"transfer_band\"],\r\n                     \"required\": bool(d[\"required\"])}\r\n                    for d in conn.execute(\"SELECT attribute_id,transfer_band,required FROM q_matrix WHERE item_id=?\",\r\n                                         (row[\"id\"],)).fetchall()]\r\n\r\n        items.append({\r\n            \"id\": row[\"id\"], \"exam_id\": row[\"exam_id\"], \"year\": year,\r\n            \"question_type\": row[\"question_type\"], \"task_model_id\": row[\"task_model_id\"],\r\n            \"stem_plain\": rich_elements_to_plain(stem_el),\r\n            \"options_plain\": options_to_plain(opts_d),\r\n            \"answer\": row[\"answer\"],\r\n            \"explanation_summary\": rich_elements_to_plain(expl_el)[:200],\r\n            \"option_diagnosis\": json.loads(row[\"option_diagnosis\"]) if row[\"option_diagnosis\"] else None,\r\n            \"da_links\": da_links,\r\n        })\r\n\r\n    return {\"items\": items, \"retrieval_meta\": {\"total_hits\": total, \"truncated\": total > limit, \"filters_applied\": filters}}\r\n\r\n\r\nif mcp_app:\r\n    @mcp_app.tool()\r\n    async def sample_exam_evidence(study_unit_id: str = None, da_ids: list[str] = None,\r\n                                    task_model_ids: list[str] = None,\r\n                                    year_start: int = None, year_end: int = None,\r\n                                    transfer_band: str = None, question_type: str = None,\r\n                                    limit: int = 3, view: str = \"snippet\") -> str:\r\n        \"\"\"取题目证据，供 Agent 生成张力卡片。\"\"\"\r\n        return json.dumps(_sample_exam_evidence(\r\n            _get_conn(), study_unit_id, da_ids, task_model_ids,\r\n            year_start, year_end, transfer_band, question_type, limit, view\r\n        ), ensure_ascii=False, indent=2)\r\n\r\n\r\n# ── get_textbook_context ──\r\n\r\n_BLOCK_TYPE_ALIASES = {\r\n    \"概念讲解\": \"body_text\", \"正文\": \"body_text\",\r\n    \"实验\": \"experiment\", \"实验步骤\": \"experiment\",\r\n    \"探究\": \"problem_exploration\", \"问题探究\": \"problem_exploration\",\r\n    \"思考讨论\": \"think_discuss\", \"讨论\": \"think_discuss\",\r\n    \"练习\": \"exercise\", \"习题\": \"exercise\",\r\n    \"关键术语\": \"key_term\", \"术语\": \"key_term\",\r\n    \"图表\": \"figure\", \"表格\": \"table\",\r\n    \"科学史\": \"science_history\", \"公式\": \"formula\",\r\n    \"数据分析\": \"data_analysis\", \"知识链接\": \"knowledge_link\",\r\n    \"旁栏\": \"sidebar\", \"章末总结\": \"chapter_summary\",\r\n    \"复习题\": \"review_exercise\", \"联系实际\": \"explore_practice\",\r\n}\r\n\r\ndef _normalize_block_types(block_types):\r\n    \"\"\"Agent 可能传中文 block type，映射为 schema 值。\"\"\"\r\n    if not block_types:\r\n        return None\r\n    return [_BLOCK_TYPE_ALIASES.get(bt, bt) for bt in block_types]\r\n\r\n\r\ndef _get_textbook_context(conn, study_unit_id=None, block_ids=None,\r\n                          block_types=None, neighbor_window=1, limit=5, view=\"snippet\"):\r\n    limit = min(limit or 5, 8)\r\n    neighbor_window = min(neighbor_window or 1, 2)\r\n    block_types = _normalize_block_types(block_types)\r\n\r\n    target_ids = list(block_ids) if block_ids else []\r\n    if study_unit_id and not target_ids:\r\n        su = conn.execute(\"SELECT textbook_anchor_ids FROM study_units WHERE id=?\", (study_unit_id,)).fetchone()\r\n        if su:\r\n            target_ids = json.loads(su[\"textbook_anchor_ids\"] or \"[]\")\r\n    if not target_ids:\r\n        return {\"blocks\": [], \"section_contexts\": [], \"retrieval_meta\": {\"total_hits\": 0, \"truncated\": False}}\r\n\r\n    ph = \",\".join(\"?\" * len(target_ids))\r\n    params = list(target_ids)\r\n    type_sql = \"\"\r\n    if block_types:\r\n        tp = \",\".join(\"?\" * len(block_types))\r\n        type_sql = f\" AND cb.type IN ({tp})\"\r\n        params.extend(block_types)\r\n\r\n    rows = conn.execute(f\"\"\"\r\n        SELECT cb.id,cb.section_id,cb.document_id,cb.type,cb.title,cb.page,cb.content,cb.ordinal\r\n        FROM content_blocks cb WHERE cb.id IN ({ph}){type_sql} ORDER BY cb.page,cb.ordinal LIMIT ?\r\n    \"\"\", params + [limit]).fetchall()\r\n\r\n    blocks = []\r\n    sec_ids = set()\r\n    for row in rows:\r\n        sec_ids.add(row[\"section_id\"])\r\n        # 邻居块：按 ordinal 位置取前后 N 个（F-004 修复：基于位置相邻）\r\n        nbrs = []\r\n        if neighbor_window > 0:\r\n            cur_ord = row[\"ordinal\"] if \"ordinal\" in row.keys() else 0\r\n            nbrs = [n[\"id\"] for n in conn.execute(\r\n                \"SELECT id FROM content_blocks WHERE section_id=? AND id!=? AND ordinal BETWEEN ? AND ? ORDER BY ordinal\",\r"
    }
  ],
  "structuredContent": {
    "content": "\"\"\"knowledge-base MCP Server — 教育知识库 5 工具。\r\n启动：python server.py --db /path/to/knowledge.db [--transport stdio|sse] [--port 9106]\r\n\"\"\"\r\nfrom __future__ import annotations\r\n\r\nimport argparse\r\nimport json\r\nimport logging\r\nimport os\r\nimport sys\r\n\r\nlogging.basicConfig(level=logging.INFO,\r\n                    format=\"%(asctime)s [%(levelname)s] %(name)s: %(message)s\")\r\nlogger = logging.getLogger(\"knowledge-mcp\")\r\n\r\ntry:\r\n    from mcp.server.fastmcp import FastMCP\r\nexcept ImportError:\r\n    FastMCP = None\r\n\r\ntry:\r\n    from .db import open_readonly, check_asset_health\r\n    from .richtext import rich_elements_to_plain, options_to_plain\r\nexcept ImportError:\r\n    from db import open_readonly, check_asset_health\r\n    from richtext import rich_elements_to_plain, options_to_plain\r\n\r\n\r\ndef _parse_args() -> argparse.Namespace:\r\n    parser = argparse.ArgumentParser(description=\"Knowledge-base MCP Server\")\r\n    parser.add_argument(\"--db\", default=os.environ.get(\"KNOWLEDGE_DB\", \"knowledge.db\"))\r\n    parser.add_argument(\"--transport\", default=\"stdio\", choices=[\"stdio\", \"sse\"])\r\n    parser.add_argument(\"--host\", default=os.environ.get(\"MCP_HOST\", \"127.0.0.1\"))\r\n    parser.add_argument(\"--port\", type=int, default=int(os.environ.get(\"MCP_PORT\", \"9106\")))\r\n    if __name__ == \"__main__\":\r\n        return parser.parse_args()\r\n    return parser.parse_args([])\r\n\r\n\r\n_args = _parse_args()\r\n\r\nif FastMCP:\r\n    mcp_app = FastMCP(\"knowledge-base\", host=_args.host, port=_args.port)\r\nelse:\r\n    mcp_app = None\r\n\r\n_conn = None\r\n\r\n\r\ndef _get_conn():\r\n    global _conn\r\n    if _conn is None:\r\n        _conn = open_readonly(_args.db)\r\n        health = check_asset_health(_conn)\r\n        if not health[\"passed\"]:\r\n            failures = {k: v for k, v in health[\"details\"].items() if not v[\"ok\"]}\r\n            raise RuntimeError(f\"Asset health check failed: {failures}\")\r\n        logger.info(\"Health check passed: %s\",\r\n                    {k: v[\"count\"] for k, v in health[\"details\"].items()})\r\n    return _conn\r\n\r\n\r\n# ── helpers ──\r\n\r\ndef _parse_exam_year(exam_id: str) -> int | None:\r\n    \"\"\"GK_2023_GD_04 → 2023\"\"\"\r\n    try:\r\n        return int(exam_id.split('_')[1])\r\n    except (IndexError, ValueError):\r\n        return None\r\n\r\n\r\n# ── resolve_topic ──\r\n\r\n_SUBJECT_ALIASES = {\r\n    \"生物\": \"biology_senior\", \"高中生物\": \"biology_senior\",\r\n    \"biology\": \"biology_senior\", \"bio\": \"biology_senior\",\r\n}\r\n\r\ndef _resolve_topic(conn, query=None, subject=\"biology_senior\",\r\n                   module=None, da_ids=None, candidate_limit=5):\r\n    candidate_limit = min(candidate_limit or 5, 10)\r\n    # 标准化 subject（Agent 可能传中文\"生物\"或英文别名）\r\n    if subject:\r\n        subject = _SUBJECT_ALIASES.get(subject, subject)\r\n    conditions, params = [], []\r\n\r\n    if query:\r\n        # 拆关键词，任一匹配即可（Agent 常传多词查询如\"渗透作用 植物吸水\"）\r\n        keywords = [kw.strip() for kw in query.split() if kw.strip()]\r\n        if keywords:\r\n            kw_conds = []\r\n            for kw in keywords:\r\n                kw_conds.append(\"(su.name LIKE ? OR su.description LIKE ?)\")\r\n                params.extend([f'%{kw}%', f'%{kw}%'])\r\n            conditions.append(f\"({' OR '.join(kw_conds)})\")\r\n    if module:\r\n        conditions.append(\"su.module = ?\")\r\n        params.append(module)\r\n\r\n    where = \" AND \".join(conditions) if conditions else \"1=1\"\r\n    rows = conn.execute(f\"\"\"\r\n        SELECT su.id, su.name, su.module, su.linked_da_ids,\r\n               su.exemplar_item_ids, su.textbook_anchor_ids\r\n        FROM study_units su WHERE {where} ORDER BY su.id\r\n    \"\"\", params).fetchall()\r\n\r\n    candidates = []\r\n    for row in rows:\r\n        linked_das = json.loads(row[\"linked_da_ids\"] or \"[]\")\r\n        if da_ids and not any(d in linked_das for d in da_ids):\r\n            continue\r\n        candidates.append({\r\n            \"study_unit_id\": row[\"id\"], \"name\": row[\"name\"], \"module\": row[\"module\"],\r\n            \"linked_da_ids\": linked_das,\r\n            \"exemplar_item_count\": len(json.loads(row[\"exemplar_item_ids\"] or \"[]\")),\r\n            \"textbook_anchor_count\": len(json.loads(row[\"textbook_anchor_ids\"] or \"[]\")),\r\n        })\r\n        if len(candidates) >= candidate_limit:\r\n            break\r\n\r\n    asset_health = {}\r\n    for table in [\"assessment_items\", \"content_blocks\", \"curriculum_requirements\", \"concepts\"]:\r\n        try:\r\n            asset_health[table] = conn.execute(f\"SELECT COUNT(*) FROM [{table}]\").fetchone()[0]\r\n        except Exception:\r\n            asset_health[table] = 0\r\n\r\n    return {\"candidates\": candidates, \"asset_health\": asset_health}\r\n\r\n\r\nif mcp_app:\r\n    @mcp_app.tool()\r\n    async def resolve_topic(query: str = None, subject: str = \"biology_senior\",\r\n                            module: str = None, da_ids: list[str] = None,\r\n                            candidate_limit: int = 5) -> str:\r\n        \"\"\"把教师自然语言映射成可挖掘的 StudyUnit 候选。\"\"\"\r\n        return json.dumps(_resolve_topic(\r\n            _get_conn(), query, subject, module, da_ids, min(candidate_limit or 5, 10)\r\n        ), ensure_ascii=False, indent=2)\r\n\r\n\r\n# ── get_unit_snapshot ──\r\n\r\ndef _get_unit_snapshot(conn, study_unit_id, include=None):\r\n    include = include or []\r\n    row = conn.execute(\"SELECT * FROM study_units WHERE id = ?\", (study_unit_id,)).fetchone()\r\n    if not row:\r\n        return {\"error\": \"not_found\", \"study_unit_id\": study_unit_id}\r\n\r\n    su = {\r\n        \"id\": row[\"id\"], \"name\": row[\"name\"], \"module\": row[\"module\"],\r\n        \"linked_da_ids\": json.loads(row[\"linked_da_ids\"] or \"[]\"),\r\n        \"textbook_anchor_ids\": json.loads(row[\"textbook_anchor_ids\"] or \"[]\"),\r\n        \"exemplar_item_ids\": json.loads(row[\"exemplar_item_ids\"] or \"[]\"),\r\n        \"prerequisite_unit_ids\": json.loads(row[\"prerequisite_unit_ids\"] or \"[]\"),\r\n        \"estimated_minutes\": row[\"estimated_minutes\"],\r\n    }\r\n    result = {\"study_unit\": su}\r\n\r\n    if \"da\" in include:\r\n        result[\"da_summaries\"] = []\r\n        for da_id in su[\"linked_da_ids\"]:\r\n            da = conn.execute(\"SELECT id,name,description,required_evidence_modes FROM diagnostic_attributes WHERE id=?\", (da_id,)).fetchone()\r\n            if da:\r\n                result[\"da_summaries\"].append({\"id\": da[\"id\"], \"name\": da[\"name\"],\r\n                    \"description\": da[\"description\"],\r\n                    \"required_evidence_modes\": json.loads(da[\"required_evidence_modes\"] or \"[]\")})\r\n\r\n    if \"exemplar_items\" in include:\r\n        result[\"exemplar_items\"] = []\r\n        for item_id in su[\"exemplar_item_ids\"]:\r\n            it = conn.execute(\"SELECT id,question_number,question_type,task_model_id FROM assessment_items WHERE id=?\", (item_id,)).fetchone()\r\n            if it:\r\n                result[\"exemplar_items\"].append(dict(it))\r\n\r\n    if \"textbook_anchor_stats\" in include:\r\n        aids = su[\"textbook_anchor_ids\"]\r\n        if aids:\r\n            ph = \",\".join(\"?\" * len(aids))\r\n            blocks = conn.execute(f\"SELECT type FROM content_blocks WHERE id IN ({ph})\", aids).fetchall()\r\n            tc = {}\r\n            for b in blocks:\r\n                tc[b[\"type\"]] = tc.get(b[\"type\"], 0) + 1\r\n            result[\"anchor_stats\"] = {\"total_blocks\": len(blocks), \"block_type_counts\": tc}\r\n        else:\r\n            result[\"anchor_stats\"] = {\"total_blocks\": 0, \"block_type_counts\": {}}\r\n\r\n    return result\r\n\r\n\r\nif mcp_app:\r\n    @mcp_app.tool()\r\n    async def get_unit_snapshot(study_unit_id: str, include: list[str] = None) -> str:\r\n        \"\"\"快速判断一个教学单元值不值得深挖。\"\"\"\r\n        return json.dumps(_get_unit_snapshot(_get_conn(), study_unit_id, include), ensure_ascii=False, indent=2)\r\n\r\n\r\n# ── sample_exam_evidence ──\r\n\r\ndef _sample_exam_evidence(conn, study_unit_id=None, da_ids=None,\r\n                          task_model_ids=None, year_start=None, year_end=None,\r\n                          transfer_band=None, question_type=None, limit=3, view=\"snippet\"):\r\n    limit = min(limit or 3, 5)\r\n    empty = {\"items\": [], \"retrieval_meta\": {\"total_hits\": 0, \"truncated\": False, \"filters_applied\": []}}\r\n\r\n    # 确定 DA IDs\r\n    target_das = list(da_ids) if da_ids else []\r\n    if study_unit_id and not target_das:\r\n        su = conn.execute(\"SELECT linked_da_ids FROM study_units WHERE id=?\", (study_unit_id,)).fetchone()\r\n        if su:\r\n            target_das = json.loads(su[\"linked_da_ids\"] or \"[]\")\r\n    if not target_das:\r\n        return empty\r\n\r\n    # q_matrix → item_ids\r\n    ph = \",\".join(\"?\" * len(target_das))\r\n    qparams = list(target_das)\r\n    band_sql = \"\"\r\n    filters = []\r\n    if transfer_band:\r\n        band_sql = \" AND qm.transfer_band = ?\"\r\n        qparams.append(transfer_band)\r\n        filters.append(f\"transfer_band={transfer_band}\")\r\n\r\n    item_ids = [r[0] for r in conn.execute(\r\n        f\"SELECT DISTINCT qm.item_id FROM q_matrix qm WHERE qm.attribute_id IN ({ph}){band_sql}\", qparams\r\n    ).fetchall()]\r\n    if not item_ids:\r\n        return empty\r\n\r\n    # assessment_items\r\n    ip = \",\".join(\"?\" * len(item_ids))\r\n    conds = [f\"ai.id IN ({ip})\"]\r\n    aparams = list(item_ids)\r\n    if question_type:\r\n        conds.append(\"ai.question_type = ?\"); aparams.append(question_type); filters.append(f\"question_type={question_type}\")\r\n    if task_model_ids:\r\n        tp = \",\".join(\"?\" * len(task_model_ids))\r\n        conds.append(f\"ai.task_model_id IN ({tp})\"); aparams.extend(task_model_ids)\r\n\r\n    all_rows = conn.execute(f\"\"\"\r\n        SELECT ai.id, ai.exam_id, ai.question_type, ai.stem, ai.options,\r\n               ai.answer, ai.explanation, ai.task_model_id, ai.option_diagnosis\r\n        FROM assessment_items ai WHERE {\" AND \".join(conds)} ORDER BY ai.exam_id DESC\r\n    \"\"\", aparams).fetchall()\r\n\r\n    # year 过滤（从 exam_id 解析）\r\n    has_year_filter = year_start or year_end\r\n    filtered = []\r\n    for row in all_rows:\r\n        year = _parse_exam_year(row[\"exam_id\"])\r\n        if has_year_filter and year is None:\r\n            continue  # F-002: 有年份过滤时排除无法解析年份的记录\r\n        if year_start and year and year < year_start: continue\r\n        if year_end and year and year > year_end: continue\r\n        filtered.append((row, year))\r\n\r\n    total = len(filtered)\r\n    filtered = filtered[:limit]\r\n\r\n    items = []\r\n    for row, year in filtered:\r\n        stem_el = json.loads(row[\"stem\"]) if isinstance(row[\"stem\"], str) else (row[\"stem\"] or [])\r\n        opts_d = json.loads(row[\"options\"]) if isinstance(row[\"options\"], str) else row[\"options\"]\r\n        expl_el = json.loads(row[\"explanation\"]) if isinstance(row[\"explanation\"], str) else (row[\"explanation\"] or [])\r\n\r\n        da_links = [{\"da_id\": d[\"attribute_id\"], \"transfer_band\": d[\"transfer_band\"],\r\n                     \"required\": bool(d[\"required\"])}\r\n                    for d in conn.execute(\"SELECT attribute_id,transfer_band,required FROM q_matrix WHERE item_id=?\",\r\n                                         (row[\"id\"],)).fetchall()]\r\n\r\n        items.append({\r\n            \"id\": row[\"id\"], \"exam_id\": row[\"exam_id\"], \"year\": year,\r\n            \"question_type\": row[\"question_type\"], \"task_model_id\": row[\"task_model_id\"],\r\n            \"stem_plain\": rich_elements_to_plain(stem_el),\r\n            \"options_plain\": options_to_plain(opts_d),\r\n            \"answer\": row[\"answer\"],\r\n            \"explanation_summary\": rich_elements_to_plain(expl_el)[:200],\r\n            \"option_diagnosis\": json.loads(row[\"option_diagnosis\"]) if row[\"option_diagnosis\"] else None,\r\n            \"da_links\": da_links,\r\n        })\r\n\r\n    return {\"items\": items, \"retrieval_meta\": {\"total_hits\": total, \"truncated\": total > limit, \"filters_applied\": filters}}\r\n\r\n\r\nif mcp_app:\r\n    @mcp_app.tool()\r\n    async def sample_exam_evidence(study_unit_id: str = None, da_ids: list[str] = None,\r\n                                    task_model_ids: list[str] = None,\r\n                                    year_start: int = None, year_end: int = None,\r\n                                    transfer_band: str = None, question_type: str = None,\r\n                                    limit: int = 3, view: str = \"snippet\") -> str:\r\n        \"\"\"取题目证据，供 Agent 生成张力卡片。\"\"\"\r\n        return json.dumps(_sample_exam_evidence(\r\n            _get_conn(), study_unit_id, da_ids, task_model_ids,\r\n            year_start, year_end, transfer_band, question_type, limit, view\r\n        ), ensure_ascii=False, indent=2)\r\n\r\n\r\n# ── get_textbook_context ──\r\n\r\n_BLOCK_TYPE_ALIASES = {\r\n    \"概念讲解\": \"body_text\", \"正文\": \"body_text\",\r\n    \"实验\": \"experiment\", \"实验步骤\": \"experiment\",\r\n    \"探究\": \"problem_exploration\", \"问题探究\": \"problem_exploration\",\r\n    \"思考讨论\": \"think_discuss\", \"讨论\": \"think_discuss\",\r\n    \"练习\": \"exercise\", \"习题\": \"exercise\",\r\n    \"关键术语\": \"key_term\", \"术语\": \"key_term\",\r\n    \"图表\": \"figure\", \"表格\": \"table\",\r\n    \"科学史\": \"science_history\", \"公式\": \"formula\",\r\n    \"数据分析\": \"data_analysis\", \"知识链接\": \"knowledge_link\",\r\n    \"旁栏\": \"sidebar\", \"章末总结\": \"chapter_summary\",\r\n    \"复习题\": \"review_exercise\", \"联系实际\": \"explore_practice\",\r\n}\r\n\r\ndef _normalize_block_types(block_types):\r\n    \"\"\"Agent 可能传中文 block type，映射为 schema 值。\"\"\"\r\n    if not block_types:\r\n        return None\r\n    return [_BLOCK_TYPE_ALIASES.get(bt, bt) for bt in block_types]\r\n\r\n\r\ndef _get_textbook_context(conn, study_unit_id=None, block_ids=None,\r\n                          block_types=None, neighbor_window=1, limit=5, view=\"snippet\"):\r\n    limit = min(limit or 5, 8)\r\n    neighbor_window = min(neighbor_window or 1, 2)\r\n    block_types = _normalize_block_types(block_types)\r\n\r\n    target_ids = list(block_ids) if block_ids else []\r\n    if study_unit_id and not target_ids:\r\n        su = conn.execute(\"SELECT textbook_anchor_ids FROM study_units WHERE id=?\", (study_unit_id,)).fetchone()\r\n        if su:\r\n            target_ids = json.loads(su[\"textbook_anchor_ids\"] or \"[]\")\r\n    if not target_ids:\r\n        return {\"blocks\": [], \"section_contexts\": [], \"retrieval_meta\": {\"total_hits\": 0, \"truncated\": False}}\r\n\r\n    ph = \",\".join(\"?\" * len(target_ids))\r\n    params = list(target_ids)\r\n    type_sql = \"\"\r\n    if block_types:\r\n        tp = \",\".join(\"?\" * len(block_types))\r\n        type_sql = f\" AND cb.type IN ({tp})\"\r\n        params.extend(block_types)\r\n\r\n    rows = conn.execute(f\"\"\"\r\n        SELECT cb.id,cb.section_id,cb.document_id,cb.type,cb.title,cb.page,cb.content,cb.ordinal\r\n        FROM content_blocks cb WHERE cb.id IN ({ph}){type_sql} ORDER BY cb.page,cb.ordinal LIMIT ?\r\n    \"\"\", params + [limit]).fetchall()\r\n\r\n    blocks = []\r\n    sec_ids = set()\r\n    for row in rows:\r\n        sec_ids.add(row[\"section_id\"])\r\n        # 邻居块：按 ordinal 位置取前后 N 个（F-004 修复：基于位置相邻）\r\n        nbrs = []\r\n        if neighbor_window > 0:\r\n            cur_ord = row[\"ordinal\"] if \"ordinal\" in row.keys() else 0\r\n            nbrs = [n[\"id\"] for n in conn.execute(\r\n                \"SELECT id FROM content_blocks WHERE section_id=? AND id!=? AND ordinal BETWEEN ? AND ? ORDER BY ordinal\",\r"
  }
}
