import asyncio
from unittest.mock import AsyncMock, MagicMock, patch

from edu_cloud.modules.pipeline.service import _update_adaptive_mastery
from edu_cloud.modules.scan.models import StudentAnswer

class ScalarResult:
    def __init__(self, items):
        self._items = items
    def all(self):
        return self._items

class ExecuteResult:
    def __init__(self, *, scalars_items=None, all_items=None, scalar_one_or_none=None):
        self._scalars_items = scalars_items
        self._all_items = all_items
        self._scalar_one_or_none = scalar_one_or_none
    def scalars(self):
        return ScalarResult(self._scalars_items)
    def all(self):
        return self._all_items
    def scalar_one_or_none(self):
        return self._scalar_one_or_none

async def main():
    db = AsyncMock()
    subj = MagicMock(id='subj1')
    ans = StudentAnswer(exam_id='exam1', subject_id='subj1', student_id='stu1', question_id='q1', school_id='sch1')
    ans.id = 'a1'
    db.execute = AsyncMock(side_effect=[
        ExecuteResult(scalars_items=[subj]),                 # subjects
        ExecuteResult(all_items=[('q1', ['kp1'])]),          # question ids
        ExecuteResult(scalars_items=[ans]),                  # answers
        ExecuteResult(scalar_one_or_none=None),              # existing AnswerLog
    ])
    with patch('edu_cloud.modules.pipeline.service._get_effective_score', AsyncMock(return_value=1.0)), \\
         patch('edu_cloud.modules.adaptive.updater.process_answer', AsyncMock(return_value={})): 
        try:
            await _update_adaptive_mastery(db, exam_id='exam1', school_id='sch1')
        except Exception as e:
            print(type(e).__name__, str(e))

asyncio.run(main())
