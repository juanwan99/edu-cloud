import asyncio
from datetime import datetime
from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker
from edu_cloud.models.base import Base
from edu_cloud.modules.knowledge_tree.models import ConceptGraphNode, ConceptBigConceptMap
from edu_cloud.modules.knowledge_tree.service import apply_edits, get_graph

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:')
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, expire_on_commit=False)
    async with Session() as db:
        now = datetime.now()
        db.add(ConceptGraphNode(id='BC1', name='bc', knowledge_level='L1', primary_module='M1', node_type='big_concept', synced_at=now))
        for i,cid in enumerate(['A','B','C']):
            db.add(ConceptGraphNode(id=cid, name=cid, knowledge_level='L1', primary_module='M1', node_type='concept', synced_at=now, display_order=i))
        await db.flush()
        for cid in ['A','B','C']:
            db.add(ConceptBigConceptMap(concept_id=cid, big_concept_id='BC1', is_primary=True))
        await db.commit()
        before = await get_graph(db, 'all')
        await apply_edits(db, [{'op':'reorder','big_concept_id':'BC1','concept_ids':['C','A','B']}])
        after = await get_graph(db, 'all')
        print('before_nav', before['navigation'][0]['big_concepts'][0]['concept_ids'])
        print('after_nav', after['navigation'][0]['big_concepts'][0]['concept_ids'])
        for cid in ['A','B','C']:
            node = await db.get(ConceptGraphNode, cid)
            print(cid, node.display_order)

asyncio.run(main())
