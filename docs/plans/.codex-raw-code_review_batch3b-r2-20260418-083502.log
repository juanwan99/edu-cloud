    90	.item { border: 1px solid var(--border-color); border-radius: 4px; padding: 10px; margin-bottom: 8px; }
    91	.item-header { display: flex; gap: 8px; margin-bottom: 6px; font-size: 12px; }
    92	.type-tag { background: var(--primary-color-hover); color: white; padding: 2px 6px; border-radius: 3px; }
