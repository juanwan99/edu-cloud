    31	<script setup>
    32	import { ref, watch, computed } from 'vue'
    33	import { NButton } from 'naive-ui'
    34	import { getExamItems } from '../../api/knowledgeTree'
    35	
    36	const props = defineProps({
    37	  nodeId: { type: String, required: true },
    38	})
    39	
    40	const items = ref([])
    41	const total = ref(0)
    42	const page = ref(1)
    43	const pageSize = ref(10)
    44	const loading = ref(false)
    45	
    46	let fetchSeq = 0
    47	
    48	const totalPages = computed(() => Math.max(1, Math.ceil(total.value / pageSize.value)))
    49	
    50	async function load() {
    51	  if (!props.nodeId) return
    52	  const mySeq = ++fetchSeq
    53	  loading.value = true
    54	  try {
    55	    const data = await getExamItems(props.nodeId, page.value, pageSize.value)
    56	    if (mySeq !== fetchSeq) return
    57	    items.value = data.items || []
    58	    total.value = data.total || 0
    59	  } catch (e) {
    60	    if (mySeq !== fetchSeq) return
    61	    items.value = []
    62	    total.value = 0
    63	  } finally {
    64	    if (mySeq === fetchSeq) loading.value = false
    65	  }
    66	}
    67	
    68	function prevPage() { if (page.value > 1) { page.value--; load() } }
    69	function nextPage() { if (page.value < totalPages.value) { page.value++; load() } }
    70	
    71	watch(() => props.nodeId, () => { page.value = 1; load() }, { immediate: true })
    72	
    73	function truncate(text, n) {
    74	  if (!text) return ''
    75	  return text.length > n ? text.slice(0, n) + '…' : text
    76	}
    77	function itemTypeLabel(type) {
    78	  return { single_choice: '单选', multiple_choice: '多选', non_choice: '主观题' }[type] || type
    79	}
    80	function formatExamId(examId) {
    81	  const m = /GK_(\d{4})_([A-Z]+)/.exec(examId || '')
    82	  return m ? `${m[1]} ${m[2]}` : examId
    83	}
    84	</script>
