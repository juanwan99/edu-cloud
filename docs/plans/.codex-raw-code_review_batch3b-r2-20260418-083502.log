    81	    map[n.id] = n
    82	  }
    83	  return map
    84	})
    85	
    86	const treeData = computed(() => {
    87	  if (!props.navigation || props.navigation.length === 0) {
    88	    return []
    89	  }
    90	  return props.navigation.map(mod => {
    91	    const modMastery = props.moduleMastery.find(m => m.module === mod.id)
    92	    return {
    93	      key: mod.id,
    94	      label: mod.name,
    95	      mastery: modMastery?.mastery ?? 0,
    96	      children: (mod.big_concepts || []).map(bc => ({
    97	        key: bc.id,
    98	        label: bc.name,
    99	        children: (bc.concept_ids || []).map(cid => {
   100	          const node = nodeMap.value[cid]
   101	          return {
   102	            key: cid,
   103	            label: node?.name || cid,
   104	            isLeaf: true,
   105	            mastery: node?.mastery ?? 0,
   106	            reviewStatus: node?.review_status,
   107	          }
   108	        }),
   109	      })),
   110	    }
   111	  })
   112	})
   113	
   114	const chapterTreeData = computed(() => {
