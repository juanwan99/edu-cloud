   158	    .slice(0, 5)
   159	    .map(n => ({ concept_id: n.id, name: n.name, mastery: n.mastery }))
   160	})
   161	
   162	function renderSuffix({ option }) {
   163	  const parts = []
   164	  if (option.reviewStatus) {
   165	    const icon = reviewStatusIcons[option.reviewStatus] || ''
   166	    if (icon) parts.push(h('span', { style: { fontSize: '12px', marginRight: '4px' } }, icon))
   167	  }
   168	  const m = option.mastery ?? 0
   169	  if (m > 0) {
   170	    parts.push(h('span', {
   171	      style: { color: masteryColor(m), fontSize: '12px' },
   172	    }, Math.round(m * 100) + '%'))
   173	  }
   174	  return parts.length ? h('span', { style: { marginLeft: '4px' } }, parts) : null
   175	}
   176	
   177	function handleSelect(keys) {
   178	  if (keys.length > 0) {
   179	    const key = keys[0]
   180	    if (typeof key === 'string' && key.includes(':')) return
