    94	.score { color: var(--text-color-3); }
    95	.item-stem { font-size: 13px; line-height: 1.5; }
    96	.item-detail { margin-top: 8px; }
    97	.item-detail summary { cursor: pointer; font-size: 12px; color: var(--primary-color); }
