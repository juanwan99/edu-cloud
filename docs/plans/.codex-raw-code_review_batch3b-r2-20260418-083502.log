    55	  moduleMastery: { type: Array, default: () => [] },
    56	  nodesWithMastery: { type: Array, default: () => [] },
    57	  selectedModule: { type: String, default: 'all' },
    58	})
    59	const emit = defineEmits(['select-module', 'select-node'])
    60	
    61	const searchQuery = ref('')
