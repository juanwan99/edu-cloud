    63	const navMode = ref('module')
    64	
    65	const reviewStatusIcons = {
    66	  ai_draft: '🤖',
    67	  teacher_reviewed: '✅',
    68	  published: '📗',
    69	}
    70	
    71	function masteryColor(mastery) {
    72	  if (mastery >= 0.85) return '#22c55e'
    73	  if (mastery >= 0.6) return '#eab308'
    74	  if (mastery >= 0.3) return '#ef4444'
    75	  return '#6b7280'
    76	}
    77	
    78	const nodeMap = computed(() => {
    79	  const map = {}
