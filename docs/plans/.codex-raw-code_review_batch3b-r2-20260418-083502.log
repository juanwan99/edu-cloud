   118	    label: book.name,
   119	    children: book.chapters.map(ch => ({
   120	      key: `chapter:${book.id}:${ch.id}`,
   121	      label: ch.name,
   122	      children: ch.sections.map(s => ({
   123	        key: `section:${book.id}:${ch.id}:${s.id}`,
   124	        label: s.name,
   125	        children: s.concept_ids.map(cid => {
   126	          const node = nodeMap.value[cid]
   127	          return {
   128	            key: cid,
   129	            label: node?.name || cid,
   130	            isLeaf: true,
   131	            mastery: node?.mastery ?? 0,
   132	            reviewStatus: node?.review_status,
   133	          }
   134	        }),
   135	      })),
   136	    })),
   137	  }))
   138	})
