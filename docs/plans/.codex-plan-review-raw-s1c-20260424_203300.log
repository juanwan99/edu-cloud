  1252	            type_=sa.Integer(),
  1253	            existing_nullable=True,
  1254	            postgresql_using='NULLIF(grade_id, \'\')::integer',  # PG 空字符串→NULL→Integer
  1255	        )
  1256	
  1257	    # classes.grade_id FK + 列去除
  1258	    with op.batch_alter_table('classes', schema=None) as batch_op:
