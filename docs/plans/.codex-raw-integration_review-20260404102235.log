de_to_name, key=len, reverse=True):\n            text = text.replace(code, self._code_to_name[code])\n        return text\n\n    def reset(self):\n        self._name_to_code.clear()\n        self._code_to_name.clear()\n        self._counter = 0\n\n    @property\n    def mapping_count(self) -> int:\n        return len(self._name_to_code)\n"
