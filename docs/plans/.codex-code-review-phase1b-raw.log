import asyncio
from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker, AsyncSession
from edu_cloud.models.base import Base
import edu_cloud.models.school
import edu_cloud.models.subject_selection
from edu_cloud.models.school import School
from edu_cloud.services.subject_selection_service import create_selection, update_selection

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:', echo=False)
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with Session() as db:
        school = School(name='Test School', code='S03', district='Test', api_key_hash='x')
        db.add(school)
        await db.flush()
        first = await create_selection(db, school_id=school.id, name='A', subject_codes=['physics'])
        second = await create_selection(db, school_id=school.id, name='B', subject_codes=['history'])
        try:
            await update_selection(db, school_id=school.id, selection_id=second.id, name='A')
            print('update_result=ok')
        except Exception as e:
            print(type(e).__name__, str(e))
    await engine.dispose()

asyncio.run(main())
