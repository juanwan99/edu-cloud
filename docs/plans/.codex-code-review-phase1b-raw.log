import asyncio
from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker, AsyncSession
from edu_cloud.models.base import Base
import edu_cloud.models.school
import edu_cloud.models.user
import edu_cloud.models.user_role
import edu_cloud.modules.student.models
import edu_cloud.models.teacher_assignment
from edu_cloud.models.school import School
from edu_cloud.models.user import User
from edu_cloud.models.user_role import UserRole
from edu_cloud.modules.student.models import Class
from edu_cloud.services.teacher_assignment_service import create_assignments, list_assignments

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:', echo=False)
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with Session() as db:
        school_a = School(name='A校', code='A01', district='测试区', api_key_hash='x')
        school_b = School(name='B校', code='B01', district='测试区', api_key_hash='x')
        db.add_all([school_a, school_b])
        await db.flush()

        user = User(username='teacher_b', display_name='B校教师')
        user.set_password('test123')
        db.add(user)
        await db.flush()
        db.add(UserRole(user_id=user.id, role='subject_teacher', school_id=school_b.id, is_primary=True))

        cls = Class(name='A班', grade='高三', grade_number=12, school_id=school_a.id)
        db.add(cls)
        await db.flush()
        await db.commit()

        created = await create_assignments(
            db, school_id=school_a.id, user_id=user.id,
            class_ids=[cls.id], subject_code='math', semester='2025-2026-2'
        )
        rows = await list_assignments(db, school_id=school_a.id)
        print({'created': created, 'rows': len(rows), 'row_user_id': rows[0].user_id if rows else None})
    await engine.dispose()

asyncio.run(main())
