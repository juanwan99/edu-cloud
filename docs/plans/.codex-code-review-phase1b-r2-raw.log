import asyncio
from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker, AsyncSession
from edu_cloud.models.base import Base
import edu_cloud.models.school
import edu_cloud.models.subject_selection
from edu_cloud.models.school import School
from edu_cloud.services.subject_selection_service import create_selection, update_selection

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:', echo=False)
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with Session() as db:
        school = School(name='测试校', code='SCH1', district='区', api_key_hash='x')
        db.add(school)
        await db.commit()
        await db.refresh(school)

        a = await create_selection(db, school_id=school.id, name='A', subject_codes=['physics'])
        b = await create_selection(db, school_id=school.id, name='B', subject_codes=['chemistry'])

        try:
            await update_selection(db, school_id=school.id, selection_id=b.id, name='A')
        except Exception as e:
            print('update_duplicate_exception', type(e).__name__, str(e))
            await db.rollback()

        try:
            sel = await create_selection(db, school_id=school.id, name='C', subject_codes=['physics', ''])
            print('create_blank_subject_ok', sel.subject_codes)
        except Exception as e:
            print('create_blank_subject_exception', type(e).__name__, str(e))
    await engine.dispose()

asyncio.run(main())
