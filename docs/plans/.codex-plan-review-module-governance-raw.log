    "content": "\"\"\"\r\nrefactor_guard.py — PreToolUse Hook (Bash)\r\n\r\nDetects when `git commit` is about to commit code that deletes\r\nexports/routes/classes without replacement.\r\n\r\nSemi-blocking: outputs {\"decision\": \"ask\"} to force Claude to\r\npause and confirm with user. Does NOT block the commit.\r\n\r\nTrigger: PreToolUse on Bash commands matching `git commit`\r\n\"\"\"\r\nimport json\r\nimport os\r\nimport re\r\nimport subprocess\r\nimport sys\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\nimport hook_lib  # noqa: E402 — surrogate-safe stdout\r\n\r\n\r\nJS_KEYWORDS = frozenset({'function', 'class', 'const', 'let', 'var', 'default', 'async', 'new', 'return', 'if', 'else', 'for', 'while', 'switch', 'case', 'break', 'continue', 'throw', 'try', 'catch', 'finally', 'typeof', 'instanceof', 'void', 'delete', 'in', 'of', 'with', 'yield', 'await', 'import', 'from', 'as', 'true', 'false', 'null', 'undefined', 'this', 'super'})\r\n\r\nEXPORT_DELETE_PATTERNS = [\r\n    re.compile(r'^-\\s*export\\s+(?:async\\s+)?(?:function|const|let|var|class|default)\\s+(\\w+)', re.MULTILINE),\r\n    re.compile(r'^-\\s*(module\\.exports)', re.MULTILINE),\r\n    re.compile(r'^-\\s*exports\\.(\\w+)\\s*=', re.MULTILINE),\r\n    re.compile(r'^-\\s*(?:async\\s+)?def\\s+(\\w+)\\s*\\(', re.MULTILINE),\r\n    re.compile(r'^-\\s*class\\s+(\\w+)', re.MULTILINE),\r\n]\r\n\r\nROUTE_DELETE_PATTERNS = [\r\n    re.compile(r'^-\\s*(?:router|app)\\.(get|post|put|delete|patch)\\s*\\(\\s*[\\'\"]([^\\'\"]+)', re.MULTILINE | re.IGNORECASE),\r\n]\r\n\r\nEXPORT_ADD_PATTERNS = [\r\n    re.compile(r'^\\+\\s*export\\s+(?:async\\s+)?(?:function|const|let|var|class|default)\\s+(\\w+)', re.MULTILINE),\r\n    re.compile(r'^\\+\\s*(module\\.exports)', re.MULTILINE),\r\n    re.compile(r'^\\+\\s*exports\\.(\\w+)\\s*=', re.MULTILINE),\r\n    re.compile(r'^\\+\\s*(?:async\\s+)?def\\s+(\\w+)\\s*\\(', re.MULTILINE),\r\n    re.compile(r'^\\+\\s*class\\s+(\\w+)', re.MULTILINE),\r\n]\r\n\r\nROUTE_ADD_PATTERNS = [\r\n    re.compile(r'^\\+\\s*(?:router|app)\\.(get|post|put|delete|patch)\\s*\\(\\s*[\\'\"]([^\\'\"]+)', re.MULTILINE | re.IGNORECASE),\r\n]\r\n\r\n\r\ndef extract_names(patterns, text):\r\n    \"\"\"Extract symbol names from diff lines.\"\"\"\r\n    names = set()\r\n    for pat in patterns:\r\n        for m in pat.finditer(text):\r\n            name = m.group(m.lastindex)\r\n            if name and name not in JS_KEYWORDS:\r\n                names.add(name)\r\n    return names\r\n\r\n\r\ndef extract_routes(patterns, text):\r\n    \"\"\"Extract METHOD /path pairs from diff lines.\"\"\"\r\n    routes = set()\r\n    for pat in patterns:\r\n        for m in pat.finditer(text):\r\n            routes.add(f\"{m.group(1).upper()} {m.group(2)}\")\r\n    return routes\r\n\r\n\r\ndef _analyze_diff(diff):\r\n    \"\"\"分析 diff 中删除的符号和路由。返回 (missing_exports, missing_routes)。\"\"\"\r\n    deleted_exports = extract_names(EXPORT_DELETE_PATTERNS, diff)\r\n    added_exports = extract_names(EXPORT_ADD_PATTERNS, diff)\r\n    missing_exports = deleted_exports - added_exports\r\n\r\n    deleted_routes = extract_routes(ROUTE_DELETE_PATTERNS, diff)\r\n    added_routes = extract_routes(ROUTE_ADD_PATTERNS, diff)\r\n    missing_routes = deleted_routes - added_routes\r\n\r\n    return missing_exports, missing_routes\r\n\r\n\r\ndef check(data, session_state, staged_info=None):\r\n    \"\"\"commit_guards 调度器入口。返回 dict 或 None。\"\"\"\r\n    if staged_info is None:\r\n        return None\r\n    diff = staged_info.get('diff', '')\r\n    if not diff:\r\n        # 没有 diff 时尝试自行获取\r\n        try:\r\n            result = subprocess.run(\r\n                ['git', 'diff', '--cached', '-U0'],\r\n                capture_output=True, text=True, timeout=15,\r\n                cwd=data.get('cwd', None),\r\n            )\r\n            diff = result.stdout\r\n        except Exception:\r\n            return None\r\n    if not diff:\r\n        return None\r\n\r\n    missing_exports, missing_routes = _analyze_diff(diff)\r\n    if not missing_exports and not missing_routes:\r\n        return None\r\n\r\n    lines = [\"[refactor-guard] 检测到删除符号且无替换:\"]\r\n    if missing_exports:\r\n        lines.append(f\"  导出/函数: {', '.join(sorted(missing_exports))}\")\r\n    if missing_routes:\r\n        lines.append(f\"  路由: {', '.join(sorted(missing_routes))}\")\r\n    lines.append(\"\")\r\n    lines.append(\"如果是故意删除，确认继续。\")\r\n    lines.append(\"如果是误删，拒绝并恢复缺失的代码。\")\r\n\r\n    return {\"decision\": \"ask\", \"message\": '\\n'.join(lines)}\r\n\r\n\r\ndef main():\r\n    try:\r\n        data = json.load(sys.stdin)\r\n    except Exception:\r\n        sys.exit(0)\r\n\r\n    if data.get('tool_name') != 'Bash':\r\n        sys.exit(0)\r\n\r\n    command = data.get('tool_input', {}).get('command', '')\r\n    if not re.search(r'\\bgit\\s+commit\\b', command):\r\n        sys.exit(0)\r\n\r\n    try:\r\n        result = subprocess.run(\r\n            ['git', 'diff', '--cached', '-U0'],\r\n            capture_output=True, text=True, timeout=15,\r\n            cwd=data.get('cwd', None),\r\n        )\r\n        diff = result.stdout\r\n    except Exception:\r\n        sys.exit(0)\r\n\r\n    staged_info = {\"files\": [], \"diff\": diff}\r\n    out = check(data, None, staged_info=staged_info)\r\n    if out:\r\n        print(json.dumps(out))\r\n    sys.exit(0)\r\n\r\n\r\nif __name__ == '__main__':\r\n    main()\r"
  }
