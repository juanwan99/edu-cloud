      "text": "\"\"\"PreToolUse Hook (Bash): 工具偏好软提醒。\n\n检测 Bash 命令中的工具偏好违规（grep/cat/find/sed 等），\n建议使用对应的专用工具（Grep/Read/Glob/Edit）。\n每 session 每种类型首次触发，后续不再提醒。\n\nPhase 2.c-3 B3: 不硬拦，只 ask。\n\"\"\"\nimport json\nimport os\nimport re\nimport sys\n\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\nimport hook_lib  # noqa: E402\n\nREMINDED_KEY = 'tool_preference_reminded'\n\n# 检测规则：type_id → (pattern, suggestion)\n# pattern 排除前缀字母/连字符（避免 git grep、npm-find 等误触发）\nRULES = {\n    'grep': {\n        'pattern': re.compile(r'(?<![a-zA-Z_-])(?:grep|rg)\\b'),\n        'suggest': 'Grep',\n        'msg': '使用 Grep 工具替代（支持 regex、glob 过滤、上下文行数）',\n    },\n    'read': {\n        'pattern': re.compile(r'(?<![a-zA-Z_-])(?:cat|head|tail)\\b'),\n        'suggest': 'Read',\n        'msg': '使用 Read 工具替代（支持行号、offset/limit、PDF/图片）',\n    },\n    'glob': {\n        'pattern': re.compile(r'(?<![a-zA-Z_-])find\\b'),\n        'suggest': 'Glob',\n        'msg': '使用 Glob 工具替代（快速文件模式匹配）',\n    },\n    'edit': {\n        'pattern': re.compile(r'(?<![a-zA-Z_-])(?:sed|awk)\\b'),\n        'suggest': 'Edit',\n        'msg': '使用 Edit 工具替代（精确字符串替换，用户可审查）',\n    },\n}\n\n# 排除模式：这些上下文中的命令不触发提醒\nEXCLUDE_PATTERNS = [\n    re.compile(r'\\bgit\\s+grep\\b'),      # git grep 不等价于 Grep 工具\n    re.compile(r'\\|.*\\b(?:grep|rg)\\b'),  # 管道右侧的 grep（ps aux | grep）\n]\n\n\ndef detect_violation(cmd):\n    \"\"\"检测命令中的工具偏好违规。\n\n    Returns: (type_id, matched_cmd) 或 None。只返回第一个匹配。\n    \"\"\"\n    if not cmd or not cmd.strip():\n        return None\n\n    # 排除检查\n    for exc in EXCLUDE_PATTERNS:\n        if exc.search(cmd):\n            # 如果整个命令被排除模式覆盖，跳过该规则\n            # 但只排除 grep 类的，其他规则不受影响\n            pass\n\n    for type_id, rule in RULES.items():\n        m = rule['pattern'].search(cmd)\n        if m:\n            # 检查是否被排除\n            excluded = False\n            if type_id == 'grep':\n                for exc in EXCLUDE_PATTERNS:\n                    if exc.search(cmd):\n                        excluded = True\n                        break\n            if not excluded:\n                return (type_id, m.group())\n    return None\n\n\ndef main():\n    try:\n        data = json.loads(sys.stdin.read())\n    except Exception:\n        sys.exit(0)\n\n    if data.get('tool_name') != 'Bash':\n        sys.exit(0)\n\n    cmd = (data.get('tool_input') or {}).get('command', '')\n    if not cmd:\n        sys.exit(0)\n\n    result = detect_violation(cmd)\n    if not result:\n        sys.exit(0)\n\n    type_id, matched = result\n    rule = RULES[type_id]\n\n    # 检查是否已提醒过\n    session_id = data.get('session_id', 'unknown')\n    try:\n        state_dir = os.environ.get('CLAUDE_HOOK_STATE_DIR')\n        if state_dir:\n            original = hook_lib.STATE_DIR\n            hook_lib.STATE_DIR = state_dir\n        ss = hook_lib.SessionState(session_id)\n        state = ss.read() or {}\n        reminded = state.get(REMINDED_KEY, [])\n\n        if type_id in reminded:\n            # 已提醒过，不再询问\n            if state_dir:\n                hook_lib.STATE_DIR = original\n            sys.exit(0)\n\n        # 记录已提醒\n        reminded.append(type_id)\n        ss.write(REMINDED_KEY, reminded)\n        if state_dir:\n            hook_lib.STATE_DIR = original\n    except Exception:\n        # state 操作失败不阻断\n        sys.exit(0)\n\n    # 软询问（ask，非 block）\n    hook_lib.safe_print(json.dumps({\n        \"decision\": \"ask\",\n        \"reason\": f\"💡 检测到 `{matched}`。{rule['msg']}。\",\n    }))\n    sys.exit(0)\n\n\nif __name__ == '__main__':\n    main()"
    }
