      "text": "\"\"\"commit_guards.py — PreToolUse 调度器：合并 3 个 git commit hook。\n\n复用 fast_guards.py 的 CHECKS + run_checks 模式。\n在调度前执行一次 git diff --cached 并传入所有子 guard。\n\n合并: doc_sync_guard, logging_guard, refactor_guard\n\"\"\"\nimport json\nimport os\nimport re\nimport subprocess\nimport sys\nimport traceback\n\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\nimport hook_lib\n\nimport doc_sync_guard\nimport logging_guard\nimport refactor_guard\n\nCHECKS = [\n    (\"doc_sync_guard\", doc_sync_guard.check),\n    (\"logging_guard\", logging_guard.check),\n    (\"refactor_guard\", refactor_guard.check),\n]\n\nPRIORITY = {\"block\": 3, \"ask\": 2}\n\n\ndef run_checks(data: dict, session_state, staged_info=None) -> dict | None:\n    \"\"\"运行所有 check，按优先级返回决策。\n\n    优先级: block > ask > hookSpecificOutput > None\n    \"\"\"\n    best = None\n    best_priority = -1\n\n    for name, check_fn in CHECKS:\n        try:\n            result = check_fn(data, session_state, staged_info=staged_info)\n        except Exception as e:\n            tb = traceback.format_exc()\n            hook_lib.log_error(name, f\"check() exception: {e}\\n{tb}\")\n            print(f\"WARNING: {name} check failed: {e}\", file=sys.stderr)\n            continue\n\n        if result is None:\n            continue\n\n        result[\"_hook_name\"] = name\n        decision = result.get(\"decision\", \"\")\n        priority = PRIORITY.get(decision, 1)  # hookSpecificOutput = 1\n\n        if priority > best_priority:\n            best = result\n            best_priority = priority\n            if priority >= 3:  # block 是最高优先级\n                break\n\n    return best\n\n\ndef main():\n    data = hook_lib.read_hook_data()\n    if not data:\n        sys.exit(0)\n\n    if data.get('tool_name') != 'Bash':\n        sys.exit(0)\n\n    command = data.get('tool_input', {}).get('command', '')\n    if not re.search(r'\\bgit\\s+commit\\b', command):\n        sys.exit(0)\n\n    cwd = data.get('cwd', None)\n    session_id = data.get(\"session_id\", \"unknown\")\n    ss = hook_lib.SessionState(session_id)\n\n    # 共享 staged_info：一次获取，传入所有子 guard\n    try:\n        files_result = subprocess.run(\n            ['git', 'diff', '--cached', '--name-only'],\n            capture_output=True, text=True, timeout=10, cwd=cwd,\n        )\n        staged_files = files_result.stdout.strip().split('\\n') if files_result.stdout.strip() else []\n    except Exception:\n        staged_files = []\n\n    try:\n        diff_result = subprocess.run(\n            ['git', 'diff', '--cached', '-U0'],\n            capture_output=True, text=True, timeout=15, cwd=cwd,\n        )\n        diff = diff_result.stdout\n    except Exception:\n        diff = \"\"\n\n    staged_info = {\"files\": staged_files, \"diff\": diff}\n    result = run_checks(data, ss, staged_info=staged_info)\n\n    if result is None:\n        sys.exit(0)\n\n    if result.get(\"decision\") == \"block\":\n        hook_lib.block(result[\"reason\"], result.get(\"_hook_name\", \"commit_guards\"), ss)\n    elif result.get(\"decision\") == \"ask\":\n        hook_lib.safe_print(json.dumps(result, ensure_ascii=False))\n        sys.exit(0)\n    elif \"hookSpecificOutput\" in result:\n        hook_lib.safe_print(json.dumps(result, ensure_ascii=False))\n        sys.exit(0)\n\n    sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()"
