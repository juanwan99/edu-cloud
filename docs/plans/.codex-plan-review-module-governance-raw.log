  "structuredContent": {
    "content": "\"\"\"\r\nhook_lib.py — Hook 基础设施公共模块 (v2)\r\n\r\n提供:\r\n- SessionState: 统一会话状态管理（替代分散的 *_gate.txt 文件）\r\n- read_hook_data(): 安全解析 stdin JSON\r\n- block() / allow(): 标准化输出\r\n- log_error(): 带轮转的错误日志\r\n- rotate_file(): 通用文件轮转\r\n\r\n设计文档: docs/plans/2026-03-11-hook-infra-v2-design.md §1.2-§1.3\r\n\"\"\"\r\n\r\nimport json\r\nimport os\r\nimport random\r\nimport re\r\nimport sys\r\nimport uuid\r\nfrom datetime import datetime, timedelta\r\n\r\n# 全局编码设置 — PYTHONIOENCODING 在 Python 启动后设置无效，\r\n# 必须显式重配置 stdout/stderr 为 utf-8\r\nos.environ.setdefault('PYTHONIOENCODING', 'utf-8')\r\nif hasattr(sys.stdout, 'reconfigure'):\r\n    sys.stdout.reconfigure(encoding='utf-8', errors='replace')\r\nif hasattr(sys.stderr, 'reconfigure'):\r\n    sys.stderr.reconfigure(encoding='utf-8', errors='replace')\r\n\r\n\r\n# ── Surrogate 清洗 ──\r\n# Windows Node.js 可能产生 lone surrogate（U+D800-U+DFFF），\r\n# 导致 API 请�� JSON 解析失败。所有 hook stdout 输出前必须清洗。\r\n\r\n_SURROGATE_RE = re.compile(r'[\\ud800-\\udfff]')\r\n\r\n\r\ndef strip_surrogates(s: str) -> str:\r\n    \"\"\"移除字符串中的 lone surrogate 字符，防止 JSON 序列化错误。\"\"\"\r\n    if not isinstance(s, str):\r\n        return s\r\n    return _SURROGATE_RE.sub('\\ufffd', s)\r\n\r\n\r\ndef safe_print(*args, **kwargs):\r\n    \"\"\"surrogate-safe 的 print 替代。用于所有 hook stdout 输出。\"\"\"\r\n    cleaned = [strip_surrogates(str(a)) for a in args]\r\n    print(*cleaned, **kwargs)\r\n\r\n\r\nclass _SurrogateCleanStream:\r\n    \"\"\"包装 sys.stdout，自动清洗 lone surrogate。\r\n    import hook_lib 时自动安装，对所有 print() 生效。\"\"\"\r\n\r\n    def __init__(self, stream):\r\n        self._stream = stream\r\n\r\n    def write(self, s):\r\n        return self._stream.write(strip_surrogates(s))\r\n\r\n    def __getattr__(self, name):\r\n        return getattr(self._stream, name)\r\n\r\n\r\n# 自动安装 — import hook_lib 即生效\r\nsys.stdout = _SurrogateCleanStream(sys.stdout)\r\n\r\n# ── 常量 ──\r\n\r\nMAX_PER_HOOK_BLOCKS = 2  # 每个 hook 独立的 block 上限（防止同一 hook 无限循环）\r\nMAX_TOTAL_BLOCKS = 10    # 全局安全阀（所有 hook 合计，防极端情况）\r\nCRITICAL_HOOKS = {'secret_guard', 'destructive_git_guard', 'deploy_guard', 'correction_guard', 'correction_precheck', 'completion_guard', 'doc_sync_guard', 'critical_path_guard'}  # 安全关键 hook 不受全局上限约束\r\nSTATE_DIR = os.environ.get(\r\n    'CLAUDE_HOOK_STATE_DIR',\r\n    os.path.join(os.path.expanduser(\"~\"), \".claude\", \"hooks\", \"state\"),\r\n)\r\nDEFAULT_ERROR_LOG = os.path.join(os.path.expanduser(\"~\"), \".claude\", \"hooks\", \"state\", \"error_log.jsonl\")\r\n\r\n\r\n# ── SessionState ──\r\n\r\nclass SessionState:\r\n    \"\"\"统一会话状态管理。\r\n\r\n    文件: STATE_DIR/{session_id[:8]}_state.json\r\n    构造时自动清理 >24h 的过期 state 文件。\r\n    \"\"\"\r\n\r\n    def __init__(self, session_id: str):\r\n        self.session_id = session_id\r\n        self.path = os.path.join(STATE_DIR, f\"{session_id[:8]}_state.json\")\r\n        os.makedirs(STATE_DIR, exist_ok=True)\r\n        # 竞争条件 #3 修复：cleanup 从每次 __init__ 移到 5% 概率触发，\r\n        # 避免在热路径中删除其他会话正在读取的文件\r\n        if random.random() < 0.05:\r\n            self._cleanup_expired()\r\n        # 初始化文件（如果不存在）\r\n        if not os.path.exists(self.path):\r\n            self._init_file()\r\n\r\n    def _init_file(self):\r\n        data = {\r\n            \"created\": datetime.now().isoformat(timespec='seconds'),\r\n            \"skills_invoked\": [],\r\n            \"blocks\": {\"total\": 0, \"detail\": {}},\r\n            \"flags\": {},\r\n        }\r\n        self._save(data)\r\n\r\n    def _load(self) -> dict:\r\n        \"\"\"加载 state 文件。竞争条件 #2 缓解：PermissionError/部分写入时重试。\"\"\"\r\n        import time\r\n        for attempt in range(3):\r\n            try:\r\n                with open(self.path, 'r', encoding='utf-8') as f:\r\n                    return json.load(f)\r\n            except PermissionError:\r\n                # Windows NTFS 文件锁：另一进程正在写入，等待后重试\r\n                if attempt < 2:\r\n                    time.sleep(0.05 * (attempt + 1))\r\n                    continue\r\n                # 3 次重试失败 → 重新初始化\r\n                self._init_file()\r\n                return self._load_once()\r\n            except (json.JSONDecodeError, OSError):\r\n                self._init_file()\r\n                return self._load_once()\r\n        return self._load_once()\r\n\r\n    def _load_once(self) -> dict:\r\n        \"\"\"单次加载，不重试。\"\"\"\r\n        try:\r\n            with open(self.path, 'r', encoding='utf-8') as f:\r\n                return json.load(f)\r\n        except Exception:\r\n            return {\"created\": datetime.now().isoformat(timespec='seconds'),\r\n                    \"skills_invoked\": [], \"blocks\": {\"total\": 0, \"detail\": {}}, \"flags\": {}}\r\n\r\n    def _save(self, data: dict):\r\n        # UUID 替代 PID，消除多窗口同 PID tmp 文件碰撞（竞争条件 #1）\r\n        tmp = self.path + f\".{uuid.uuid4().hex[:8]}.tmp\"\r\n        try:\r\n            with open(tmp, 'w', encoding='utf-8') as f:\r\n                json.dump(data, f, ensure_ascii=False, indent=2)\r\n            os.replace(tmp, self.path)\r\n        except OSError:\r\n            try:\r\n                os.remove(tmp)\r\n            except OSError:\r\n                pass\r\n            raise\r\n\r\n    def read(self) -> dict:\r\n        return self._load()\r\n\r\n    def write(self, key: str, value):\r\n        data = self._load()\r\n        data[key] = value\r\n        self._save(data)\r\n\r\n    def append_list(self, key: str, value):\r\n        data = self._load()\r\n        lst = data.get(key, [])\r\n        if not isinstance(lst, list):\r\n            lst = []\r\n        lst.append(value)\r\n        data[key] = lst\r\n        self._save(data)\r\n\r\n    def append_verification_event(self, event: dict, max_events: int = 50):\r\n        data = self._load()\r\n        events = data.get('verification_events', [])\r\n        if not isinstance(events, list):\r\n            events = []\r\n        events.append(event)\r\n        if len(events) > max_events:\r\n            events = events[-max_events:]\r\n        data['verification_events'] = events\r\n        self._save(data)\r\n\r\n    def incr_block(self, hook_name: str) -> int:\r\n        data = self._load()\r\n        blocks = data.get(\"blocks\", {\"total\": 0, \"detail\": {}})\r\n        blocks[\"total\"] = blocks.get(\"total\", 0) + 1\r\n        detail = blocks.get(\"detail\", {})\r\n        detail[hook_name] = detail.get(hook_name, 0) + 1\r\n        blocks[\"detail\"] = detail\r\n        data[\"blocks\"] = blocks\r\n        self._save(data)\r\n        return blocks[\"total\"]\r\n\r\n    def get_blocks(self) -> int:\r\n        data = self._load()\r\n        return data.get(\"blocks\", {}).get(\"total\", 0)\r\n\r\n    def set_flag(self, flag_name: str, value):\r\n        \"\"\"设置会话标志（如 completion_degraded）。\"\"\"\r\n        data = self._load()\r\n        flags = data.get(\"flags\", {})\r\n        flags[flag_name] = value\r\n        data[\"flags\"] = flags\r\n        self._save(data)\r\n\r\n    def get_flag(self, flag_name: str, default=None):\r\n        \"\"\"读取会话标志。\"\"\"\r\n        data = self._load()\r\n        return data.get(\"flags\", {}).get(flag_name, default)\r\n\r\n    def _cleanup_expired(self):\r\n        \"\"\"删除 created 超过 24h 的 state 文件。\"\"\"\r\n        cutoff = datetime.now() - timedelta(hours=24)\r\n        try:\r\n            for fname in os.listdir(STATE_DIR):\r\n                if not fname.endswith(\"_state.json\"):\r\n                    continue\r\n                fpath = os.path.join(STATE_DIR, fname)\r\n                if fpath == self.path:\r\n                    continue\r\n                try:\r\n                    with open(fpath, 'r', encoding='utf-8') as f:\r\n                        d = json.load(f)\r\n                    created = datetime.fromisoformat(d.get(\"created\", \"2099-01-01\"))\r\n                    if created < cutoff:\r\n                        os.remove(fpath)\r\n                except Exception as e1:\r\n                    # 无法解析的文件也清理（>24h mtime 作为 fallback）\r\n                    try:\r\n                        mtime = datetime.fromtimestamp(os.path.getmtime(fpath))\r\n                        if mtime < cutoff:\r\n                            os.remove(fpath)\r\n                    except Exception as e2:\r\n                        log_error(\"SessionState._cleanup\", f\"cleanup failed {fpath}: {e2}\")\r\n        except Exception as e0:\r\n            log_error(\"SessionState._cleanup\", f\"cleanup dir scan failed: {e0}\")\r\n\r\n\r\n# ── I/O 函数 ──\r\n\r\ndef read_hook_data() -> dict:\r\n    \"\"\"解析 stdin JSON。空或无效时返回 {} 并输出 stderr 警告。\"\"\"\r\n    try:\r\n        raw = sys.stdin.read()\r\n        if not raw.strip():\r\n            print(\"WARNING: hook received empty stdin\", file=sys.stderr)\r\n            return {}\r\n        return json.loads(raw)\r\n    except (json.JSONDecodeError, Exception) as e:\r\n        print(f\"WARNING: hook stdin parse error: {e}\", file=sys.stderr)\r\n        return {}\r\n\r\n\r\ndef block(reason: str, hook_name: str, session_state: 'SessionState'):\r\n    \"\"\"输出 block JSON。同一 hook 超过 MAX_PER_HOOK_BLOCKS 时静默退出。\r\n\r\n    使用 per-hook 限制而非全局限制，防止低优先级 hook 耗尽预算\r\n    导致安全关键 hook（secret_guard, deploy_guard）被绕过。\r\n    全局 MAX_TOTAL_BLOCKS 作为极端情况的安全阀。\r\n    \"\"\"\r\n    try:\r\n        data = session_state.read()\r\n        blocks = data.get(\"blocks\", {})\r\n        # per-hook 限制（主要防护）\r\n        hook_blocks = blocks.get(\"detail\", {}).get(hook_name, 0)\r\n        if hook_blocks >= MAX_PER_HOOK_BLOCKS:\r\n            sys.exit(0)\r\n        # 全局安全阀（极端情况防护）— 安全关键 hook 豁免\r\n        if hook_name not in CRITICAL_HOOKS:\r\n            if blocks.get(\"total\", 0) >= MAX_TOTAL_BLOCKS:\r\n                sys.exit(0)\r\n        session_state.incr_block(hook_name)\r\n    except Exception:\r\n        pass  # state 读写失败时仍输出 block，宁可误拦不可漏放\r\n    safe_print(json.dumps({\"decision\": \"block\", \"reason\": strip_surrogates(reason)}, ensure_ascii=False))\r\n    sys.exit(0)\r\n\r\n\r\ndef allow():\r\n    \"\"\"输出 allow JSON。\"\"\"\r\n    print(json.dumps({\"decision\": \"allow\"}))\r\n    sys.exit(0)\r\n\r\n\r\n# ── 日志 ──\r\n\r\ndef log_error(hook: str, msg: str, log_path: str = None):\r\n    \"\"\"追加错误日志。超过 1000 行时轮转保留 500 行。\"\"\"\r\n    if log_path is None:\r\n        log_path = DEFAULT_ERROR_LOG\r\n    os.makedirs(os.path.dirname(log_path), exist_ok=True)\r\n\r\n    # 轮转检查\r\n    rotate_file(log_path, max_lines=1000, keep_lines=500)\r\n\r\n    # 追加\r\n    entry = {\r\n        \"ts\": datetime.now().isoformat(timespec='seconds'),\r\n        \"hook\": hook,\r\n        \"msg\": msg,\r\n    }\r\n    with open(log_path, 'a', encoding='utf-8') as f:\r\n        f.write(json.dumps(entry, ensure_ascii=False) + \"\\n\")\r\n\r\n\r\ndef rotate_file(path: str, max_lines: int = 1000, keep_lines: int = 500):\r\n    \"\"\"通用文件轮转：超过 max_lines 时保留最后 keep_lines 行。\r\n    使用 tmp+os.replace 原子���入，大幅缩短竞态窗口。\"\"\"\r\n    if not os.path.exists(path):\r\n        return\r\n    try:\r\n        with open(path, 'r', encoding='utf-8', errors='replace') as f:\r\n            lines = f.readlines()\r\n        if len(lines) > max_lines:\r\n            tmp = path + f\".rotate.{uuid.uuid4().hex[:8]}.tmp\"\r\n            with open(tmp, 'w', encoding='utf-8') as f:\r\n                f.writelines(lines[-keep_lines:])\r\n            os.replace(tmp, path)\r\n    except Exception as e:\r\n        log_error(\"rotate_file\", f\"rotation failed {path}: {e}\")\r"
  }
