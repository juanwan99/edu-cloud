      "text": "\"\"\"\r\nPreToolUse Hook (Bash): 日志规范守卫。\r\n\r\n在 git commit 时检测暂存文件中的日志违规：\r\n1. 新增的 print()/console.log() 调用（应使用 logger）\r\n2. 新增的 .py/.js 业务文件缺少 logger 导入\r\n\r\n触发: PreToolUse on Bash commands matching `git commit`\r\n输出: decision: block（硬阻断，必须修复后再 commit）\r\n性能: subprocess + 正则，<30ms\r\n\"\"\"\r\nimport json\r\nimport os\r\nimport re\r\nimport subprocess\r\nimport sys\r\n\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\nimport hook_lib  # noqa: E402\r\n\r\n# ── 排除模式 ──\r\n\r\nEXCLUDED_PATH_PATTERNS = [\r\n    re.compile(r'tests?/'),           # 测试目录\r\n    re.compile(r'conftest\\.py$'),      # pytest conftest\r\n    re.compile(r'__init__\\.py$'),      # 包初始化\r\n    re.compile(r'__main__\\.py$'),      # 入口脚本\r\n    re.compile(r'migrations?/'),       # 数据库迁移\r\n    re.compile(r'alembic/'),           # alembic 迁移\r\n    re.compile(r'hooks?/'),            # hook 文件自身\r\n    re.compile(r'scripts?/'),          # 工具脚本\r\n    re.compile(r'setup\\.py$'),         # 安装脚本\r\n    re.compile(r'\\.config\\.[jt]s$'),   # 配置文件\r\n    re.compile(r'vite\\.config'),       # vite 配置\r\n    re.compile(r'next\\.config'),       # next 配置\r\n    re.compile(r'\\.eslintrc'),         # lint 配置\r\n]\r\n\r\n# ── 检测模式 ──\r\n\r\n# Python: 裸 print( 调用（排除 print(file= 和注释行）\r\nPY_PRINT_PATTERN = re.compile(\r\n    r'^\\+\\s*print\\s*\\(',\r\n    re.MULTILINE\r\n)\r\n\r\n# Node.js: 裸 console.log/warn/error 调用\r\nJS_CONSOLE_PATTERN = re.compile(\r\n    r'^\\+\\s*console\\.(log|warn|error|info|debug)\\s*\\(',\r\n    re.MULTILINE\r\n)\r\n\r\n# Python logger 导入\r\nPY_LOGGER_IMPORT = re.compile(\r\n    r'(?:import\\s+logging|from\\s+logging\\s+import|logger\\s*=\\s*logging\\.getLogger)',\r\n)\r\n\r\n# Node.js logger 导入\r\nJS_LOGGER_IMPORT = re.compile(\r\n    r'''(?:require\\s*\\(\\s*['\"].*logger|import\\s+.*(?:logger|log)\\s+from)''',\r\n)\r\n\r\n\r\ndef is_excluded(filepath):\r\n    \"\"\"检查文件是否在排除列表中。\"\"\"\r\n    normalized = filepath.replace('\\\\', '/')\r\n    for pat in EXCLUDED_PATH_PATTERNS:\r\n        if pat.search(normalized):\r\n            return True\r\n    return False\r\n\r\n\r\ndef check_staged_files(cwd):\r\n    \"\"\"检查暂存文件的日志违规。返回 (violations, suggestions)。\"\"\"\r\n    # 获取暂存的 .py 和 .js/.ts 文件\r\n    try:\r\n        result = subprocess.run(\r\n            ['git', 'diff', '--cached', '--name-only', '--diff-filter=ACM'],\r\n            capture_output=True, text=True, timeout=10, cwd=cwd,\r\n        )\r\n        staged = [f for f in (result.stdout or '').strip().split('\\n') if f.strip()]\r\n    except Exception:\r\n        return [], []\r\n\r\n    py_files = [f for f in staged if f.endswith('.py') and not is_excluded(f)]\r\n    js_files = [f for f in staged if f.endswith(('.js', '.ts', '.jsx', '.tsx', '.vue'))\r\n                and not is_excluded(f)]\r\n\r\n    if not py_files and not js_files:\r\n        return [], []\r\n\r\n    violations = []\r\n\r\n    # 检查 Python 文件\r\n    if py_files:\r\n        try:\r\n            result = subprocess.run(\r\n                ['git', 'diff', '--cached', '-U0', '--'] + py_files,\r\n                capture_output=True, text=True, timeout=10, cwd=cwd,\r\n            )\r\n            diff = result.stdout or ''\r\n        except Exception:\r\n            diff = \"\"\r\n\r\n        # 按文件拆分 diff\r\n        file_diffs = re.split(r'^diff --git ', diff, flags=re.MULTILINE)\r\n        for fdiff in file_diffs:\r\n            if not fdiff.strip():\r\n                continue\r\n            # 提取文件名\r\n            m = re.match(r'a/(.+?)\\s+b/', fdiff)\r\n            if not m:\r\n                continue\r\n            fname = m.group(1)\r\n            if not fname.endswith('.py') or is_excluded(fname):\r\n                continue\r\n\r\n            # 检查新增的 print( 调用\r\n            prints = PY_PRINT_PATTERN.findall(fdiff)\r\n            if prints:\r\n                # 排除注释行和 print(file= 形式\r\n                real_prints = []\r\n                for line in fdiff.split('\\n'):\r\n                    if re.match(r'^\\+\\s*print\\s*\\(', line):\r\n                        stripped = line.lstrip('+').strip()\r\n                        # 排除: # 开头的注释、print(file=、print( 在字符串内\r\n                        if stripped.startswith('#'):\r\n                            continue\r\n                        if 'print(file=' in stripped:\r\n                            continue\r\n                        real_prints.append(stripped)\r\n\r\n                if real_prints:\r\n                    violations.append({\r\n                        'file': fname,\r\n                        'type': 'bare_print',\r\n                        'count': len(real_prints),\r\n                        'examples': real_prints[:3],\r\n                    })\r\n\r\n    # 检查 JS/TS 文件\r\n    if js_files:\r\n        try:\r\n            result = subprocess.run(\r\n                ['git', 'diff', '--cached', '-U0', '--'] + js_files,\r\n                capture_output=True, text=True, timeout=10, cwd=cwd,\r\n            )\r\n            diff = result.stdout or ''\r\n        except Exception:\r\n            diff = \"\"\r\n\r\n        file_diffs = re.split(r'^diff --git ', diff, flags=re.MULTILINE)\r\n        for fdiff in file_diffs:\r\n            if not fdiff.strip():\r\n                continue\r\n            m = re.match(r'a/(.+?)\\s+b/', fdiff)\r\n            if not m:\r\n                continue\r\n            fname = m.group(1)\r\n            if is_excluded(fname):\r\n                continue\r\n\r\n            consoles = JS_CONSOLE_PATTERN.findall(fdiff)\r\n            if consoles:\r\n                real_consoles = []\r\n                for line in fdiff.split('\\n'):\r\n                    if re.match(r'^\\+\\s*console\\.(log|warn|error|info|debug)\\s*\\(', line):\r\n                        stripped = line.lstrip('+').strip()\r\n                        if stripped.startswith('//'):\r\n                            continue\r\n                        real_consoles.append(stripped)\r\n\r\n                if real_consoles:\r\n                    violations.append({\r\n                        'file': fname,\r\n                        'type': 'bare_console',\r\n                        'count': len(real_consoles),\r\n                        'examples': real_consoles[:3],\r\n                    })\r\n\r\n    # 检查新增文件是否缺少 logger 导入\r\n    suggestions = []\r\n    try:\r\n        result = subprocess.run(\r\n            ['git', 'diff', '--cached', '--name-only', '--diff-filter=A'],\r\n            capture_output=True, text=True, timeout=10, cwd=cwd,\r\n        )\r\n        new_files = [f for f in (result.stdout or '').strip().split('\\n') if f.strip()]\r\n    except Exception:\r\n        new_files = []\r\n\r\n    for f in new_files:\r\n        if is_excluded(f):\r\n            continue\r\n        try:\r\n            content_result = subprocess.run(\r\n                ['git', 'show', f':' + f],\r\n                capture_output=True, text=True, timeout=10, cwd=cwd,\r\n            )\r\n            content = content_result.stdout or ''\r\n        except Exception:\r\n            continue\r\n\r\n        if f.endswith('.py') and not PY_LOGGER_IMPORT.search(content):\r\n            # 只提醒超过 20 行的文件（小文件可能是工具脚本）\r\n            if content.count('\\n') > 20:\r\n                suggestions.append(f\"{f}: 新文件缺少 logger 导入（建议添加 logger = logging.getLogger(__name__)）\")\r\n        elif f.endswith(('.js', '.ts')) and not JS_LOGGER_IMPORT.search(content):\r\n            if content.count('\\n') > 20:\r\n                suggestions.append(f\"{f}: 新文件缺少 logger 导入\")\r\n\r\n    return violations, suggestions\r\n\r\n\r\ndef _build_result(violations, suggestions):\r\n    \"\"\"根据违规和建议构建返回值。\"\"\"\r\n    if not violations:\r\n        if suggestions:\r\n            return {\r\n                \"hookSpecificOutput\": {\r"
