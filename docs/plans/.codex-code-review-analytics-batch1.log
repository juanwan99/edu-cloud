    18	async def resolve_subject_to_exam(
    19	    db: AsyncSession, subject_id: str, school_id: str,
    20	) -> tuple[str, Subject]:
    21	    """Resolve a subject_id to its parent exam_id. Returns (exam_id, subject).
    22	
    23	    Raises NotFoundError if the subject doesn't exist or doesn't belong to the school.
    24	    """
    25	    result = await db.execute(
    26	        select(Subject).where(Subject.id == subject_id, Subject.school_id == school_id)
    27	    )
    28	    subject = result.scalar_one_or_none()
    29	    if not subject:
    30	        raise NotFoundError("Subject not found")
    31	    return subject.exam_id, subject
