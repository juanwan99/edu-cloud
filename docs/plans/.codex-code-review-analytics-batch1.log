     1	"""Analytics helper — effective score computation."""
     2	import logging
     3	from sqlalchemy import select
     4	from sqlalchemy.ext.asyncio import AsyncSession
     5	from edu_cloud.modules.grading.models import GradingResult
     6	from edu_cloud.modules.scan.models import StudentAnswer
     7	from edu_cloud.modules.student.models import Student
     8	
     9	logger = logging.getLogger(__name__)
    10	
    11	
    12	async def get_effective_scores(
    13	    db: AsyncSession, subject_id: str, school_id: str,
    14	    visible_class_ids: list[str] | None = None,
    15	) -> list[dict]:
    16	    """Return effective scores for all graded answers in a subject.
    17	
    18	    Effective score = GradingResult.final_score（单一权威源）。
    19	    """
    20	    stmt = (
    21	        select(
    22	            StudentAnswer.student_id,
    23	            GradingResult.question_id,
    24	            GradingResult.final_score,
    25	            GradingResult.max_score,
    26	            GradingResult.status,
    27	        )
    28	        .join(GradingResult, GradingResult.answer_id == StudentAnswer.id)
    29	        .where(
    30	            StudentAnswer.subject_id == subject_id,
    31	            StudentAnswer.school_id == school_id,
    32	            GradingResult.school_id == school_id,
    33	        )
    34	    )
    35	    if visible_class_ids is not None:
    36	        stmt = stmt.join(Student, Student.id == StudentAnswer.student_id).where(
    37	            Student.class_id.in_(visible_class_ids)
    38	        )
    39	
    40	    result = await db.execute(stmt)
    41	    rows = result.all()
    42	
    43	    scores = []
    44	    for row in rows:
    45	        if row.final_score is None:
    46	            logger.warning(
    47	                "grading_result missing final_score: student=%s question=%s status=%s",
    48	                row.student_id, row.question_id, row.status,
    49	            )
    50	            continue
    51	        scores.append({
    52	            "student_id": row.student_id,
    53	            "question_id": row.question_id,
    54	            "effective_score": row.final_score,
    55	            "max_score": row.max_score,
    56	        })
    57	    return scores
