   631	async def _find_prev_exam(db: AsyncSession, exam_id: str, school_id: str) -> str | None:
   632	    """找到同校上一次考试（按 exam_date 或 created_at 倒序）。"""
   633	    current = (await db.execute(
   634	        select(Exam).where(Exam.id == exam_id, Exam.school_id == school_id)
   635	    )).scalar_one_or_none()
   636	    if not current:
   637	        return None
   638	    order_col = Exam.exam_date if current.exam_date else Exam.created_at
   639	    prev = (await db.execute(
   640	        select(Exam.id)
   641	        .where(Exam.school_id == school_id, Exam.status == "completed", Exam.id != exam_id)
   642	        .where(order_col < (current.exam_date or current.created_at))
   643	        .order_by(order_col.desc())
   644	        .limit(1)
   645	    )).scalar_one_or_none()
   646	    return prev
   647	
