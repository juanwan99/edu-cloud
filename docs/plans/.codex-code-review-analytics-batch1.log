   134	    subj_ids = [s.id for s in subjects]
   135	    max_by_subject = await _get_max_by_subject(db, subj_ids, school_id)
   136	
   137	    student_totals: dict[str, float] = {}
   138	    total_max = sum(max_by_subject.get(s.id, 0.0) for s in subjects)
