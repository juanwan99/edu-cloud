    83	async def exam_summary(
    84	    db: AsyncSession, *, exam_id: str, school_id: str,
    85	    visible_subject_codes: list[str] | None = None,
    86	    visible_class_ids: list[str] | None = None,
    87	) -> dict:
    88	    await _verify_exam(db, exam_id, school_id)
    89	    subjects = await _get_subjects(db, exam_id, school_id, visible_subject_codes)
    90	    subject_ids = [s.id for s in subjects]
    91	    if not subject_ids:
    92	        return {"exam_id": exam_id, "total_students": 0, "subjects": []}
    93	
    94	    max_by_subject = await _get_max_by_subject(db, subject_ids, school_id)
    95	    all_students: set[str] = set()
    96	    subject_stats = []
    97	
    98	    for subj in subjects:
    99	        max_possible = max_by_subject.get(subj.id, 0.0)
   100	        scores = await get_effective_scores(db, subj.id, school_id, visible_class_ids)
   101	        student_totals: dict[str, float] = {}
   102	        for s in scores:
   103	            all_students.add(s["student_id"])
   104	            student_totals[s["student_id"]] = student_totals.get(s["student_id"], 0.0) + s["effective_score"]
   105	
   106	        graded_count = len(student_totals)
   107	        if student_totals:
   108	            values = list(student_totals.values())
   109	            avg = sum(values) / len(values)
   110	            highest = max(values)
   111	            lowest = min(values)
   112	            score_rate = round(avg / max_possible, 4) if max_possible > 0 else 0.0
   113	        else:
   114	            avg = highest = lowest = score_rate = None
   115	
   116	        subject_stats.append({
   117	            "subject_id": subj.id, "subject_name": subj.name,
   118	            "avg_score": round(avg, 2) if avg is not None else None,
   119	            "max_score_possible": max_possible, "score_rate": score_rate,
   120	            "highest": highest, "lowest": lowest, "graded_count": graded_count,
   121	        })
   122	
   123	    return {"exam_id": exam_id, "total_students": len(all_students), "subjects": subject_stats}
