    18	async def _get_student_scores(
    19	    db: AsyncSession, exam_id: str, school_id: str,
    20	    subject_id: str | None = None,
    21	    visible_class_ids: list[str] | None = None,
    22	    visible_subject_codes: list[str] | None = None,
    23	) -> list[dict]:
    24	    """聚合每个学生在某次考试的总分。
    25	
    26	    F002 修复：增加 visible_subject_codes 过滤，防止受限角色看到超范围科目数据。
    27	    """
    28	    subj_q = select(Subject.id).where(Subject.exam_id == exam_id, Subject.school_id == school_id)
    29	    if subject_id:
    30	        subj_q = subj_q.where(Subject.id == subject_id)
    31	    if visible_subject_codes is not None:
    32	        subj_q = subj_q.where(Subject.code.in_(visible_subject_codes))
    33	    subj_ids = [r[0] for r in (await db.execute(subj_q)).all()]
    34	    if not subj_ids:
    35	        return []
    36	
    37	    from edu_cloud.modules.analytics import get_effective_scores
    38	    student_totals: dict[str, float] = defaultdict(float)
    39	    for sid in subj_ids:
    40	        scores = await get_effective_scores(db, sid, school_id, visible_class_ids)
    41	        for s in scores:
    42	            student_totals[s["student_id"]] += s["effective_score"]
    43	
    44	    # 获取学生信息
    45	    stu_result = await db.execute(
    46	        select(Student.id, Student.name, Student.class_id)
    47	        .where(Student.school_id == school_id)
    48	    )
    49	    stu_map = {r.id: {"name": r.name, "class_id": r.class_id} for r in stu_result.all()}
    50	
    51	    result = []
    52	    for sid, total in student_totals.items():
    53	        info = stu_map.get(sid, {"name": sid, "class_id": None})
    54	        result.append({"student_id": sid, "name": info["name"], "class_id": info["class_id"], "score": total})
    55	
    56	    result.sort(key=lambda x: x["score"], reverse=True)
    57	    # 年级排名
    58	    for i, r in enumerate(result):
    59	        r["grade_rank"] = i + 1
    60	        r["grade_size"] = len(result)
    61	    # 班级排名
    62	    by_class: dict[str, list] = defaultdict(list)
    63	    for r in result:
    64	        by_class[r["class_id"]].append(r)
    65	    for cls_students in by_class.values():
    66	        for i, r in enumerate(cls_students):
    67	            r["class_rank"] = i + 1
    68	            r["class_size"] = len(cls_students)
    69	
    70	    return result
