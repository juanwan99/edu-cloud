    73	async def _find_prev_exam(db: AsyncSession, exam_id: str, school_id: str) -> str | None:
    74	    """找到同校上一次考试（按 exam_date 或 created_at 倒序）。"""
    75	    """F005 修复：限同年级——通过 Subject 关联找到当前考试的年级（从 Student→Class→grade），
    76	    然后只在同年级考试中找上一次。"""
    77	    current = (await db.execute(
    78	        select(Exam).where(Exam.id == exam_id, Exam.school_id == school_id)
    79	    )).scalar_one_or_none()
    80	    if not current:
    81	        return None
    82	
    83	    # 找当前考试的年级（通过参与学生的班级）
    84	    grade_result = await db.execute(
    85	        select(Class.grade).distinct()
    86	        .select_from(StudentAnswer)
    87	        .join(Student, Student.id == StudentAnswer.student_id)
    88	        .join(Class, Class.id == Student.class_id)
    89	        .where(StudentAnswer.exam_id == exam_id)
    90	        .limit(1)
    91	    )
    92	    grade = grade_result.scalar_one_or_none()
    93	
    94	    order_col = Exam.exam_date if current.exam_date else Exam.created_at
    95	    prev_q = (
    96	        select(Exam.id)
    97	        .where(Exam.school_id == school_id, Exam.status == "completed", Exam.id != exam_id)
    98	        .where(order_col < (current.exam_date or current.created_at))
    99	        .order_by(order_col.desc())
   100	        .limit(1)
   101	    )
   102	    # 限同年级：只找包含同年级学生的考试
   103	    if grade:
   104	        prev_q = prev_q.where(
   105	            Exam.id.in_(
   106	                select(StudentAnswer.exam_id).distinct()
   107	                .join(Student, Student.id == StudentAnswer.student_id)
   108	                .join(Class, Class.id == Student.class_id)
   109	                .where(Class.grade == grade)
   110	            )
   111	        )
   112	    prev = (await db.execute(prev_q)).scalar_one_or_none()
   113	    return prev
