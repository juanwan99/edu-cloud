    34	async def _verify_exam(db: AsyncSession, exam_id: str, school_id: str) -> Exam:
    35	    result = await db.execute(
    36	        select(Exam).where(Exam.id == exam_id, Exam.school_id == school_id)
    37	    )
    38	    exam = result.scalar_one_or_none()
    39	    if not exam:
    40	        raise NotFoundError("Exam not found")
    41	    return exam
