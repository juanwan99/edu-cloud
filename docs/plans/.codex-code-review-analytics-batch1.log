   582	async def _get_student_scores(
   583	    db: AsyncSession, exam_id: str, school_id: str,
   584	    subject_id: str | None = None,
   585	    visible_class_ids: list[str] | None = None,
   586	) -> list[dict]:
   587	    """聚合每个学生在某次考试的总分。"""
   588	    subj_q = select(Subject.id).where(Subject.exam_id == exam_id, Subject.school_id == school_id)
   589	    if subject_id:
   590	        subj_q = subj_q.where(Subject.id == subject_id)
   591	    subj_ids = [r[0] for r in (await db.execute(subj_q)).all()]
   592	    if not subj_ids:
   593	        return []
   594	
   595	    from edu_cloud.modules.analytics import get_effective_scores
   596	    student_totals: dict[str, float] = defaultdict(float)
   597	    for sid in subj_ids:
   598	        scores = await get_effective_scores(db, sid, school_id, visible_class_ids)
   599	        for s in scores:
   600	            student_totals[s["student_id"]] += s["effective_score"]
   601	
   602	    # 获取学生信息
   603	    stu_result = await db.execute(
   604	        select(Student.id, Student.name, Student.class_id)
   605	        .where(Student.school_id == school_id)
   606	    )
   607	    stu_map = {r.id: {"name": r.name, "class_id": r.class_id} for r in stu_result.all()}
   608	
   609	    result = []
   610	    for sid, total in student_totals.items():
   611	        info = stu_map.get(sid, {"name": sid, "class_id": None})
   612	        result.append({"student_id": sid, "name": info["name"], "class_id": info["class_id"], "score": total})
   613	
   614	    result.sort(key=lambda x: x["score"], reverse=True)
   615	    # 年级排名
   616	    for i, r in enumerate(result):
   617	        r["grade_rank"] = i + 1
   618	        r["grade_size"] = len(result)
   619	    # 班级排名
   620	    by_class: dict[str, list] = defaultdict(list)
   621	    for r in result:
   622	        by_class[r["class_id"]].append(r)
   623	    for cls_students in by_class.values():
   624	        for i, r in enumerate(cls_students):
   625	            r["class_rank"] = i + 1
   626	            r["class_size"] = len(cls_students)
   627	
   628	    return result
