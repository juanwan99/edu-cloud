   275	        StudentKnowledgeMastery.school_id == school_id,
   276	    )
   277	    if exam_id:
   278	        stmt = stmt.where(StudentKnowledgeMastery.last_exam_id == exam_id)
   279	    rows = list((await db.execute(stmt)).scalars().all())
   280	
   281	    # 查询错误模式
   282	    ep_stmt = select(StudentErrorPattern).where(
   283	        StudentErrorPattern.student_id == student_id,
   284	        StudentErrorPattern.school_id == school_id,
   285	    )
   286	    if subject_code:
   287	        ep_stmt = ep_stmt.where(StudentErrorPattern.subject_code == subject_code)
   288	    error_patterns = list((await db.execute(ep_stmt)).scalars().all())
   289	
   290	    improving = []
   291	    declining = []
   292	    weak_points = []
   293	
   294	    for m in rows:
   295	        item = {
   296	            "kp_name": m.knowledge_point_id,
   297	            "mastery_level": round(m.mastery_level, 4) if m.mastery_level else 0,
   298	            "trend": m.trend or "stable",
   299	            "recent_scores": m.recent_scores or [],
   300	        }
   301	        if m.trend == "improving":
   302	            improving.append(item)
   303	        elif m.trend == "declining":
   304	            declining.append(item)
   305	        if m.mastery_level is not None and m.mastery_level < 0.6:
   306	            weak_points.append(item)
   307	
   308	    # 构建诊断文本
   309	    parts = []
   310	    if declining:
   311	        d = declining[0]
   312	        parts.append(f"知识点'{d['kp_name']}'掌握率持续下降（当前 {d['mastery_level']:.0%}），建议重点关注。")
   313	    if improving:
   314	        imp = improving[0]
   315	        parts.append(f"知识点'{imp['kp_name']}'掌握率在上升（当前 {imp['mastery_level']:.0%}），继续保持。")
   316	    if weak_points and not declining:
   317	        w = weak_points[0]
   318	        parts.append(f"知识点'{w['kp_name']}'掌握率较低（{w['mastery_level']:.0%}），建议加强练习。")
   319	
   320	    # F004: 融入错误模式
   321	    if error_patterns:
   322	        ep = error_patterns[0]
   323	        dist = ep.error_distribution or {}
   324	        if dist:
   325	            top_error = max(dist, key=dist.get)
   326	            parts.append(f"主要错误类型为{top_error}（占比 {dist[top_error]:.0%}）。")
   327	
   328	    if not parts:
   329	        parts.append("暂无足够数据生成诊断。")
   330	
   331	    return {
   332	        "summary": "".join(parts),
   333	        "improving": improving[:5],
   334	        "declining": declining[:5],
   335	        "weak_points": weak_points[:5],
   336	        "error_patterns": [{"subject_code": ep.subject_code, "distribution": ep.error_distribution} for ep in error_patterns[:3]],
   337	    }
