    84	async def question_insights(
    85	    db: AsyncSession, *, exam_id: str, school_id: str,
    86	    subject_id: str | None = None,
    87	    visible_subject_codes: list[str] | None = None,
    88	    visible_class_ids: list[str] | None = None,
    89	) -> dict:
    90	    """聚合每题的错因分布 + 难度/区分度。"""
    91	    # 验证考试
    92	    exam = (await db.execute(
    93	        select(Exam).where(Exam.id == exam_id, Exam.school_id == school_id)
    94	    )).scalar_one_or_none()
    95	    if not exam:
    96	        raise NotFoundError("Exam not found")
    97	
    98	    # 获取科目
    99	    subj_q = select(Subject).where(Subject.exam_id == exam_id, Subject.school_id == school_id)
   100	    if subject_id:
   101	        subj_q = subj_q.where(Subject.id == subject_id)
   102	    if visible_subject_codes is not None:
   103	        subj_q = subj_q.where(Subject.code.in_(visible_subject_codes))
   104	    subjects = list((await db.execute(subj_q)).scalars().all())
   105	    if not subjects:
   106	        return {"questions": []}
   107	
   108	    subj_ids = [s.id for s in subjects]
   109	
   110	    # 查询所有 GradingResult（有 ai_raw_response 的）
   111	    stmt = (
   112	        select(
   113	            GradingResult.question_id,
   114	            GradingResult.ai_raw_response,
   115	            GradingResult.final_score,
   116	            GradingResult.max_score,
   117	        )
   118	        .join(StudentAnswer, StudentAnswer.id == GradingResult.answer_id)
   119	        .where(
   120	            StudentAnswer.subject_id.in_(subj_ids),
   121	            GradingResult.school_id == school_id,
   122	            GradingResult.final_score.isnot(None),
   123	        )
   124	    )
   125	    if visible_class_ids is not None:
   126	        stmt = stmt.join(Student, Student.id == StudentAnswer.student_id).where(
   127	            Student.class_id.in_(visible_class_ids)
   128	        )
   129	
   130	    rows = (await db.execute(stmt)).all()
   131	
   132	    # 按题聚合
   133	    q_scores: dict[str, list[float]] = defaultdict(list)
   134	    q_max: dict[str, float] = {}
   135	    q_errors: dict[str, Counter] = defaultdict(Counter)
   136	    q_total: dict[str, int] = defaultdict(int)
   137	
   138	    for row in rows:
   139	        qid = row.question_id
   140	        q_scores[qid].append(row.final_score)
   141	        q_max[qid] = row.max_score
   142	        q_total[qid] += 1
   143	
   144	        # 解析 ai_raw_response 提取错因
   145	        raw = row.ai_raw_response
   146	        if not raw or not isinstance(raw, dict):
   147	            continue
   148	        details = raw.get("details", [])
   149	        if isinstance(details, str):
   150	            continue
   151	        for detail in details:
   152	            if not isinstance(detail, dict):
   153	                continue
   154	            for blank in detail.get("blanks", []):
   155	                if not isinstance(blank, dict):
   156	                    continue
   157	                if blank.get("correct") is False and blank.get("reason"):
   158	                    cause = _classify_error(blank["reason"])
   159	                    q_errors[qid][cause] += 1
   160	
   161	    # 查询题目元数据
   162	    questions_meta = {}
   163	    q_result = await db.execute(
   164	        select(Question.id, Question.name, Question.question_type, Question.max_score)
   165	        .where(Question.subject_id.in_(subj_ids), Question.school_id == school_id)
   166	    )
   167	    for q in q_result.all():
   168	        questions_meta[q.id] = {"name": q.name, "type": q.question_type, "max_score": q.max_score}
   169	
   170	    # 构建结果
   171	    result_questions = []
   172	    for qid, scores in q_scores.items():
   173	        meta = questions_meta.get(qid, {"name": qid, "type": "unknown", "max_score": 0})
   174	        max_s = q_max.get(qid, meta["max_score"])
   175	        avg = sum(scores) / len(scores) if scores else 0
   176	        score_rate = round(avg / max_s, 4) if max_s > 0 else 0.0
   177	        total = q_total[qid]
   178	
   179	        # 难度和区分度
   180	        difficulty = score_rate
   181	        discrimination = None
   182	        if len(scores) >= 10:
   183	            sorted_s = sorted(scores, reverse=True)
   184	            n27 = max(1, len(sorted_s) * 27 // 100)
   185	            top_avg = sum(sorted_s[:n27]) / n27
   186	            bot_avg = sum(sorted_s[-n27:]) / n27
   187	            discrimination = round((top_avg - bot_avg) / max_s, 4) if max_s > 0 else None
   188	
   189	        # 错因分布
   190	        errors = q_errors.get(qid, Counter())
   191	        error_total = sum(errors.values())
   192	        error_causes = []
   193	        for cause, count in errors.most_common():
   194	            error_causes.append({
   195	                "cause": cause,
   196	                "count": count,
   197	                "pct": round(count / total, 4) if total > 0 else 0,
   198	            })
   199	
   200	        result_questions.append({
   201	            "question_id": qid,
   202	            "name": meta["name"],
   203	            "question_type": meta["type"],
   204	            "score_rate": score_rate,
   205	            "graded_count": total,
   206	            "error_causes": error_causes,
   207	            "difficulty": difficulty,
   208	            "discrimination": discrimination,
   209	        })
   210	
   211	    result_questions.sort(key=lambda x: x["score_rate"])
   212	    return {"questions": result_questions}
   213	
