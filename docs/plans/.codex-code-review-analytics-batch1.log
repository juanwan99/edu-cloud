   339	@router.post("/report/export", status_code=201)
   340	async def export_report(
   341	    body: dict,
   342	    db: AsyncSession = Depends(get_db),
   343	    current: dict = Depends(require_permission(Permission.GENERATE_REPORT)),
   344	):
   345	    """生成分析报告文档（走 Studio）。"""
   346	    role = current["current_role"]
   347	    user = current["user"]
   348	    exam_ids = body.get("exam_ids", [])
   349	    if not exam_ids:
   350	        raise HTTPException(422, "exam_ids 不能为空")
   351	
   352	    RESTRICTED_METRICS = {"ranking", "top_bottom"}
   353	    RESTRICTED_ROLES = {"parent", "homeroom_teacher", "subject_teacher"}
   354	    ALL_METRICS = ["summary", "segments", "ranking", "questions", "top_bottom"]
   355	    requested_metrics = body.get("metrics") or ALL_METRICS
   356	    if role.role in RESTRICTED_ROLES:
   357	        allowed_metrics = [m for m in requested_metrics if m not in RESTRICTED_METRICS]
   358	    else:
   359	        allowed_metrics = requested_metrics
   360	
   361	    report_data = await build_report(
   362	        db, school_id=role.school_id, exam_ids=exam_ids,
   363	        metrics=allowed_metrics,
   364	        subject_codes=body.get("subject_codes"),
   365	        class_ids=body.get("class_ids"),
   366	        visible_subject_codes=get_visible_subject_codes(role),
   367	        visible_class_ids=get_visible_class_ids(role),
   368	    )
   369	
   370	    from edu_cloud.modules.exam.models import Exam as ExamModel
   371	    exam_result = await db.execute(sa_select(ExamModel).where(ExamModel.id == exam_ids[0]))
   372	    exam = exam_result.scalar_one_or_none()
   373	    title = body.get("title") or f"{exam.name if exam else '考试'}分析报告"
   374	
   375	    from edu_cloud.modules.studio.service import StudioService
   376	    svc = StudioService(db)
   377	    doc = await svc.create_document(
   378	        type="analysis_report",
   379	        title=title,
   380	        content_json={
   381	            "report_type": "exam_analysis",
   382	            "config": {"exam_ids": exam_ids, "metrics": body.get("metrics")},
   383	            "sections": report_data["metrics"],
   384	        },
   385	        school_id=role.school_id,
   386	        created_by=user.id,
   387	    )
   388	    # Studio 状态流转：draft → reviewed → executed
   389	    await svc.transition_status(doc.id, "reviewed", school_id=role.school_id)
   390	    await svc.transition_status(doc.id, "executed", school_id=role.school_id)
   391	    await db.commit()
   392	
   393	    return {
   394	        "document_id": doc.id,
   395	        "status": "executed",
   396	        "title": doc.title,
   397	    }
