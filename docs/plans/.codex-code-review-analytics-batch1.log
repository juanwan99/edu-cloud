   361	async def class_error_patterns(
   362	    db: AsyncSession, *, exam_id: str, school_id: str,
   363	    subject_id: str | None = None,
   364	    visible_subject_codes: list[str] | None = None,
   365	    visible_class_ids: list[str] | None = None,
   366	) -> dict:
   367	    """班级错误模式对比。"""
   368	    from edu_cloud.modules.analytics.insights_service import question_insights, _classify_error
   369	
   370	    insights = await question_insights(
   371	        db, exam_id=exam_id, school_id=school_id,
   372	        subject_id=subject_id,
   373	        visible_subject_codes=visible_subject_codes,
   374	        visible_class_ids=visible_class_ids,
   375	    )
   376	
   377	    # 需要按班拆分 — 重新查询带 class_id 信息的 GradingResult
   378	    subj_q = select(Subject.id).where(Subject.exam_id == exam_id, Subject.school_id == school_id)
   379	    if subject_id:
   380	        subj_q = subj_q.where(Subject.id == subject_id)
   381	    if visible_subject_codes is not None:
   382	        subj_q = subj_q.where(Subject.code.in_(visible_subject_codes))
   383	    subj_ids = [r[0] for r in (await db.execute(subj_q)).all()]
   384	    if not subj_ids:
   385	        return {"error_types": [], "classes": []}
   386	
   387	    stmt = (
   388	        select(
   389	            Student.class_id,
   390	            GradingResult.ai_raw_response,
   391	        )
   392	        .select_from(GradingResult)
   393	        .join(StudentAnswer, StudentAnswer.id == GradingResult.answer_id)
   394	        .join(Student, Student.id == StudentAnswer.student_id)
   395	        .where(
   396	            StudentAnswer.subject_id.in_(subj_ids),
   397	            GradingResult.school_id == school_id,
   398	            GradingResult.ai_raw_response.isnot(None),
   399	        )
   400	    )
   401	    if visible_class_ids is not None:
   402	        stmt = stmt.where(Student.class_id.in_(visible_class_ids))
   403	
   404	    rows = (await db.execute(stmt)).all()
   405	
   406	    class_errors: dict[str, Counter] = defaultdict(Counter)
   407	    all_types: set[str] = set()
   408	    for row in rows:
   409	        cid = row.class_id
   410	        raw = row.ai_raw_response
   411	        if not isinstance(raw, dict):
   412	            continue
   413	        for detail in raw.get("details", []):
   414	            if not isinstance(detail, dict):
   415	                continue
   416	            for blank in detail.get("blanks", []):
   417	                if not isinstance(blank, dict):
   418	                    continue
   419	                if blank.get("correct") is False and blank.get("reason"):
   420	                    cause = _classify_error(blank["reason"])
   421	                    class_errors[cid][cause] += 1
   422	                    all_types.add(cause)
   423	
   424	    # 班级名
   425	    class_ids = list(class_errors.keys())
   426	    if not class_ids:
   427	        return {"error_types": [], "classes": []}
   428	    cls_result = await db.execute(select(Class.id, Class.name).where(Class.id.in_(class_ids)))
   429	    cls_map = {r.id: r.name for r in cls_result.all()}
   430	
   431	    error_types = sorted(all_types)
   432	    classes = []
   433	    for cid, counter in class_errors.items():
   434	        total = sum(counter.values())
   435	        dist = {t: round(counter.get(t, 0) / total, 4) if total > 0 else 0 for t in error_types}
   436	        classes.append({"class_id": cid, "name": cls_map.get(cid, cid), "distribution": dist})
   437	    classes.sort(key=lambda x: x["name"])
   438	    return {"error_types": error_types, "classes": classes}

