     7	from edu_cloud.database import get_db
     8	from edu_cloud.shared.auth import decode_token
     9	from jose import ExpiredSignatureError, JWTError
    10	
    11	from edu_cloud.core.permissions import Permission, ROLE_PERMISSIONS
    12	from edu_cloud.services.exceptions import PermissionDeniedError
    13	
    14	logger = logging.getLogger(__name__)
    15	
    16	security = HTTPBearer()
    17	
    18	
    19	async def get_current_user(
    20	    credentials: HTTPAuthorizationCredentials = Depends(security),
    21	    db: AsyncSession = Depends(get_db),
    22	) -> dict:
    23	    """平台用户认证（JWT）。返回 dict 含 user/roles/current_role/permissions。"""
    24	    try:
    25	        payload = decode_token(credentials.credentials)
    26	    except ExpiredSignatureError:
    27	        raise HTTPException(401, "Token expired")
    28	    except JWTError:
    29	        raise HTTPException(401, "Invalid token")
    30	
    31	    user_id = payload.get("sub")
    32	    if not user_id:
    33	        raise HTTPException(401, "Invalid token")
    34	
    35	    # 优先查新 User 模型
    36	    from edu_cloud.models.user import User
    37	    from edu_cloud.models.user_role import UserRole
    38	
    39	    user = await db.get(User, user_id)
    40	    if user:
    41	        if not user.is_active:
    42	            raise HTTPException(401, "User not found or inactive")
    43	
    44	        roles = (
    45	            await db.execute(select(UserRole).where(UserRole.user_id == user.id))
    46	        ).scalars().all()
    47	        if not roles:
    48	            raise HTTPException(403, "No role assigned")
    49	
    50	        # 选择活跃角色
    51	        active_role_id = payload.get("active_role_id")
    52	        if active_role_id:
    53	            active = next((r for r in roles if r.id == active_role_id), None)
    54	        else:
    55	            active = next((r for r in roles if r.is_primary), roles[0])
    56	
    57	        if active is None:
    58	            active = roles[0]
    59	
    60	        return {
    61	            "user": user,
    62	            "roles": roles,
    63	            "current_role": active,
    64	            "permissions": ROLE_PERMISSIONS.get(active.role, set()),
    65	        }
    66	
    67	    logger.warning("token user_id=%s not found", user_id)
    68	    raise HTTPException(401, "User not found")
    69	
    70	
    71	def require_permission(permission: Permission):
    72	    """Factory: returns a FastAPI dependency that checks the user has a permission."""
    73	    async def checker(current: dict = Depends(get_current_user)):
    74	        if permission not in current["permissions"]:
    75	            raise PermissionDeniedError(
    76	                f"Role '{current['current_role'].role}' lacks permission '{permission.value}'"
    77	            )
    78	        return current
    79	    return checker

