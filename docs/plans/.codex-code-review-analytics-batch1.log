    44	async def _get_subjects(
    45	    db: AsyncSession, exam_id: str, school_id: str,
    46	    visible_subject_codes: list[str] | None = None,
    47	    subject_id: str | None = None,
    48	) -> list[Subject]:
    49	    if subject_id:
    50	        query = select(Subject).where(
    51	            Subject.id == subject_id, Subject.exam_id == exam_id,
    52	            Subject.school_id == school_id,
    53	        )
    54	        if visible_subject_codes is not None:
    55	            query = query.where(Subject.code.in_(visible_subject_codes))
    56	        result = await db.execute(query)
    57	        subjects = list(result.scalars().all())
    58	        if not subjects:
    59	            raise NotFoundError("Subject not found")
    60	        return subjects
    61	    else:
    62	        query = select(Subject).where(Subject.exam_id == exam_id, Subject.school_id == school_id)
    63	        if visible_subject_codes is not None:
    64	            query = query.where(Subject.code.in_(visible_subject_codes))
    65	        result = await db.execute(query)
    66	        return list(result.scalars().all())
