   116	async def student_rankings(
   117	    db: AsyncSession, *, exam_id: str, school_id: str,
   118	    subject_id: str | None = None,
   119	    class_id: str | None = None,
   120	    visible_subject_codes: list[str] | None = None,
   121	    visible_class_ids: list[str] | None = None,
   122	) -> dict:
   123	    """学生排名 + 进退步 delta。"""
   124	    effective_class_ids = [class_id] if class_id else visible_class_ids
   125	    current = await _get_student_scores(db, exam_id, school_id, subject_id, effective_class_ids, visible_subject_codes)
   126	    if not current:
   127	        return {"students": []}
   128	
   129	    # 上次考试排名
   130	    prev_exam_id = await _find_prev_exam(db, exam_id, school_id)
   131	    prev_map: dict[str, dict] = {}
   132	    if prev_exam_id:
   133	        prev_scores = await _get_student_scores(db, prev_exam_id, school_id, subject_id, effective_class_ids, visible_subject_codes)
   134	        for p in prev_scores:
   135	            prev_map[p["student_id"]] = p
   136	
   137	    students = []
   138	    for s in current:
   139	        prev = prev_map.get(s["student_id"])
   140	        students.append({
   141	            "student_id": s["student_id"],
   142	            "name": s["name"],
   143	            "score": round(s["score"], 2),
   144	            "class_rank": s.get("class_rank"),
   145	            "grade_rank": s["grade_rank"],
   146	            "prev_class_rank": prev["class_rank"] if prev else None,
   147	            "prev_grade_rank": prev["grade_rank"] if prev else None,
   148	            "delta_class": (prev["class_rank"] - s["class_rank"]) if prev and prev.get("class_rank") else None,
   149	            "delta_grade": (prev["grade_rank"] - s["grade_rank"]) if prev else None,
   150	        })
   151	
   152	    return {"students": students}
