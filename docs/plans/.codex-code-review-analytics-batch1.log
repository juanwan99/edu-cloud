    17	# V1 关键词分类规则
    18	_ERROR_PATTERNS = [
    19	    (re.compile(r"概念|混淆|误写|误用|错误.*名词|名词.*错误"), "概念混淆"),
    20	    (re.compile(r"计算|运算|数值|算错|算术"), "计算错误"),
    21	    (re.compile(r"步骤|不完整|缺少|缺失|遗漏|不全"), "步骤不完整"),
    22	    (re.compile(r"审题|理解|题意|看错"), "审题不清"),
    23	]
    24	
    25	
    26	def _classify_error(reason: str) -> str:
    27	    for pattern, label in _ERROR_PATTERNS:
    28	        if pattern.search(reason):
    29	            return label
    30	    return "其他"
