   274	async def class_knowledge(
   275	    db: AsyncSession, *, exam_id: str, school_id: str,
   276	    subject_id: str | None = None,
   277	    visible_subject_codes: list[str] | None = None,
   278	    visible_class_ids: list[str] | None = None,
   279	) -> dict:
   280	    """班级×知识点 掌握率热力图数据。"""
   281	    from edu_cloud.modules.exam.models import Subject, Question
   282	    from edu_cloud.modules.analytics import get_effective_scores
   283	
   284	    subj_q = select(Subject).where(Subject.exam_id == exam_id, Subject.school_id == school_id)
   285	    if subject_id:
   286	        subj_q = subj_q.where(Subject.id == subject_id)
   287	    if visible_subject_codes is not None:
   288	        subj_q = subj_q.where(Subject.code.in_(visible_subject_codes))
   289	    subjects = list((await db.execute(subj_q)).scalars().all())
   290	    if not subjects:
   291	        return {"knowledge_points": [], "classes": []}
   292	
   293	    subj_ids = [s.id for s in subjects]
   294	
   295	    # 获取题目→知识点映射
   296	    q_result = await db.execute(
   297	        select(Question.id, Question.knowledge_points, Question.max_score)
   298	        .where(Question.subject_id.in_(subj_ids), Question.school_id == school_id)
   299	    )
   300	    q_kps: dict[str, list[str]] = {}
   301	    q_max: dict[str, float] = {}
   302	    all_kps: set[str] = set()
   303	    for q in q_result.all():
   304	        qid = q.id
   305	        q_max[qid] = q.max_score
   306	        kps = []
   307	        if q.knowledge_points and isinstance(q.knowledge_points, dict):
   308	            kps = q.knowledge_points.get("knowledge_ids", [])
   309	        q_kps[qid] = kps
   310	        all_kps.update(kps)
   311	
   312	    if not all_kps:
   313	        return {"knowledge_points": [], "classes": []}
   314	
   315	    # 聚合每个学生每个知识点的得分率
   316	    student_kp_scores: dict[str, dict[str, list[float]]] = defaultdict(lambda: defaultdict(list))
   317	    for subj in subjects:
   318	        scores = await get_effective_scores(db, subj.id, school_id, visible_class_ids)
   319	        for s in scores:
   320	            kps = q_kps.get(s["question_id"], [])
   321	            max_s = q_max.get(s["question_id"], 1)
   322	            rate = s["effective_score"] / max_s if max_s > 0 else 0
   323	            for kp in kps:
   324	                student_kp_scores[s["student_id"]][kp].append(rate)
   325	
   326	    # 学生→班级映射
   327	    all_sids = list(student_kp_scores.keys())
   328	    stu_result = await db.execute(
   329	        select(Student.id, Student.class_id).where(Student.id.in_(all_sids))
   330	    )
   331	    stu_class = {r.id: r.class_id for r in stu_result.all()}
   332	
   333	    # 按班聚合
   334	    class_kp_rates: dict[str, dict[str, list[float]]] = defaultdict(lambda: defaultdict(list))
   335	    for sid, kp_data in student_kp_scores.items():
   336	        cid = stu_class.get(sid)
   337	        if not cid:
   338	            continue
   339	        for kp, rates in kp_data.items():
   340	            avg_rate = sum(rates) / len(rates) if rates else 0
   341	            class_kp_rates[cid][kp].append(avg_rate)
   342	
   343	    # 班级名
   344	    class_ids = list(class_kp_rates.keys())
   345	    cls_result = await db.execute(select(Class.id, Class.name).where(Class.id.in_(class_ids)))
   346	    cls_map = {r.id: r.name for r in cls_result.all()}
   347	
   348	    kp_list = sorted(all_kps)
   349	    classes = []
   350	    for cid, kp_data in class_kp_rates.items():
   351	        mastery = []
   352	        for kp in kp_list:
   353	            rates = kp_data.get(kp, [])
   354	            avg = round(sum(rates) / len(rates), 4) if rates else 0
   355	            mastery.append({"kp_id": kp, "name": kp, "rate": avg})
   356	        classes.append({"class_id": cid, "name": cls_map.get(cid, cid), "mastery": mastery})
   357	    classes.sort(key=lambda x: x["name"])
   358	    return {"knowledge_points": kp_list, "classes": classes}
   359	
