+    gr4 = GradingResult(
+        answer_id=sa2_q1.id, question_id=q1.id, school_id=school.id,
+        final_score=3.0, max_score=3.0, status="confirmed", source="manual",
+    )
+    db.add_all([gr1, gr2, gr3, gr4])
