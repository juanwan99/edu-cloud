   297	@router.get("/report/trend/student")
   298	async def student_trend_api(
   299	    exam_ids: str = Query(...),
   300	    student_id: str = Query(...),
   301	    subject_code: str | None = Query(None),
   302	    db: AsyncSession = Depends(get_db),
   303	    current: dict = Depends(get_current_user),
   304	):
   305	    """显式校验 student_id 可见性（班级/家长 guardian）。"""
   306	    role = current["current_role"]
   307	    ids = [eid.strip() for eid in exam_ids.split(",") if eid.strip()]
   308	    # 家长：只能查自己孩子（优先于班级可见性）
   309	    if role.role == "parent":
   310	        from edu_cloud.models.guardian import GuardianStudentLink
   311	        guard_result = await db.execute(
   312	            sa_select(GuardianStudentLink.id).where(
   313	                GuardianStudentLink.guardian_user_id == current["user"].id,
   314	                GuardianStudentLink.student_id == student_id,
   315	            )
   316	        )
   317	        if not guard_result.scalar_one_or_none():
   318	            raise HTTPException(403, "家长只能查看自己孩子的数据")
   319	    else:
   320	        # 非家长：按班级可见性校验
   321	        vis_classes = get_visible_class_ids(role)
   322	        if vis_classes is not None:
   323	            from edu_cloud.modules.student.models import Student
   324	            stu_result = await db.execute(
   325	                sa_select(Student.class_id).where(
   326	                    Student.id == student_id, Student.school_id == role.school_id
   327	                )
   328	            )
   329	            stu_row = stu_result.first()
   330	            if not stu_row or stu_row.class_id not in vis_classes:
   331	                raise HTTPException(403, "无权查看该学生数据")
   332	    return await get_student_trend(
   333	        db, school_id=role.school_id, exam_ids=ids, student_id=student_id,
   334	        subject_code=subject_code,
   335	        visible_subject_codes=get_visible_subject_codes(role),
   336	    )
