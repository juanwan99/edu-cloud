    33	async def question_insights(
    34	    db: AsyncSession, *, exam_id: str, school_id: str,
    35	    subject_id: str | None = None,
    36	    visible_subject_codes: list[str] | None = None,
    37	    visible_class_ids: list[str] | None = None,
    38	) -> dict:
    39	    """聚合每题的错因分布 + 难度/区分度。"""
    40	    # 验证考试
    41	    exam = (await db.execute(
    42	        select(Exam).where(Exam.id == exam_id, Exam.school_id == school_id)
    43	    )).scalar_one_or_none()
    44	    if not exam:
    45	        raise NotFoundError("Exam not found")
    46	
    47	    # 获取科目
    48	    subj_q = select(Subject).where(Subject.exam_id == exam_id, Subject.school_id == school_id)
    49	    if subject_id:
    50	        subj_q = subj_q.where(Subject.id == subject_id)
    51	    if visible_subject_codes is not None:
    52	        subj_q = subj_q.where(Subject.code.in_(visible_subject_codes))
    53	    subjects = list((await db.execute(subj_q)).scalars().all())
    54	    if not subjects:
    55	        return {"questions": []}
    56	
    57	    subj_ids = [s.id for s in subjects]
    58	
    59	    # 查询所有 GradingResult（有 ai_raw_response 的）
    60	    stmt = (
    61	        select(
    62	            GradingResult.question_id,
    63	            GradingResult.ai_raw_response,
    64	            GradingResult.final_score,
    65	            GradingResult.max_score,
    66	        )
    67	        .join(StudentAnswer, StudentAnswer.id == GradingResult.answer_id)
    68	        .where(
    69	            StudentAnswer.subject_id.in_(subj_ids),
    70	            GradingResult.school_id == school_id,
    71	            GradingResult.final_score.isnot(None),
    72	        )
    73	    )
    74	    if visible_class_ids is not None:
    75	        stmt = stmt.join(Student, Student.id == StudentAnswer.student_id).where(
    76	            Student.class_id.in_(visible_class_ids)
    77	        )
    78	
    79	    rows = (await db.execute(stmt)).all()
    80	
    81	    # 按题聚合
    82	    q_scores: dict[str, list[float]] = defaultdict(list)
    83	    q_max: dict[str, float] = {}
    84	    q_errors: dict[str, Counter] = defaultdict(Counter)
    85	    q_total: dict[str, int] = defaultdict(int)
    86	
    87	    for row in rows:
    88	        qid = row.question_id
    89	        q_scores[qid].append(row.final_score)
    90	        q_max[qid] = row.max_score
    91	        q_total[qid] += 1
    92	
    93	        # 解析 ai_raw_response 提取错因
    94	        raw = row.ai_raw_response
    95	        if not raw or not isinstance(raw, dict):
    96	            continue
    97	        details = raw.get("details", [])
    98	        if isinstance(details, str):
    99	            continue
   100	        for detail in details:
   101	            if not isinstance(detail, dict):
   102	                continue
   103	            for blank in detail.get("blanks", []):
   104	                if not isinstance(blank, dict):
   105	                    continue
   106	                if blank.get("correct") is False and blank.get("reason"):
   107	                    cause = _classify_error(blank["reason"])
   108	                    q_errors[qid][cause] += 1
   109	
   110	    # 查询题目元数据
   111	    questions_meta = {}
   112	    q_result = await db.execute(
   113	        select(Question.id, Question.name, Question.question_type, Question.max_score)
   114	        .where(Question.subject_id.in_(subj_ids), Question.school_id == school_id)
   115	    )
   116	    for q in q_result.all():
   117	        questions_meta[q.id] = {"name": q.name, "type": q.question_type, "max_score": q.max_score}
   118	
   119	    # 构建结果
   120	    result_questions = []
   121	    for qid, scores in q_scores.items():
   122	        meta = questions_meta.get(qid, {"name": qid, "type": "unknown", "max_score": 0})
   123	        max_s = q_max.get(qid, meta["max_score"])
   124	        avg = sum(scores) / len(scores) if scores else 0
   125	        score_rate = round(avg / max_s, 4) if max_s > 0 else 0.0
   126	        total = q_total[qid]
   127	
   128	        # 难度和区分度
   129	        difficulty = score_rate
   130	        discrimination = None
   131	        if len(scores) >= 10:
   132	            sorted_s = sorted(scores, reverse=True)
   133	            n27 = max(1, len(sorted_s) * 27 // 100)
   134	            top_avg = sum(sorted_s[:n27]) / n27
   135	            bot_avg = sum(sorted_s[-n27:]) / n27
   136	            discrimination = round((top_avg - bot_avg) / max_s, 4) if max_s > 0 else None
   137	
   138	        # 错因分布
   139	        errors = q_errors.get(qid, Counter())
   140	        error_total = sum(errors.values())
   141	        error_causes = []
   142	        for cause, count in errors.most_common():
   143	            error_causes.append({
   144	                "cause": cause,
   145	                "count": count,
   146	                "pct": round(count / total, 4) if total > 0 else 0,
   147	            })
   148	
   149	        result_questions.append({
   150	            "question_id": qid,
   151	            "name": meta["name"],
   152	            "question_type": meta["type"],
   153	            "score_rate": score_rate,
   154	            "graded_count": total,
   155	            "error_causes": error_causes,
   156	            "difficulty": difficulty,
   157	            "discrimination": discrimination,
   158	        })
   159	
   160	    result_questions.sort(key=lambda x: x["score_rate"])
   161	    return {"questions": result_questions}
