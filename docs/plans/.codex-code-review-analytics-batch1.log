   155	async def critical_students(
   156	    db: AsyncSession, *, exam_id: str, school_id: str,
   157	    subject_id: str | None = None,
   158	    class_id: str | None = None,
   159	    threshold: int = 3,
   160	    visible_subject_codes: list[str] | None = None,
   161	    visible_class_ids: list[str] | None = None,
   162	) -> dict:
   163	    """临界生筛选：差 N 分及格/优秀。F005 修复：返回 worst_question。"""
   164	    from edu_cloud.modules.analytics.segment_service import get_segment_config
   165	    from edu_cloud.modules.analytics.service import _get_max_by_subject, _get_subjects
   166	    from edu_cloud.modules.analytics import get_effective_scores as _get_eff
   167	
   168	    effective_class_ids = [class_id] if class_id else visible_class_ids
   169	    scores = await _get_student_scores(db, exam_id, school_id, subject_id, effective_class_ids, visible_subject_codes)
   170	    if not scores:
   171	        return {"near_pass": [], "near_excellent": []}
   172	
   173	    # 获取满分和分数段
   174	    subjects = await _get_subjects(db, exam_id, school_id, visible_subject_codes, subject_id)
   175	    subj_ids = [s.id for s in subjects]
   176	    max_by_subject = await _get_max_by_subject(db, subj_ids, school_id)
   177	    total_max = sum(max_by_subject.values())
   178	
   179	    subject_code = subjects[0].code if len(subjects) == 1 else None
   180	    boundaries, labels = await get_segment_config(db, school_id, subject_code)
   181	
   182	    # 及格线和优秀线（按百分比×满分）
   183	    pass_line = total_max * (boundaries[-1] / 100) if boundaries else total_max * 0.6
   184	    excellent_line = total_max * (boundaries[0] / 100) if boundaries else total_max * 0.85
   185	
   186	    # F005: 预计算每个学生丢分最多的题目
   187	    student_worst: dict[str, dict] = {}
   188	    q_meta_result = await db.execute(
   189	        select(Question.id, Question.name, Question.max_score)
   190	        .where(Question.subject_id.in_(subj_ids), Question.school_id == school_id)
   191	    )
   192	    q_meta = {r.id: {"name": r.name, "max_score": r.max_score} for r in q_meta_result.all()}
   193	
   194	    for subj in subjects:
   195	        eff_scores = await _get_eff(db, subj.id, school_id, effective_class_ids)
   196	        for s in eff_scores:
   197	            sid = s["student_id"]
   198	            loss = s["max_score"] - s["effective_score"]
   199	            if loss > 0:
   200	                prev = student_worst.get(sid)
   201	                if prev is None or loss > prev["loss"]:
   202	                    meta = q_meta.get(s["question_id"], {"name": s["question_id"], "max_score": s["max_score"]})
   203	                    student_worst[sid] = {
   204	                        "question_name": meta["name"],
   205	                        "score": round(s["effective_score"], 2),
   206	                        "max_score": round(s["max_score"], 2),
   207	                        "loss": round(loss, 2),
   208	                    }
   209	
   210	    near_pass = []
   211	    near_excellent = []
   212	    for s in scores:
   213	        gap_pass = pass_line - s["score"]
   214	        gap_excellent = excellent_line - s["score"]
   215	        worst = student_worst.get(s["student_id"])
   216	        if 0 < gap_pass <= threshold:
   217	            near_pass.append({
   218	                "student_id": s["student_id"], "name": s["name"],
   219	                "score": round(s["score"], 2), "gap": round(gap_pass, 2),
   220	                "worst_question": worst,
   221	            })
   222	        if 0 < gap_excellent <= threshold:
   223	            near_excellent.append({
   224	                "student_id": s["student_id"], "name": s["name"],
   225	                "score": round(s["score"], 2), "gap": round(gap_excellent, 2),
   226	                "worst_question": worst,
   227	            })
   228	
   229	    near_pass.sort(key=lambda x: x["gap"])
   230	    near_excellent.sort(key=lambda x: x["gap"])
   231	    return {"near_pass": near_pass, "near_excellent": near_excellent}
