    69	async def _get_max_by_subject(
    70	    db: AsyncSession, subject_ids: list[str], school_id: str
    71	) -> dict[str, float]:
    72	    q_result = await db.execute(
    73	        select(
    74	            Question.subject_id,
    75	            func.sum(Question.max_score).label("max_possible"),
    76	        )
    77	        .where(Question.subject_id.in_(subject_ids), Question.school_id == school_id)
    78	        .group_by(Question.subject_id)
    79	    )
    80	    return {row.subject_id: row.max_possible for row in q_result.all()}
