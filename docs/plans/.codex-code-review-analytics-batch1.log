   263	            "count": n,
   264	            "min": round(vals[0], 2),
   265	            "max": round(vals[-1], 2),
   266	            "median": round(statistics.median(vals), 2),
   267	            "p25": round(vals[n * 25 // 100], 2) if n >= 4 else round(vals[0], 2),
   268	            "p75": round(vals[n * 75 // 100], 2) if n >= 4 else round(vals[-1], 2),
