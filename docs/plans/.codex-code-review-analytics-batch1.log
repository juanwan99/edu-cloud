   688	async def critical_students(
   689	    db: AsyncSession, *, exam_id: str, school_id: str,
   690	    subject_id: str | None = None,
   691	    class_id: str | None = None,
   692	    threshold: int = 3,
   693	    visible_subject_codes: list[str] | None = None,
   694	    visible_class_ids: list[str] | None = None,
   695	) -> dict:
   696	    """临界生筛选：差 N 分及格/优秀。"""
   697	    from edu_cloud.modules.analytics.segment_service import get_segment_config
   698	    from edu_cloud.modules.analytics.service import _get_max_by_subject, _get_subjects
   699	
   700	    effective_class_ids = [class_id] if class_id else visible_class_ids
   701	    scores = await _get_student_scores(db, exam_id, school_id, subject_id, effective_class_ids)
   702	    if not scores:
   703	        return {"near_pass": [], "near_excellent": []}
   704	
   705	    # 获取满分和分数段
   706	    subjects = await _get_subjects(db, exam_id, school_id, visible_subject_codes, subject_id)
   707	    subj_ids = [s.id for s in subjects]
   708	    max_by_subject = await _get_max_by_subject(db, subj_ids, school_id)
   709	    total_max = sum(max_by_subject.values())
   710	
   711	    subject_code = subjects[0].code if len(subjects) == 1 else None
   712	    boundaries, labels = await get_segment_config(db, school_id, subject_code)
   713	
   714	    # 及格线和优秀线（按百分比×满分）
   715	    pass_line = total_max * (boundaries[-1] / 100) if boundaries else total_max * 0.6
   716	    excellent_line = total_max * (boundaries[0] / 100) if boundaries else total_max * 0.85
   717	
   718	    near_pass = []
   719	    near_excellent = []
   720	    for s in scores:
   721	        gap_pass = pass_line - s["score"]
   722	        gap_excellent = excellent_line - s["score"]
   723	        if 0 < gap_pass <= threshold:
   724	            near_pass.append({
   725	                "student_id": s["student_id"], "name": s["name"],
   726	                "score": round(s["score"], 2), "gap": round(gap_pass, 2),
   727	            })
   728	        if 0 < gap_excellent <= threshold:
   729	            near_excellent.append({
   730	                "student_id": s["student_id"], "name": s["name"],
   731	                "score": round(s["score"], 2), "gap": round(gap_excellent, 2),
   732	            })
   733	
   734	    near_pass.sort(key=lambda x: x["gap"])
   735	    near_excellent.sort(key=lambda x: x["gap"])
   736	    return {"near_pass": near_pass, "near_excellent": near_excellent}
   737	
   738	
   739	async def class_boxplot(
   740	    db: AsyncSession, *, exam_id: str, school_id: str,
   741	    subject_id: str | None = None,
   742	    visible_subject_codes: list[str] | None = None,
   743	    visible_class_ids: list[str] | None = None,
   744	) -> dict:
   745	    """各班分数箱线图数据。"""
   746	    scores = await _get_student_scores(db, exam_id, school_id, subject_id, visible_class_ids)
   747	    by_class: dict[str, list[float]] = defaultdict(list)
   748	    for s in scores:
   749	        if s["class_id"]:
   750	            by_class[s["class_id"]].append(s["score"])
   751	
   752	    # 获取班级名
   753	    class_ids = list(by_class.keys())
   754	    if not class_ids:
   755	        return {"classes": []}
   756	    cls_result = await db.execute(
   757	        select(Class.id, Class.name).where(Class.id.in_(class_ids))
   758	    )
   759	    cls_map = {r.id: r.name for r in cls_result.all()}
   760	
   761	    classes = []
   762	    for cid, vals in by_class.items():
   763	        vals.sort()
   764	        n = len(vals)
   765	        classes.append({
   766	            "class_id": cid,
   767	            "name": cls_map.get(cid, cid),
   768	            "count": n,
   769	            "min": round(vals[0], 2),
   770	            "max": round(vals[-1], 2),
   771	            "median": round(statistics.median(vals), 2),
   772	            "p25": round(vals[n * 25 // 100], 2) if n >= 4 else round(vals[0], 2),
   773	            "p75": round(vals[n * 75 // 100], 2) if n >= 4 else round(vals[-1], 2),
   774	        })
   775	    classes.sort(key=lambda x: x["name"])
   776	    return {"classes": classes}
