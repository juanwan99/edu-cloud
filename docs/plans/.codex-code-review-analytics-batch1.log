   215	async def exam_diagnosis(
   216	    db: AsyncSession, *, exam_id: str, school_id: str,
   217	    subject_id: str | None = None,
   218	    class_id: str | None = None,
   219	    visible_subject_codes: list[str] | None = None,
   220	    visible_class_ids: list[str] | None = None,
   221	) -> dict:
   222	    """生成考试诊断文本（模板拼接，不调 LLM）。ORC-007。"""
   223	    from edu_cloud.modules.analytics.service import exam_summary, grade_aggregates
   224	
   225	    summary = await exam_summary(
   226	        db, exam_id=exam_id, school_id=school_id,
   227	        visible_subject_codes=visible_subject_codes,
   228	        visible_class_ids=[class_id] if class_id else visible_class_ids,
   229	    )
   230	    agg = await grade_aggregates(
   231	        db, exam_id=exam_id, school_id=school_id,
   232	        subject_id=subject_id,
   233	        visible_subject_codes=visible_subject_codes,
   234	        visible_class_ids=visible_class_ids,
   235	    )
   236	
   237	    insights = await question_insights(
   238	        db, exam_id=exam_id, school_id=school_id,
   239	        subject_id=subject_id,
   240	        visible_subject_codes=visible_subject_codes,
   241	        visible_class_ids=[class_id] if class_id else visible_class_ids,
   242	    )
   243	
   244	    # 构建诊断文本
   245	    parts = []
   246	    grade_avg = agg.get("grade_stats", {}).get("avg_score")
   247	    subjects = summary.get("subjects", [])
   248	    if subjects:
   249	        subj = subjects[0]
   250	        class_avg = subj.get("avg_score")
   251	        if class_avg is not None and grade_avg is not None:
   252	            diff = round(class_avg - grade_avg, 1)
   253	            if diff < 0:
   254	                parts.append(f"本次考试均分 {class_avg}，低于年级均分 {abs(diff)} 分。")
   255	            elif diff > 0:
   256	                parts.append(f"本次考试均分 {class_avg}，高于年级均分 {diff} 分。")
   257	            else:
   258	                parts.append(f"本次考试均分 {class_avg}，与年级持平。")
   259	
   260	    # 薄弱题
   261	    weak = [q for q in insights.get("questions", []) if q["score_rate"] < 0.5]
   262	    weak.sort(key=lambda x: x["score_rate"])
   263	    weak_questions = []
   264	    if weak:
   265	        q = weak[0]
   266	        parts.append(f"主要失分集中在第 {q['name']} 题（得分率 {q['score_rate']:.0%}）。")
   267	        weak_questions = [{"name": w["name"], "score_rate": w["score_rate"]} for w in weak[:5]]
   268	
   269	    # 高频错因
   270	    all_errors: Counter = Counter()
   271	    for q in insights.get("questions", []):
   272	        for ec in q.get("error_causes", []):
   273	            all_errors[ec["cause"]] += ec["count"]
   274	    error_distribution = {}
   275	    total_errors = sum(all_errors.values())
   276	    if total_errors > 0:
   277	        top_cause = all_errors.most_common(1)[0]
   278	        pct = top_cause[1] / total_errors
   279	        parts.append(f"{pct:.0%} 的错误为{top_cause[0]}。")
   280	        for cause, cnt in all_errors.most_common():
   281	            error_distribution[cause] = round(cnt / total_errors, 4)
   282	
   283	    suggestions = []
   284	    if weak:
   285	        suggestions.append(f"建议重点讲解第 {weak[0]['name']} 题相关知识点。")
   286	
   287	    return {
   288	        "summary_text": "".join(parts) if parts else "暂无诊断数据。",
   289	        "weak_questions": weak_questions,
   290	        "error_distribution": error_distribution,
   291	        "suggestions": suggestions,
   292	    }
   293	```
