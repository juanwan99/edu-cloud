   649	async def student_rankings(
   650	    db: AsyncSession, *, exam_id: str, school_id: str,
   651	    subject_id: str | None = None,
   652	    class_id: str | None = None,
   653	    visible_subject_codes: list[str] | None = None,
   654	    visible_class_ids: list[str] | None = None,
   655	) -> dict:
   656	    """学生排名 + 进退步 delta。"""
   657	    effective_class_ids = [class_id] if class_id else visible_class_ids
   658	    current = await _get_student_scores(db, exam_id, school_id, subject_id, effective_class_ids)
   659	    if not current:
   660	        return {"students": []}
   661	
   662	    # 上次考试排名
   663	    prev_exam_id = await _find_prev_exam(db, exam_id, school_id)
   664	    prev_map: dict[str, dict] = {}
   665	    if prev_exam_id:
   666	        prev_scores = await _get_student_scores(db, prev_exam_id, school_id, subject_id, effective_class_ids)
   667	        for p in prev_scores:
   668	            prev_map[p["student_id"]] = p
   669	
   670	    students = []
   671	    for s in current:
   672	        prev = prev_map.get(s["student_id"])
   673	        students.append({
   674	            "student_id": s["student_id"],
   675	            "name": s["name"],
   676	            "score": round(s["score"], 2),
   677	            "class_rank": s.get("class_rank"),
   678	            "grade_rank": s["grade_rank"],
   679	            "prev_class_rank": prev["class_rank"] if prev else None,
   680	            "prev_grade_rank": prev["grade_rank"] if prev else None,
   681	            "delta_class": (prev["class_rank"] - s["class_rank"]) if prev and prev.get("class_rank") else None,
   682	            "delta_grade": (prev["grade_rank"] - s["grade_rank"]) if prev else None,
   683	        })
   684	
   685	    return {"students": students}
