    51	# src/edu_cloud/modules/analytics/insights_service.py
    52	"""AI 阅卷深度分析 — 错因聚合 + 诊断文本生成。"""
    53	import logging
    54	import re
    55	from collections import Counter, defaultdict
    56	
    57	from sqlalchemy import select, func
    58	from sqlalchemy.ext.asyncio import AsyncSession
    59	
    60	from edu_cloud.modules.exam.models import Exam, Subject, Question
    61	from edu_cloud.modules.grading.models import GradingResult
    62	from edu_cloud.modules.scan.models import StudentAnswer
    63	from edu_cloud.modules.student.models import Class, Student
    64	from edu_cloud.services.exceptions import NotFoundError
    65	
    66	logger = logging.getLogger(__name__)
    67	
    68	# V1 关键词分类规则
    69	_ERROR_PATTERNS = [
    70	    (re.compile(r"概念|混淆|误写|误用|错误.*名词|名词.*错误"), "概念混淆"),
    71	    (re.compile(r"计算|运算|数值|算错|算术"), "计算错误"),
    72	    (re.compile(r"步骤|不完整|缺少|缺失|遗漏|不全"), "步骤不完整"),
    73	    (re.compile(r"审题|理解|题意|看错"), "审题不清"),
    74	]
    75	
    76	
    77	def _classify_error(reason: str) -> str:
    78	    for pattern, label in _ERROR_PATTERNS:
    79	        if pattern.search(reason):
    80	            return label
    81	    return "其他"
    82	
