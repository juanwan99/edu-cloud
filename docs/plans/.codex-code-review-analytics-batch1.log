   164	async def exam_diagnosis(
   165	    db: AsyncSession, *, exam_id: str, school_id: str,
   166	    subject_id: str | None = None,
   167	    class_id: str | None = None,
   168	    visible_subject_codes: list[str] | None = None,
   169	    visible_class_ids: list[str] | None = None,
   170	) -> dict:
   171	    """生成考试诊断文本（模板拼接，不调 LLM）。ORC-007。
   172	
   173	    F001 修复：所有数据源使用同一 scoped_class_ids 口径。
   174	    当传入 class_id 时，class_avg 来自该班数据，grade_avg 来自全校可见数据。
   175	    两个 summary 调用使用不同 scope 以实现"班级 vs 年级"对比。
   176	    """
   177	    from edu_cloud.modules.analytics.service import exam_summary
   178	
   179	    scoped_class_ids = [class_id] if class_id else visible_class_ids
   180	
   181	    # 班级/当前范围的均分
   182	    summary = await exam_summary(
   183	        db, exam_id=exam_id, school_id=school_id,
   184	        visible_subject_codes=visible_subject_codes,
   185	        visible_class_ids=scoped_class_ids,
   186	    )
   187	
   188	    # 年级均分（全可见范围，用于对比基线）
   189	    grade_summary = await exam_summary(
   190	        db, exam_id=exam_id, school_id=school_id,
   191	        visible_subject_codes=visible_subject_codes,
   192	        visible_class_ids=visible_class_ids,
   193	    ) if class_id else summary
   194	
   195	    insights = await question_insights(
   196	        db, exam_id=exam_id, school_id=school_id,
   197	        subject_id=subject_id,
   198	        visible_subject_codes=visible_subject_codes,
   199	        visible_class_ids=scoped_class_ids,
   200	    )
   201	
   202	    # 构建诊断文本
   203	    parts = []
   204	    subjects = summary.get("subjects", [])
   205	    grade_subjects = grade_summary.get("subjects", [])
   206	    if subjects:
   207	        subj = subjects[0]
   208	        class_avg = subj.get("avg_score")
   209	        # F001: grade_avg 从 grade_summary 同科目取，口径一致
   210	        grade_avg = None
   211	        if grade_subjects:
   212	            grade_subj = next((g for g in grade_subjects if g.get("subject_id") == subj.get("subject_id")), grade_subjects[0])
   213	            grade_avg = grade_subj.get("avg_score")
   214	        if class_avg is not None and grade_avg is not None:
   215	            diff = round(class_avg - grade_avg, 1)
   216	            if diff < 0:
   217	                parts.append(f"本次考试均分 {class_avg}，低于年级均分 {abs(diff)} 分。")
   218	            elif diff > 0:
   219	                parts.append(f"本次考试均分 {class_avg}，高于年级均分 {diff} 分。")
   220	            else:
   221	                parts.append(f"本次考试均分 {class_avg}，与年级持平。")
   222	
   223	    # 薄弱题
   224	    weak = [q for q in insights.get("questions", []) if q["score_rate"] < 0.5]
   225	    weak.sort(key=lambda x: x["score_rate"])
   226	    weak_questions = []
   227	    if weak:
   228	        q = weak[0]
   229	        parts.append(f"主要失分集中在第 {q['name']} 题（得分率 {q['score_rate']:.0%}）。")
   230	        weak_questions = [{"name": w["name"], "score_rate": w["score_rate"]} for w in weak[:5]]
   231	
   232	    # 高频错因
   233	    all_errors: Counter = Counter()
   234	    for q in insights.get("questions", []):
   235	        for ec in q.get("error_causes", []):
   236	            all_errors[ec["cause"]] += ec["count"]
   237	    error_distribution = {}
   238	    total_errors = sum(all_errors.values())
   239	    if total_errors > 0:
   240	        top_cause = all_errors.most_common(1)[0]
   241	        pct = top_cause[1] / total_errors
   242	        parts.append(f"{pct:.0%} 的错误为{top_cause[0]}。")
   243	        for cause, cnt in all_errors.most_common():
   244	            error_distribution[cause] = round(cnt / total_errors, 4)
   245	
   246	    suggestions = []
   247	    if weak:
   248	        suggestions.append(f"建议重点讲解第 {weak[0]['name']} 题相关知识点。")
   249	
   250	    return {
   251	        "summary_text": "".join(parts) if parts else "暂无诊断数据。",
   252	        "weak_questions": weak_questions,
   253	        "error_distribution": error_distribution,
   254	        "suggestions": suggestions,
   255	    }
