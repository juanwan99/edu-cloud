   413	@router.get("/report/grade/{exam_id}/{subject_id}/export")
   414	async def export_grade_subject_report(
   415	    exam_id: str,
   416	    subject_id: str,
   417	    format: str = Query("pdf", pattern="^(pdf|xlsx)$"),
   418	    db: AsyncSession = Depends(get_db),
   419	    current: dict = Depends(get_current_user),
   420	):
   421	    """导出年级学科报告（PDF / XLSX）。
   422	
   423	    权限：通过 visible_subject_codes / visible_class_ids 过滤。
   424	    """
   425	    role = current["current_role"]
   426	    try:
   427	        report = await build_grade_subject_report(
   428	            db, exam_id=exam_id, subject_id=subject_id, school_id=role.school_id,
   429	            visible_subject_codes=get_visible_subject_codes(role),
   430	            visible_class_ids=get_visible_class_ids(role),
   431	        )
   432	    except NotFoundError as e:
   433	        raise HTTPException(404, str(e))
   434	    except PermissionDeniedError as e:
   435	        raise HTTPException(403, str(e))
   436	
   437	    base_name = f"{report['exam']['name']}-{report['subject']['name']}-年级报告"
   438	    if format == "pdf":
   439	        data = render_grade_subject_report_pdf(report)
   440	        media_type = "application/pdf"
   441	        filename = f"{base_name}.pdf"
   442	    else:
   443	        data = render_grade_subject_report_xlsx(report)
   444	        media_type = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
   445	        filename = f"{base_name}.xlsx"
   446	
   447	    encoded = quote(filename)
   448	    return Response(
   449	        content=data,
   450	        media_type=media_type,
   451	        headers={
   452	            "Content-Disposition": f"attachment; filename*=UTF-8''{encoded}",
   453	        },
   454	    )
