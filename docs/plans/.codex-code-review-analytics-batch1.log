  1482	
  1483	```typescript
  1484	// frontend-nuxt/composables/useAnalytics.ts
  1485	export function useAnalytics() {
  1486	  const api = useApi()
  1487	  const loading = ref(false)
  1488	  const advancedLoading = ref(false)
  1489	
  1490	  const summary = ref<any>(null)
  1491	  const distribution = ref<any>(null)
  1492	  const gradeAggregates = ref<any>(null)
  1493	  const questions = ref<any>(null)
  1494	
  1495	  const questionInsights = ref<any>(null)
  1496	  const diagnosis = ref<any>(null)
  1497	
  1498	  async function loadBasicData(params: { exam_id: string; subject_id?: string }) {
  1499	    loading.value = true
  1500	    clearAdvancedData()
  1501	    try {
  1502	      const [s, d, g, q] = await Promise.all([
  1503	        api.getExamSummary(params.exam_id),
  1504	        api.getExamDistribution(params.exam_id, params.subject_id),
  1505	        api.getExamGradeAggregates(params.exam_id, params.subject_id),
  1506	        params.subject_id ? api.getSubjectQuestions(params.subject_id) : Promise.resolve(null),
  1507	      ])
  1508	      summary.value = s
  1509	      distribution.value = d
  1510	      gradeAggregates.value = g
  1511	      questions.value = q
  1512	    } finally {
  1513	      loading.value = false
  1514	    }
  1515	  }
  1516	
  1517	  async function loadAdvancedData(params: { exam_id: string; subject_id?: string; class_id?: string }) {
  1518	    if (questionInsights.value) return
  1519	    advancedLoading.value = true
  1520	    try {
  1521	      const [qi, diag] = await Promise.all([
  1522	        api.getQuestionInsights(params.exam_id, params.subject_id),
  1523	        api.getExamDiagnosis(params.exam_id, params.subject_id, params.class_id),
  1524	      ])
  1525	      questionInsights.value = qi
  1526	      diagnosis.value = diag
  1527	    } finally {
  1528	      advancedLoading.value = false
  1529	    }
  1530	  }
  1531	
  1532	  function clearAdvancedData() {
  1533	    questionInsights.value = null
  1534	    diagnosis.value = null
  1535	  }
  1536	
  1537	  function clearAll() {
  1538	    summary.value = null
  1539	    distribution.value = null
  1540	    gradeAggregates.value = null
  1541	    questions.value = null
  1542	    clearAdvancedData()
  1543	  }
  1544	
  1545	  return {
  1546	    loading, advancedLoading,
  1547	    summary, distribution, gradeAggregates, questions,
  1548	    questionInsights, diagnosis,
  1549	    loadBasicData, loadAdvancedData, clearAll,
  1550	  }
  1551	}
  1552	```
