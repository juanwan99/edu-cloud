     1	"""PowerOptions 级联筛选服务 — 构建 年级→班级→科目→考试 级联树。"""
     2	from __future__ import annotations
     3	
     4	from collections import defaultdict
     5	
     6	from sqlalchemy import select, func, distinct, extract
     7	from sqlalchemy.ext.asyncio import AsyncSession
     8	
     9	from edu_cloud.modules.exam.models import Exam, Subject, ExamResult
    10	from edu_cloud.modules.student.models import Class, Student
    11	
    12	
    13	async def get_power_options(
    14	    db: AsyncSession,
    15	    school_id: str,
    16	    visible_class_ids: list[str] | None = None,
    17	    visible_subject_codes: list[str] | None = None,
    18	    exam_type: str | None = None,
    19	    year: int | None = None,
    20	) -> dict:
    21	    stmt = (
    22	        select(
    23	            Class.grade,
    24	            Class.id.label("class_id"),
    25	            Class.name.label("class_name"),
    26	            Subject.id.label("subject_id"),
    27	            Subject.code.label("subject_code"),
    28	            Subject.name.label("subject_name"),
    29	            Exam.id.label("exam_id"),
    30	            Exam.name.label("exam_name"),
    31	            Exam.exam_date.label("exam_date"),
    32	            func.count(distinct(ExamResult.student_id)).label("student_count"),
    33	        )
    34	        .select_from(Exam)
    35	        .join(Subject, Subject.exam_id == Exam.id)
    36	        .join(ExamResult, ExamResult.exam_id == Exam.id)
    37	        .join(Student, Student.id == ExamResult.student_id)
    38	        .join(Class, Class.id == Student.class_id)
    39	        .where(Exam.school_id == school_id)
    40	        .where(Exam.status == "completed")
    41	        .group_by(
    42	            Class.grade, Class.id, Class.name,
    43	            Subject.id, Subject.code, Subject.name,
    44	            Exam.id, Exam.name, Exam.exam_date,
    45	        )
    46	        .order_by(Class.grade, Class.name, Subject.name, Exam.exam_date.desc())
    47	    )
    48	
    49	    if visible_class_ids is not None:
    50	        stmt = stmt.where(Class.id.in_(visible_class_ids))
    51	    if visible_subject_codes is not None:
    52	        stmt = stmt.where(Subject.code.in_(visible_subject_codes))
    53	    if exam_type:
    54	        stmt = stmt.where(Exam.exam_type == exam_type)
    55	    if year:
    56	        stmt = stmt.where(extract("year", Exam.exam_date) == year)
    57	
    58	    rows = (await db.execute(stmt)).all()
    59	
    60	    return _build_tree(rows)
    61	
    62	
    63	def _build_tree(rows) -> dict:
    64	    grade_map: dict[str, dict] = {}
    65	
    66	    for row in rows:
    67	        grade_name = row.grade
    68	        if grade_name not in grade_map:
    69	            grade_map[grade_name] = {}
    70	
    71	        class_id = row.class_id
    72	        if class_id not in grade_map[grade_name]:
    73	            grade_map[grade_name][class_id] = {
    74	                "id": class_id,
    75	                "name": row.class_name,
    76	                "subjects": {},
    77	            }
    78	
    79	        cls = grade_map[grade_name][class_id]
    80	        subj_id = row.subject_id
    81	        if subj_id not in cls["subjects"]:
    82	            cls["subjects"][subj_id] = {
    83	                "id": subj_id,
    84	                "code": row.subject_code,
    85	                "name": row.subject_name,
    86	                "exams": [],
    87	            }
    88	
    89	        cls["subjects"][subj_id]["exams"].append({
    90	            "id": row.exam_id,
    91	            "exam_id": row.exam_id,
    92	            "subject_id": subj_id,
    93	            "name": row.exam_name,
    94	            "exam_date": row.exam_date.isoformat() if row.exam_date else None,
    95	            "student_count": row.student_count,
    96	        })
    97	
    98	    grades = []
    99	    for grade_name, classes_map in grade_map.items():
   100	        real_classes = list(classes_map.values())
   101	
   102	        all_subjects: dict[str, dict] = {}
   103	        for cls in real_classes:
   104	            for subj_id, subj in cls["subjects"].items():
   105	                if subj_id not in all_subjects:
   106	                    all_subjects[subj_id] = {
   107	                        "id": subj["id"],
   108	                        "code": subj["code"],
   109	                        "name": subj["name"],
   110	                        "exams": defaultdict(lambda: {"student_count": 0}),
   111	                    }
   112	                for exam in subj["exams"]:
   113	                    key = exam["exam_id"]
   114	                    entry = all_subjects[subj_id]["exams"][key]
   115	                    entry["id"] = exam["exam_id"]
   116	                    entry["exam_id"] = exam["exam_id"]
   117	                    entry["subject_id"] = exam["subject_id"]
   118	                    entry["name"] = exam["name"]
   119	                    entry["exam_date"] = exam["exam_date"]
   120	                    entry["student_count"] += exam["student_count"]
   121	
   122	        all_node = {
   123	            "id": "all",
   124	            "name": "全部班级",
   125	            "subjects": {
   126	                sid: {
   127	                    "id": s["id"],
   128	                    "code": s["code"],
   129	                    "name": s["name"],
   130	                    "exams": list(s["exams"].values()),
   131	                }
   132	                for sid, s in all_subjects.items()
   133	            },
   134	        }
   135	
   136	        for cls in real_classes:
   137	            cls["subjects"] = list(cls["subjects"].values())
   138	        all_node["subjects"] = list(all_node["subjects"].values())
   139	
   140	        grades.append({
   141	            "id": grade_name,
   142	            "name": grade_name,
   143	            "classes": [all_node] + real_classes,
   144	        })
   145	
   146	    return {"grades": grades}

