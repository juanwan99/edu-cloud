    38	  it('有 conduct sidebar 入口的角色必须有 view_conduct 权限（防点击 403）', () => {
    39	    // 单向契约：入口 → 权限（真 bug 防护）
    40	    // 反向（权限 → 入口）是产品决策，不强制，见 lesson_prep_leader
    41	    for (const role of Object.keys(ROLE_PERMISSIONS)) {
    42	      const items = getSidebarItems(role)
    43	      const hasConductItem = items.some(i => i.route?.startsWith(CONDUCT_ROUTE_PREFIX))
    44	      if (hasConductItem) {
    45	        expect(
    46	          HAS_VIEW_CONDUCT(role),
    47	          `${role} sidebar 有 conduct 入口但 permissions.js 缺 view_conduct — 点击会 403`,
    48	        ).toBe(true)
    49	      }
    50	    }
    51	  })
    52	})
