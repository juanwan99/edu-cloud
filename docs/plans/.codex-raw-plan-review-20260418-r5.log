    27	    ['subject_teacher', 2, 'TEACHER'],
    28	  ])('%s sidebar 含 %d 个 conduct 入口（%s）', (role, expectedCount) => {
    29	    const items = getSidebarItems(role)
    30	    const conductItems = items.filter(i => i.route?.startsWith(CONDUCT_ROUTE_PREFIX))
    31	    expect(conductItems.length).toBe(expectedCount)
