    38	})
    39	
    40	const items = ref([])
    41	const total = ref(0)
    42	const page = ref(1)
    43	const pageSize = ref(10)
    44	const loading = ref(false)
    45	
    46	const totalPages = computed(() => Math.max(1, Math.ceil(total.value / pageSize.value)))
    47	
    48	async function load() {
    49	  if (!props.nodeId) return
    50	  loading.value = true
    51	  try {
    52	    const data = await getExamItems(props.nodeId, page.value, pageSize.value)
    53	    items.value = data.items || []
    54	    total.value = data.total || 0
    55	  } catch (e) {
    56	    items.value = []
    57	    total.value = 0
    58	  } finally {
    59	    loading.value = false
    60	  }
    61	}
    62	
    63	function prevPage() { if (page.value > 1) { page.value--; load() } }
    64	function nextPage() { if (page.value < totalPages.value) { page.value++; load() } }
    65	
    66	watch(() => props.nodeId, () => { page.value = 1; load() }, { immediate: true })
