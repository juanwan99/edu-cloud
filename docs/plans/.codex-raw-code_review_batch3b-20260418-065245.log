<template>
  <div class="exam-items-tab">
    <div v-if="loading" class="loading">加载中…</div>
    <div v-else-if="total === 0" class="empty">该概念暂无关联高考真题</div>
    <div v-else>
      <div class="summary">共 {{ total }} 道关联题，显示第 {{ (page-1)*pageSize + 1 }}-{{ Math.min(page*pageSize, total) }} 条</div>
