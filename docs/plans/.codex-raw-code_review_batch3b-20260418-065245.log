            </n-form-item>
            <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 12px;">
              <n-button type="primary" size="small" @click="handleSave" :loading="saving">
                保存修改
              </n-button>
              <n-button
                v-if="node.review_status === 'ai_draft'"
                size="small"
                @click="handleReview('teacher_reviewed')"
              >
                标记已审核
              </n-button>
