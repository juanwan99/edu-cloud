import asyncio
from unittest.mock import AsyncMock
from edu_cloud.ai.context_manager import ContextManager
from edu_cloud.ai.llm_adapter import LLMProxyAdapter, LLMResponse, TokenUsage
from edu_cloud.ai.schemas import Message, ToolCall

async def main():
    adapter = LLMProxyAdapter(base_url='http://test:8100', slot='primary')
    adapter.chat = AsyncMock(return_value=LLMResponse(content='sum', usage=TokenUsage(1,1)))
    msgs = [Message(role='system', content='sys')]
    for i in range(1,5):
        msgs.append(Message(role='user', content=f'u{i}'))
        msgs.append(Message(role='assistant', content=None, tool_calls=[ToolCall(id=f'tc{i}', name='tool', arguments={'i': i})]))
        msgs.append(Message(role='tool', content=f'result{i}', tool_call_id=f'tc{i}', name='tool'))
        msgs.append(Message(role='assistant', content=f'a{i}'))
    out = await ContextManager().compact(msgs, adapter)
    for m in out:
        print(m.role, m.content, 'tc' if m.tool_calls else '')
    print('out_len=', len(out))

asyncio.run(main())
