"assign_grading_task\"]\n    assert assign.category == \"L4_action\"\n\n    # Phase 1d 合入后启用以下断言:\n    # assert progress.domain == \"exam\"\n    # assert progress.risk_level == \"low\"\n    # assert assign.risk_level == \"med\"\n    # assert \"platform_admin\" in assign.allowed_roles\n```\n\n- [ ] **Step 2: Implement tools**\n\n```python\n# src/edu_cloud/ai/tools/grading_ops.py\nfrom edu_cloud.ai.registry import tools\nfrom edu_cloud.modules.grading.assignment_service import GradingAssignmentService\nfrom edu_cloud.modules.grading.quality_service import QualityCheckService\n\n\n@tools.register(\n    name=\"get_grading_progress\",\n    description=\"获取考试阅卷进度汇总：总任务数、完成/进行中/待开始数、按教师明细\",\n    parameters={\n        \"type\": \"object\",\n        \"properties\": {\"exam_id\": {\"type\": \"string\", \"description\": \"考试 ID\"}},\n        \"required\": [\"exam_id\"],\n    },\n    category=\"L1_exam\",  # Phase 1d 合入后升级: 添加 module_code/domain/risk_level/allowed_roles\n)\nasync def get_grading_progress(exam_id: str, _db=None, _school_id: str = \"\"):\n    return await GradingAssignmentService.get_progress(_db, exam_id)\n\n\n@tools.register(\n    name=\"get_quality_report\",\n    description=\"获取阅卷质量报告：抽检数量、平均偏差、高严重度问题数\",\n    parameters={\n        \"type\": \"object\",\n        \"properties\": {\"exam_id\": {\"type\": \"string\", \"description\": \"考试 ID\"}},\n        \"required\": [\"exam_id\"],\n    },\n    category=\"L2_analytics\",  # Phase 1d 合入后升级: 添加 module_code/domain/risk_level/allowed_roles\n)\nasync def get_quality_report(exam_id: str, _db=None, _school_id: str = \"\"):\n    return await QualityCheckService.get_quality_report(_db, exam_id)\n\n\n@tools.register(\n    name=\"assign_grading_task\",\n    description=\"自动分配阅卷任务：按题目均匀分配给指定教师列表\",\n    parameters={\n        \"type\": \"object\",\n        \"properties\": {\n            \"exam_id\": {\"type\": \"string\", \"description\": \"考试 ID\"},\n            \"subject_id\": {\"type\": \"string\", \"description\": \"科目 ID\"},\n            \"question_ids\": {\"type\": \"string\", \"description\": \"题目 ID 列表，逗号分隔\"},\n            \"teacher_ids\": {\"type\": \"string\", \"description\": \"教师 ID 列表，逗号分隔\"},\n        },\n        \"required\": [\"exam_id\", \"subject_id\", \"question_ids\", \"teacher_ids\"],\n    },\n    category=\"L4_action\",  # Phase 1d 合入后升级: 添加 module_code/domain/risk_level/allowed_roles\n)\nasync def assign_grading_task(\n    exam_id: str, subject_id: str,\n    question_ids: str, teacher_ids: str,\n    _db=None, _school_id: str = \"\",\n):\n    q_list = [q.strip() for q in question_ids.split(\",\") if q.strip()]\n    t_list = [t.strip() for t in teacher_ids.split(\",\") if t.strip()]\n    assignments = await GradingAssignmentService.auto_assign(\n        _db, exam_id=exam_id, subject_id=subject_id,\n        question_ids=q_list, teacher_ids=t_list, school_id=_school_id,\n    )\n    return {\n        \"assigned\": len(assignments),\n        \"teachers\": [a.assigned_to for a in assignments],\n    }\n```\n\n- [ ] **Step 3: Register in __init__.py**\n\n在 `src/edu_cloud/ai/tools/__init__.py` 添加：\n```python\nfrom . import grading_ops  # noqa: F401\n```\n\n- [ ] **Step 4: Update alembic/env.py, test_alembic_migration.py, CLAUDE.md**\n\n- alembic/env.py: 无需额外 import（grading/models.py 已被导入）\n- test_alembic_migration.py: 在预期表集合添加 `\"grading_assignments\"`, `\"grading_quality_checks\"`\n- CLAUDE.md: 同步新 API 端点、权限、数据模型\n\n- [ ] **Step 5: Generate Alembic migration**\n\nRun: `cd C:/Users/Administrator/edu-cloud && alembic revision --autogenerate -m \"add grading_assignments and grading_quality_checks tables\"`\n\n- [ ] **Step 6: Run full test suite**\n\nRun: `cd C:/Users/Administrator/edu-cloud && python -m pytest --tb=short -q`\nExpected: 全部 pass（~960+ tests）\n\n- [ ] **Step 7: Commit**\n\n```bash\ngit add src/edu_cloud/ai/tools/grading_ops.py src/edu_cloud/ai/tools/__init__.py alembic/ tests/test_alembic_migration.py tests/test_ai/test_grading_tools.py CLAUDE.md\ngit commit -m \"feat: add grading Agent tools + Alembic migration + CLAUDE.md sync\"\n```\n\n**审查清单:**\n- ✓ 3 个工具注册到现有 registry\n- ✓ 工具使用 _db/_school_id 注入模式（与现有工具一致）\n- ✓ 工具只用现有 category 参数，Phase 1d 元数据参数注释标记待升级（F-05 修复）\n- ✓ Migration 包含 grading_assignments + grading_quality_checks\n- ✓ CLAUDE.md 同步了所有新增端点和模型\n- ✗ 工具未做 school_id scope 过滤（依赖调用方注入）\n\n**测试契约:**\n1. 工具注册和基本调用\n   - 入口: `tools.execute(\"get_grading_progress\", {\"exam_id\": \"e1\"}, _db=db, _school_id=\"s1\")`\n   - 反例: 未注册的工具会返回 error dict — 本测试验证工具存在且可调用\n   - 边界: exam_id 不存在（返回空进度） / _db=None（抛异常）\n   - 回归: N/A\n   - 命令: `pytest tests/test_ai/test_grading_tools.py -v`\n"
