   701	"""
   702	from datetime import datetime
   703	from pydantic import BaseModel, Field
   704	
   705	
   706	class TrendEntry(BaseModel):
   707	    exam_id: str
   708	    subject_code: str
   709	    total_score: float
   710	    max_score: float
   711	    score_rate: float
   712	    class_rank: int | None = None
   713	    grade_rank: int | None = None
