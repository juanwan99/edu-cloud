  1102	        sa.Column('xueduan', sa.String(length=20), nullable=True),
  1103	        sa.Column('sort_order', sa.Integer(), nullable=False, server_default='0'),
  1104	        sa.Column('created_at', sa.DateTime(), nullable=False),
  1105	        sa.Column('updated_at', sa.DateTime(), nullable=False),
  1106	        sa.UniqueConstraint('school_id', 'name', name='uq_grade_school_name'),
  1107	    )
  1108	
  1109	    # 1.4 teaching_plans 新表
  1110	    op.create_table(
  1111	        'teaching_plans',
  1112	        sa.Column('id', sa.String(length=36), primary_key=True),
  1113	        sa.Column('school_id', sa.String(length=36), sa.ForeignKey('schools.id'), nullable=False),
  1114	        sa.Column('subject_code', sa.String(length=50), nullable=False),
  1115	        sa.Column('grade_id', sa.String(length=36), sa.ForeignKey('grades.id'), nullable=True),
  1116	        sa.Column('semester', sa.String(length=30), nullable=False),
  1117	        sa.Column('weeks_json', sa.JSON(), nullable=True),
  1118	        sa.Column('created_by', sa.String(length=36), sa.ForeignKey('users.id'), nullable=True),
  1119	        sa.Column('created_at', sa.DateTime(), nullable=False),
  1120	        sa.Column('updated_at', sa.DateTime(), nullable=False),
  1121	        sa.UniqueConstraint('school_id', 'subject_code', 'grade_id', 'semester',
  1122	                            name='uq_teaching_plan_subject_grade_semester'),
  1123	    )
  1124	
  1125	    # 1.1 bank_questions 扩展
  1126	    with op.batch_alter_table('bank_questions') as batch_op:
  1127	        batch_op.add_column(sa.Column('source', sa.String(length=20), nullable=True))
  1128	        batch_op.add_column(sa.Column('explanation', sa.Text(), nullable=True))
  1129	        batch_op.add_column(sa.Column('knowledge_point_ids', sa.JSON(), nullable=True))
  1130	        batch_op.add_column(sa.Column('grade_id', sa.String(length=36), nullable=True))
  1131	        batch_op.add_column(sa.Column('difficulty_level', sa.String(length=10), nullable=True))
  1132	        batch_op.create_foreign_key(
  1133	            'fk_bank_questions_grade_id', 'grades', ['grade_id'], ['id'],
  1134	        )
  1135	
  1136	    # 1.2 concept_graph_nodes.depth_level
  1137	    with op.batch_alter_table('concept_graph_nodes') as batch_op:
  1138	        batch_op.add_column(sa.Column('depth_level', sa.String(length=20), nullable=True))
  1139	
  1140	    # 1.3 classes.grade_id FK
  1141	    with op.batch_alter_table('classes') as batch_op:
  1142	        batch_op.add_column(sa.Column('grade_id', sa.String(length=36), nullable=True))
  1143	        batch_op.create_foreign_key(
  1144	            'fk_classes_grade_id', 'grades', ['grade_id'], ['id'],
  1145	        )
  1146	
  1147	
  1148	def downgrade() -> None:
  1149	    with op.batch_alter_table('classes') as batch_op:
  1150	        batch_op.drop_constraint('fk_classes_grade_id', type_='foreignkey')
  1151	        batch_op.drop_column('grade_id')
  1152	
  1153	    with op.batch_alter_table('concept_graph_nodes') as batch_op:
  1154	        batch_op.drop_column('depth_level')
  1155	
  1156	    with op.batch_alter_table('bank_questions') as batch_op:
  1157	        batch_op.drop_constraint('fk_bank_questions_grade_id', type_='foreignkey')
  1158	        batch_op.drop_column('difficulty_level')
  1159	        batch_op.drop_column('grade_id')
  1160	        batch_op.drop_column('knowledge_point_ids')
  1161	        batch_op.drop_column('explanation')
  1162	        batch_op.drop_column('source')
  1163	
  1164	    op.drop_table('teaching_plans')
  1165	    op.drop_table('grades')
