   720	    confidence: float = Field(ge=0.0, le=1.0)
   721	    trend: str
   722	    attempt_count: int
   723	    correct_count: int
   724	
   725	
   726	class ErrorPatternEntry(BaseModel):
   727	    subject_code: str
   728	    error_distribution: dict
   729	    total_errors: int
   730	    careless_rate: float | None = None
   731	    snapshot_date: datetime
   732	
   733	
   734	class ProfileSummary(BaseModel):
   735	    exam_count: int
   736	    avg_score_rate: float
   737	    weakness_top3: list[str]
   738	
   739	
   740	class StudentProfileView(BaseModel):
   741	    """学生学情综合视图（S3 前端消费）。"""
   742	    student_id: str
   743	    school_id: str
   744	    trend: list[TrendEntry]
   745	    knowledge_map: list[KnowledgeEntry]
   746	    error_patterns: list[ErrorPatternEntry]
   747	    summary: ProfileSummary
   748	    generated_at: datetime
   749	```
