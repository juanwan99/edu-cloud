  1081	"""
  1082	from typing import Sequence, Union
  1083	
  1084	from alembic import op
  1085	import sqlalchemy as sa
  1086	
  1087	
  1088	revision: str = '{新 rev}'
  1089	down_revision: Union[str, Sequence[str], None] = 'f7a3b2c1d456'
  1090	branch_labels: Union[str, Sequence[str], None] = None
  1091	depends_on: Union[str, Sequence[str], None] = None
