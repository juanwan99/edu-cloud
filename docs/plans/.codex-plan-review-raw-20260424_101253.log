   830	
   831	```python
   832	from datetime import datetime
   833	from edu_cloud.modules.profile.schemas import (
   834	    StudentProfileView, TrendEntry, KnowledgeEntry, ErrorPatternEntry, ProfileSummary,
   835	)
   836	
   837	
   838	async def get_student_profile_view(
   839	    db: AsyncSession,
   840	    *,
   841	    student_id: str,
   842	    school_id: str,
   843	    subject_code: str | None = None,
   844	    trend_limit: int = 10,
   845	) -> StudentProfileView:
   846	    """聚合学生学情综合视图（零新表，读取现有 3 表）。
   847	
   848	    refs: design §4 1.6 / 附录 B §Gap#1
   849	    """
   850	    trend_rows = await get_student_trend(
   851	        db, student_id=student_id, school_id=school_id,
   852	        subject_code=subject_code, limit=trend_limit,
   853	    )
   854	    trend = [
   855	        TrendEntry(
   856	            exam_id=r.exam_id, subject_code=r.subject_code,
   857	            total_score=r.total_score, max_score=r.max_score,
   858	            score_rate=r.score_rate,
   859	            class_rank=r.class_rank, grade_rank=r.grade_rank,
   860	            exam_date=r.exam_date,
   861	        ) for r in trend_rows
   862	    ]
   863	
   864	    knowledge_rows = await get_student_knowledge_map(
   865	        db, student_id=student_id, school_id=school_id,
   866	    )
   867	    knowledge_map = [
   868	        KnowledgeEntry(
   869	            knowledge_point_id=r.knowledge_point_id,
   870	            mastery_level=r.mastery_level, confidence=r.confidence,
   871	            trend=r.trend, attempt_count=r.attempt_count, correct_count=r.correct_count,
   872	        ) for r in knowledge_rows
   873	    ]
   874	
   875	    error_rows = await get_student_error_pattern(
   876	        db, student_id=student_id, school_id=school_id, subject_code=subject_code,
   877	    )
   878	    error_patterns = [
   879	        ErrorPatternEntry(
   880	            subject_code=r.subject_code,
   881	            error_distribution=r.error_distribution or {},
   882	            total_errors=r.total_errors,
   883	            careless_rate=r.careless_rate,
   884	            snapshot_date=r.snapshot_date,
   885	        ) for r in error_rows
   886	    ]
   887	
   888	    weakness_top3 = [k.knowledge_point_id for k in sorted(
   889	        knowledge_map, key=lambda x: x.mastery_level
   890	    )[:3]]
   891	
   892	    summary = ProfileSummary(
   893	        exam_count=len(trend),
   894	        avg_score_rate=(sum(t.score_rate for t in trend) / len(trend)) if trend else 0.0,
   895	        weakness_top3=weakness_top3,
   896	    )
   897	
   898	    return StudentProfileView(
   899	        student_id=student_id, school_id=school_id,
   900	        trend=trend, knowledge_map=knowledge_map, error_patterns=error_patterns,
   901	        summary=summary, generated_at=datetime.utcnow(),
   902	    )
   903	```
