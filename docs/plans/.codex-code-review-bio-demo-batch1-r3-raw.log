import asyncio, sqlite3, tempfile, os
from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker, AsyncSession
from sqlalchemy import select, func

from edu_cloud.models.base import Base
import edu_cloud.modules.adaptive.models  # noqa: F401
import edu_cloud.modules.knowledge_tree.models  # noqa: F401

from edu_cloud.modules.knowledge_tree.models import ConceptGraphNode
from edu_cloud.modules.adaptive.models import DaCatalogSnapshot, DaKnowledgePointMap
from edu_cloud.modules.knowledge_tree.sync_service import sync_knowledge_on_startup


def make_kdb(path):
    conn = sqlite3.connect(path)
    conn.execute(\"CREATE TABLE concepts (id TEXT PRIMARY KEY, name TEXT, knowledge_level TEXT, description TEXT)\")
    conn.execute(\"CREATE TABLE concept_relations (source_id TEXT, target_id TEXT, relation_type TEXT, strength REAL, confidence REAL)\")
    conn.execute(\"CREATE TABLE diagnostic_attributes (id TEXT PRIMARY KEY, name TEXT, linked_concept_ids TEXT, observable_behaviors TEXT, common_cause_families TEXT, required_evidence_modes TEXT, common_errors TEXT, description TEXT)\")
    conn.execute(\"CREATE TABLE study_units (id TEXT PRIMARY KEY, linked_da_ids TEXT)\")
    conn.execute(\"INSERT INTO concepts VALUES ('BIO_SR_CP_M1_A','A','L1','d')\")
    conn.execute(\"INSERT INTO concepts VALUES ('BIO_SR_CP_M1_B','B','L1','d')\")
    conn.execute(\"INSERT INTO concept_relations VALUES ('BIO_SR_CP_M1_A','BIO_SR_CP_M1_B','prerequisite_hard',1.0,1.0)\")
    conn.execute(\"INSERT INTO diagnostic_attributes VALUES ('da1','DA1','[\\\"BIO_SR_CP_M1_A\\\"]','[]','[]','[]','[]','d')\")
    conn.execute(\"INSERT INTO study_units VALUES ('su1','[\\\"da1\\\"]')\")
    conn.commit(); conn.close()


async def main():
    fd, path = tempfile.mkstemp(suffix='.db')
    os.close(fd)
    make_kdb(path)
    engine = create_async_engine('sqlite+aiosqlite:///:memory:')
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
    async with Session() as db:
        # seed partial init: nodes + DA + KP exist, but no edges
        db.add(ConceptGraphNode(id='BIO_SR_CP_M1_A', name='A', knowledge_level='L1', primary_module='M1', description='d', synced_at=None))
        db.add(DaCatalogSnapshot(da_id='da1', name='DA1', module='M1', concept_ids=['BIO_SR_CP_M1_A'], study_unit_ids=['su1'], synced_at=None))
        db.add(DaKnowledgePointMap(da_id='da1', knowledge_point_id='BIO_SR_CP_M1_A', weight=1.0))
        await db.commit()
        res = await sync_knowledge_on_startup(db, knowledge_db_path=path)
        edges = (await db.execute(select(func.count()).select_from(__import__('edu_cloud.modules.knowledge_tree.models', fromlist=['ConceptGraphEdge']).ConceptGraphEdge))).scalar()
        print({'res': res, 'edges': edges})
    await engine.dispose()
    os.unlink(path)

asyncio.run(main())
