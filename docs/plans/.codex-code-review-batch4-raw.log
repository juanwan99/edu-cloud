import edu_cloud.models.agent_snapshot  # noqa: F401
import edu_cloud.models.scope_version  # noqa: F401

from edu_cloud.ai.workflow.engine import WorkflowContext
from edu_cloud.ai.workflow.w6_patrol import scan_grading_overdue, deduplicate_and_dispatch
from edu_cloud.models.school import School
from edu_cloud.models.agent_finding import AgentFinding
from edu_cloud.modules.grading.models import GradingTask


def make_ctx(db, school_id):
    return WorkflowContext(db=db, school_id=school_id, trigger_ref='patrol', run_id='x', step_outputs={})

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:')
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    sf = async_sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

    async with sf() as db:
        school = School(name='S1', code='S1', district='D', api_key_hash='x')
        db.add(school)
        await db.flush()
        task = GradingTask(subject_id='subj', status='processing', total=1, completed=0, failed=0, created_by='u', school_id=school.id)
        db.add(task)
        await db.flush()
        task.created_at = datetime.now(timezone.utc) - timedelta(hours=100)
        await db.commit()
        res = await scan_grading_overdue(make_ctx(db, school.id))
        print('processing_overdue', res)

    async with sf() as db:
        school = School(name='S2', code='S2', district='D', api_key_hash='x')
        db.add(school)
        await db.flush()
        for i in range(10):
            db.add(AgentFinding(school_id=school.id, finding_type='x', severity='warning', target_type='t', target_id=str(i), summary='old', status='notified', notify_roles=['academic_director'], idempotency_key=f'old:{i}'))
        db.add(AgentFinding(school_id=school.id, finding_type='x', severity='warning', target_type='t', target_id='new', summary='new', status='new', notify_roles=['academic_director'], idempotency_key='new:1'))
        await db.commit()
