able=True)\n    version: Mapped[int] = mapped_column(Integer, default=1)\n    status: Mapped[str] = mapped_column(String(20))\n    computed_at: Mapped[datetime] = mapped_column(\n        DateTime(timezone=True), default=lambda: datetime.now(timezone.utc),\n    )"
