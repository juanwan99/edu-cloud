    "content": "import { describe, it, expect, vi, beforeEach } from 'vitest'\nimport { ref, nextTick } from 'vue'\n\n/**\n * KnowledgeTreePage 页面级逻辑测试。\n * 直接测试页面组件需要大量 mock（auth store, API, 子组件）。\n * 这里提取并验证关键页面级逻辑：canEdit watcher + handleEdit 流程。\n */\n\n// 模拟 canEdit watcher 行为\ndescribe('KnowledgeTreePage canEdit watcher logic', () => {\n  it('resets activeTab to graph when canEdit becomes false', async () => {\n    const canEdit = ref(true)\n    const activeTab = ref('review')\n\n    // 模拟 watch 逻辑（与 KnowledgeTreePage.vue 一致）\n    const { watch } = await import('vue')\n    watch(canEdit, (val) => {\n      if (!val && activeTab.value === 'review') {\n        activeTab.value = 'graph'\n      }\n    })\n\n    canEdit.value = false\n    await nextTick()\n    expect(activeTab.value).toBe('graph')\n  })\n\n  it('keeps activeTab when canEdit becomes false but tab is graph', async () => {\n    const canEdit = ref(true)\n    const activeTab = ref('graph')\n\n    const { watch } = await import('vue')\n    watch(canEdit, (val) => {\n      if (!val && activeTab.value === 'review') {\n        activeTab.value = 'graph'\n      }\n    })\n\n    canEdit.value = false\n    await nextTick()\n    expect(activeTab.value).toBe('graph')\n  })\n})\n\n// 模拟 handleEdit 流程（验证 loadQuality 被调用）\ndescribe('KnowledgeTreePage handleEdit logic', () => {\n  it('calls loadQuality after successful edit when canEdit=true', async () => {\n    const loadQualityCalled = ref(false)\n    const canEdit = ref(true)\n    const selectedModule = ref('M1')\n\n    // 模拟 handleEdit 逻辑\n    const applyEdit = vi.fn().mockResolvedValue({})\n    const loadQuality = vi.fn().mockImplementation(() => { loadQualityCalled.value = true })\n\n    async function handleEdit(operations) {\n      await applyEdit(operations)\n      if (canEdit.value) {\n        await loadQuality(selectedModule.value)\n      }\n    }\n\n    await handleEdit([{ op: 'set_review_status', edge_id: 1, status: 'teacher_reviewed' }])\n    expect(applyEdit).toHaveBeenCalledTimes(1)\n    expect(loadQuality).toHaveBeenCalledWith('M1')\n  })\n\n  it('does not call loadQuality when canEdit=false', async () => {\n    const canEdit = ref(false)\n    const selectedModule = ref('M1')\n\n    const applyEdit = vi.fn().mockResolvedValue({})\n    const loadQuality = vi.fn()\n\n    async function handleEdit(operations) {\n      await applyEdit(operations)\n      if (canEdit.value) {\n        await loadQuality(selectedModule.value)\n      }\n    }\n\n    await handleEdit([{ op: 'set_review_status', edge_id: 1, status: 'teacher_reviewed' }])\n    expect(loadQuality).not.toHaveBeenCalled()\n  })\n})\n\n// Batch 2 Task 6: 互斥路由逻辑（INV-004 ModuleOverviewPanel vs ConceptMapPanel）\ndescribe('KnowledgeTreePage Batch 2 routing logic (INV-004)', () => {\n  it('selectedModule=all → ModuleOverviewPanel branch, ConceptMapPanel not', () => {\n    const selectedModule = ref('all')\n    // 模板中使用 v-if/v-else 互斥，这里等价表达\n    const showOverview = selectedModule.value === 'all'\n    const showConceptMap = selectedModule.value !== 'all'\n    expect(showOverview).toBe(true)\n    expect(showConceptMap).toBe(false)\n  })\n\n  it('selectedModule=M1 → ConceptMapPanel branch, ModuleOverviewPanel not', () => {\n    const selectedModule = ref('M1')\n    const showOverview = selectedModule.value === 'all'\n    const showConceptMap = selectedModule.value !== 'all'\n    expect(showOverview).toBe(false)\n    expect(showConceptMap).toBe(true)\n  })\n\n  it('handleBackToOverview resets selectedModule to all and calls loadAllModulesQuality (canEdit=true)', async () => {\n    const selectedModule = ref('M1')\n    const canEdit = ref(true)\n    const loadGraph = vi.fn().mockResolvedValue()\n    const loadAllModulesQuality = vi.fn().mockResolvedValue()\n\n    async function handleBackToOverview() {\n      selectedModule.value = 'all'\n      await loadGraph('all')\n      if (canEdit.value) {\n        await loadAllModulesQuality()\n      }\n    }\n\n    await handleBackToOverview()\n    expect(selectedModule.value).toBe('all')\n    expect(loadGraph).toHaveBeenCalledWith('all')\n    expect(loadAllModulesQuality).toHaveBeenCalledTimes(1)\n  })\n\n  it('handleBackToOverview skips loadAllModulesQuality when canEdit=false', async () => {\n    const selectedModule = ref('M1')\n    const canEdit = ref(false)\n    const loadGraph = vi.fn().mockResolvedValue()\n    const loadAllModulesQuality = vi.fn().mockResolvedValue()\n\n    async function handleBackToOverview() {\n      selectedModule.value = 'all'\n      await loadGraph('all')\n      if (canEdit.value) {\n        await loadAllModulesQuality()\n      }\n    }\n\n    await handleBackToOverview()\n    expect(selectedModule.value).toBe('all')\n    expect(loadAllModulesQuality).not.toHaveBeenCalled()\n  })\n\n  it('handleModuleSelect switches to Mx → calls loadQuality(Mx), not loadAllModulesQuality', async () => {\n    const showCards = ref(true)\n    const selectedModule = ref('all')\n    const canEdit = ref(true)\n    const loadGraph = vi.fn().mockResolvedValue()\n    const loadQuality = vi.fn().mockResolvedValue()\n    const loadAllModulesQuality = vi.fn().mockResolvedValue()\n\n    async function handleModuleSelect(mod) {\n      showCards.value = false\n      selectedModule.value = mod\n      await loadGraph(mod)\n      if (canEdit.value && mod !== 'all') {\n        await loadQuality(mod)\n      }\n      if (canEdit.value && mod === 'all') {\n        await loadAllModulesQuality()\n      }\n    }\n\n    await handleModuleSelect('M1')\n    expect(showCards.value).toBe(false)\n    expect(selectedModule.value).toBe('M1')\n    expect(loadGraph).toHaveBeenCalledWith('M1')\n    expect(loadQuality).toHaveBeenCalledWith('M1')\n    expect(loadAllModulesQuality).not.toHaveBeenCalled()\n  })\n\n  it('handleModuleSelect(all) calls loadAllModulesQuality not loadQuality', async () => {\n    const showCards = ref(true)\n    const selectedModule = ref('M1')\n    const canEdit = ref(true)\n    const loadGraph = vi.fn().mockResolvedValue()\n    const loadQuality = vi.fn().mockResolvedValue()\n    const loadAllModulesQuality = vi.fn().mockResolvedValue()\n\n    async function handleModuleSelect(mod) {\n      showCards.value = false\n      selectedModule.value = mod\n      await loadGraph(mod)\n      if (canEdit.value && mod !== 'all') {\n        await loadQuality(mod)\n      }\n      if (canEdit.value && mod === 'all') {\n        await loadAllModulesQuality()\n      }\n    }\n\n    await handleModuleSelect('all')\n    expect(loadQuality).not.toHaveBeenCalled()\n    expect(loadAllModulesQuality).toHaveBeenCalledTimes(1)\n  })\n\n  it('init sets showCards=false for teacher (needsStudentSelector=true, studentId=null)', async () => {\n    const showCards = ref(true)\n    const studentId = ref(null)\n    const needsStudentSelector = ref(true)\n    const canEdit = ref(true)\n    const loadGraph = vi.fn().mockResolvedValue()\n    const loadQuality = vi.fn().mockResolvedValue()\n    const loadAllModulesQuality = vi.fn().mockResolvedValue()\n    const loadMastery = vi.fn().mockResolvedValue()\n    const selectedModule = ref('all')\n\n    async function init() {\n      await loadGraph()\n      if (canEdit.value) {\n        await loadQuality(selectedModule.value)\n        await loadAllModulesQuality()\n      }\n      if (studentId.value) {\n        await loadMastery(studentId.value)\n      }\n      if (!studentId.value && needsStudentSelector.value) {\n        showCards.value = false\n      }\n    }\n\n    await init()\n    expect(showCards.value).toBe(false)\n    expect(loadAllModulesQuality).toHaveBeenCalledTimes(1)\n    expect(loadMastery).not.toHaveBeenCalled()\n  })\n\n  it('handleMarkReviewed dispatches set_review_status op via handleEdit', async () => {\n    const editCalls = []\n    async function handleEdit(operations) {\n      editCalls.push(operations)\n    }\n    async function handleMarkReviewed(concept) {\n      await handleEdit([{ op: 'set_review_status', id: concept.id, status: 'teacher_reviewed' }])\n    }\n\n    await handleMarkReviewed({ id: 'node-A', name: '蛋白质' })\n    expect(editCalls).toHaveLength(1)\n    expect(editCalls[0]).toEqual([\n      { op: 'set_review_status', id: 'node-A', status: 'teacher_reviewed' },\n    ])\n  })\n})\n"
  }
}
