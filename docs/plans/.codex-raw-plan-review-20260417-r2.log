   167	
   168	    school, cls, student = school_class_student
   169	    # 关键修复：operator_id 必须对应真实 User（inner join 不过滤）
   170	    operator_id = homeroom_teacher.id
   171	
   172	    rec1 = ConductRecord(
   173	        student_id=student.id, class_id=cls.id, points=3,
   174	        reason="课堂表现好", date=_date(2026, 4, 10),
   175	        operator_id=operator_id, source="manual",
   176	    )
   177	    rec2 = ConductRecord(
   178	        student_id=student.id, class_id=cls.id, points=-2,
   179	        reason="迟到", date=_date(2026, 4, 11),
   180	        operator_id=operator_id, source="manual",
   181	    )
   182	    db.add_all([rec1, rec2])
   183	    await db.commit()
