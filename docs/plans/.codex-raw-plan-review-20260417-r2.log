   161	async def test_export_records_excel(client, db, homeroom_headers, school_class_student, homeroom_teacher):
   162	    """F006 R3: 导出 Excel 解包后必须含 header + N 条记录行 + 字段正确（不被 inner join 过滤）."""
   163	    from datetime import date as _date
   164	    from io import BytesIO
   165	    from openpyxl import load_workbook
