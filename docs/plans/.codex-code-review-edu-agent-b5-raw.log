import asyncio, json
from edu_cloud.ai.agent_loop import AgentLoop
from edu_cloud.ai.llm_adapter import LLMProxyAdapter, LLMResponse, TokenUsage
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_context import ToolContext, ToolResult
from edu_cloud.ai.capability_probe import LoopStrategy

async def main():
    reg = ToolRegistry()
    ctx = ToolContext(db=None, school_id='S1', user_id='U1', role='teacher')
    adapter = LLMProxyAdapter(base_url='http://test:8100', slot='primary')
    plan_json = json.dumps({'plan': [
        {'description': '先收集数据', 'tools_hint': [], 'depends_on': []},
        {'description': '再生成总结', 'tools_hint': [], 'depends_on': ['0']},
    ]}, ensure_ascii=False)
    calls = 0
    async def mock_chat(request):
        nonlocal calls
        calls += 1
        if calls == 1:
            return LLMResponse(content=plan_json, usage=TokenUsage(10,5))
        if calls == 2:
            return LLMResponse(content='任务0结果：平均分85.2', usage=TokenUsage(10,5), stop_reason='end_turn')
        return LLMResponse(content='任务1结果：生成报告完成', usage=TokenUsage(10,5), stop_reason='end_turn')
    adapter.chat = mock_chat
    loop = AgentLoop(registry=reg, adapter=adapter, strategy=LoopStrategy.for_tier(2))
    async for event in loop.run('全面分析', ctx, tool_specs=[]):
        print(json.dumps(event.to_dict(), ensure_ascii=False))
asyncio.run(main())
