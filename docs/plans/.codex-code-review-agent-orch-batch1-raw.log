"C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import asyncio
from unittest.mock import AsyncMock, MagicMock, patch

from edu_cloud.ai.supervisor import Supervisor, ClassificationResult
from edu_cloud.ai.agent_team import AgentTeam, TeamRegistry
from edu_cloud.ai.agent_spec import AgentSpec
from edu_cloud.ai.capability_probe import LoopStrategy
from edu_cloud.ai.llm_adapter import LLMResponse, TokenUsage
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_context import ToolContext, ToolResult

async def main():
    reg = ToolRegistry()
    @reg.register(name='tool1', description='t1')
    async def tool1(i: dict, ctx: ToolContext) -> ToolResult:
        return ToolResult(success=True, data='x')
    @reg.register(name='tool2', description='t2')
    async def tool2(i: dict, ctx: ToolContext) -> ToolResult:
        return ToolResult(success=True, data='y')

    parent_adapter = MagicMock()
    parent_adapter._base_url = 'http://x'
    parent_adapter._context_window = 128000
    parent_adapter.chat = AsyncMock(return_value=LLMResponse(content='summary', stop_reason='end_turn', usage=TokenUsage(input_tokens=1, output_tokens=1)))

    team_reg = TeamRegistry()
    team_reg.register(AgentTeam(name='team1', description='t', agents=[
        AgentSpec(name='a1', description='d1', tools=['tool1']),
        AgentSpec(name='a2', description='d2', tools=['tool2']),
    ]))
    supervisor = Supervisor(registry=reg, adapter=parent_adapter, strategy=LoopStrategy.for_tier(1), team_registry=team_reg)

    ctx = MagicMock(spec=ToolContext)
    ctx.db = None
    ctx.anonymizer = MagicMock()
    ctx.anonymizer.anonymize = lambda x: x
    ctx.anonymizer.deanonymize = lambda x: x

