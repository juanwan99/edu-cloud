import asyncio
from unittest.mock import AsyncMock, MagicMock, patch

from edu_cloud.ai.supervisor import Supervisor, ClassificationResult
from edu_cloud.ai.agent_team import AgentTeam, TeamRegistry
from edu_cloud.ai.agent_spec import AgentSpec
from edu_cloud.ai.capability_probe import LoopStrategy
from edu_cloud.ai.llm_adapter import LLMResponse, TokenUsage
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_context import ToolContext, ToolResult

async def main():
    reg = ToolRegistry()

    @reg.register(name='allowed_tool', description='Allowed')
    async def allowed_tool(i: dict, ctx: ToolContext) -> ToolResult:
        return ToolResult(success=True, data='allowed')

    @reg.register(name='blocked_tool', description='Blocked')
    async def blocked_tool(i: dict, ctx: ToolContext) -> ToolResult:
        return ToolResult(success=True, data='blocked')

    parent_adapter = MagicMock()
    parent_adapter._base_url = 'http://x'
    parent_adapter._context_window = 128000
    parent_adapter.chat = AsyncMock(return_value=LLMResponse(content='summary', stop_reason='end_turn', usage=TokenUsage(input_tokens=1, output_tokens=1)))

    team_reg = TeamRegistry()
    team_reg.register(AgentTeam(name='team1', description='t', agents=[AgentSpec(name='sub', description='d', tools=['blocked_tool'])]))
    supervisor = Supervisor(registry=reg, adapter=parent_adapter, strategy=LoopStrategy.for_tier(1), team_registry=team_reg)

    ctx = MagicMock(spec=ToolContext)
    ctx.db = None
    ctx.anonymizer = MagicMock()
    ctx.anonymizer.anonymize = lambda x: x
    ctx.anonymizer.deanonymize = lambda x: x

    sub_adapter = MagicMock()
    sub_adapter.close = AsyncMock()
    sub_adapter.chat = AsyncMock(return_value=LLMResponse(content='sub answer', stop_reason='end_turn', usage=TokenUsage(input_tokens=1, output_tokens=1)))
    sub_adapter.context_window_size.return_value = 128000

    with patch('edu_cloud.ai.supervisor.LLMProxyAdapter', return_value=sub_adapter):
        with patch.object(supervisor, '_classify', return_value=ClassificationResult(needs_team=True, team_name='team1')):
            allowed_specs = reg.filter_by_names(['allowed_tool'])
            events = []
            async for event in supervisor.handle(message='hi', ctx=ctx, tool_specs=allowed_specs):
                events.append(event.type)

    req = sub_adapter.chat.call_args[0][0]
    print('events', events)
    print('sub_tools', [t['function']['name'] for t in (req.tools or [])])

asyncio.run(main())
