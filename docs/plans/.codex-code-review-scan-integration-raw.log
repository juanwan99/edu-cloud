import asyncio
from pathlib import Path
from PIL import Image
import tempfile
from edu_cloud.modules.scan.pipeline_service import run_pipeline

async def main():
    with tempfile.TemporaryDirectory() as tmp:
        scan_dir = Path(tmp) / 'scans'
        out_dir = Path(tmp) / 'out'
        scan_dir.mkdir()
        Image.new('RGB', (200,150), (255,255,255)).save(scan_dir / 'stuA.png')
        calls = []
        async def save_answer(**kwargs):
            calls.append(kwargs)
        template = {
            'image_size': {'width': 200, 'height':150},
            'barcode_region': None,
            'regions': [
                {'id':'Q01','question_id':'uuid-q1','type':'subjective','rect':{'x1':0,'y1':0,'x2':10,'y2':10}},
            ],
        }
        await run_pipeline(str(scan_dir), template, str(out_dir), 'exam1', 'sub1', 'school1', save_answer_fn=save_answer)
        print(calls)

asyncio.run(main())
