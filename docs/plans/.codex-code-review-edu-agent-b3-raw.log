import asyncio
import tests.test_ai.test_tool_executor as tmod
from edu_cloud.ai.tool_executor import ToolOrchestrator

orig = ToolOrchestrator.execute

async def serial_execute(self, batches, ctx):
    results = []
    for batch in batches:
        for call in batch.calls:
            results.append(await self._executor.run_one(call, ctx))
    return results

ToolOrchestrator.execute = serial_execute
try:
