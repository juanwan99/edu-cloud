import asyncio
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_executor import ToolExecutor
from edu_cloud.ai.tool_context import ToolContext
from edu_cloud.ai.schemas import ToolCall

async def main():
    reg = ToolRegistry()
    @reg.register(name='legacy', description='legacy', is_read_only=True, sensitivity='school')
    async def legacy(x: int = 0, _db=None):
        return {'ok': True, 'x': x, 'db': _db}

    executor = ToolExecutor(reg)
    ctx = ToolContext(db='DB', school_id='S1', user_id='U1', role='admin')
    result = await executor.run_one(ToolCall(id='1', name='legacy', arguments={'x': 1}, _raw={}), ctx)
    print(type(result).__name__, getattr(result, 'success', None), getattr(result, 'error', None), getattr(result, 'data', None))

asyncio.run(main())
