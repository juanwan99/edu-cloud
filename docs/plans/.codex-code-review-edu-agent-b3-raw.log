import asyncio
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_executor import ToolOrchestrator
from edu_cloud.ai.tool_context import ToolContext, ToolResult
from edu_cloud.ai.schemas import ToolCall

class FakeDb:
    def __init__(self):
        self.busy = False
    async def use(self, label):
        if self.busy:
            raise RuntimeError(f'concurrent db use: {label}')
        self.busy = True
        try:
            await asyncio.sleep(0.05)
        finally:
            self.busy = False

async def main():
    reg = ToolRegistry()
    @reg.register(name='r1', description='r1', is_read_only=True, sensitivity='school')
    async def r1(input: dict, ctx: ToolContext) -> ToolResult:
        await ctx.db.use('r1')
        return ToolResult(success=True, data='r1')
    @reg.register(name='r2', description='r2', is_read_only=True, sensitivity='school')
    async def r2(input: dict, ctx: ToolContext) -> ToolResult:
        await ctx.db.use('r2')
        return ToolResult(success=True, data='r2')

    orch = ToolOrchestrator(reg)
    calls = [ToolCall(id='1', name='r1', arguments={}, _raw={}), ToolCall(id='2', name='r2', arguments={}, _raw={})]
    batches = orch.partition(calls)
    ctx = ToolContext(db=FakeDb(), school_id='S1', user_id='U1', role='admin')
    results = await orch.execute(batches, ctx)
    print([(r.success, r.error, r.data) for r in results])

asyncio.run(main())
