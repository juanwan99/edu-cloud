import asyncio
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_executor import ToolOrchestrator
from edu_cloud.ai.tool_context import ToolContext, ToolResult
from edu_cloud.ai.schemas import ToolCall

async def main():
    reg = ToolRegistry()
    seen = []
    for i in range(12):
        name = f'r{i}'
        @reg.register(name=name, description=name, is_read_only=True, sensitivity='school')
        async def reader(input: dict, ctx: ToolContext, idx=i) -> ToolResult:
            seen.append(idx)
            return ToolResult(success=True, data=idx)
    orch = ToolOrchestrator(reg)
    calls = [ToolCall(id=str(i), name=f'r{i}', arguments={}, _raw={}) for i in range(12)]
    results = await orch.execute(orch.partition(calls), ToolContext(db=None, school_id='S1', user_id='U1', role='admin'))
    print('result_count=', len(results), 'seen=', seen)

asyncio.run(main())
