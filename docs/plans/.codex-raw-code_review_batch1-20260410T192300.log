ys) {\n  if (keys.length > 0) {\n    const key = keys[0]\n    if (['M1', 'M2', 'M3', 'M4', 'M5'].includes(key)) {\n      emit('select-module', key)\n    } else if (!key.startsWith('BC_')) {\n      // 叶子节点（概念）点击 → 触发节点详情\n      const node = nodeMap.value[key]\n      if (node) emit('select-node', node)\n    }\n  }\n}\n</script>\n\n<style scoped>\n.tree-nav-panel {\n  height: 100%;\n  overflow-y: auto;\n  padding: 12px;\n}\n.nav-header {\n  margin-bottom: 12px;\n}\n.weak-section {\n  margin-top: 16px;\n  padding-top: 12px;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n.section-title {\n  font-size: 12px;\n  color: #888;\n  margin-bottom: 8px;\n}\n.weak-item {\n  display: flex;\n  justify-content: space-between;\n  font-size: 13px;\n  padding: 4px 0;\n}\n</style>\n\n\n---\nC:/Users/Administrator/edu-cloud/frontend/src/api/knowledgeTree.js:\nimport client from './client'\n\nexport const getGraph = (module = 'all', includeDraft = true) =>\n  client.get('/knowledge-tree/graph', { params: { module, include_draft: includeDraft } })\n\nexport const getMastery = (studentId, module = 'all') =>\n  client.get('/knowledge-tree/mastery', { params: { student_id: studentId, module } })\n\nexport const getNodeDetail = (nodeId, signal) =>\n  client.get(`/knowledge-tree/graph/${nodeId}/detail`, { signal })\n\nexport const searchConcepts = (q) =>\n  client.get('/knowledge-tree/search', { params: { q } })\n\nexport const editGraph = (operations) =>\n  client.post('/knowledge-tree/edit', { operations })\n\nexport const qualityCheck = (module = 'all') =>\n  client.get('/knowledge-tree/quality-check', { params: { module } })\n\n\n---\nC:/Users/Administrator/edu-cloud/frontend/src/components/knowledge-tree/RelationReviewPanel.vue:\n<template>\r\n  <div class=\"relation-review-panel\">\r\n    <div class=\"review-left\">\r\n      <ConceptReviewList\r\n        :nodes=\"nodes\"\r\n        :edges=\"edges\"\r\n        :quality-issues=\"qualityIssues\"\r\n        :selected-id=\"selectedConc