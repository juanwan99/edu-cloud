from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker
from edu_cloud.models.base import Base
from edu_cloud.modules.menu.models import MenuConfig

async def main():
    engine = create_async_engine('sqlite+aiosqlite:///:memory:')
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)
    Session = async_sessionmaker(engine, expire_on_commit=False)
    async with Session() as s:
        exam = MenuConfig(code='exam', name='щШЕхН╖', icon='document', sort=1, roles=['principal'], is_active=True)
        report = MenuConfig(code='report', name='хИЖцЮР', icon='data-analysis', sort=2, roles=['principal'], is_active=True)
        s.add_all([exam, report])
        await s.commit()
        rows = (await s.execute(select(MenuConfig).where(MenuConfig.parent_id.is_(None)))).scalars().all()
        print([r.code for r in rows])
    await engine.dispose()

asyncio.run(main())
