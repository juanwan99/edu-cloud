Item('auth_state', JSON.stringify({\n      roles: [{ role: 'teacher', context: {} }],\n      currentRoleIndex: 0,\n    }))\n    const router = createTestRouter()\n    // teacher -> subject_teacher -> in EXAM_ROLES\n    await router.push('/exams')\n    await router.isReady()\n    expect(router.currentRoute.value.path).toBe('/exams')\n  })\n})\n\n\n---\nC:/Users/Administrator/edu-cloud/frontend/src/layouts/AppShell.vue:\n<template>\n  <div class=\"app-shell\">\n    <AppHeader />\n    <div class=\"app-body\">\n      <AppSidebar />\n      <main class=\"app-main\">\n        <router-view />\n      </main>\n    </div>\n    <AiFloatingButton @toggle=\"aiPanelOpen = !aiPanelOpen\" />\n    <AiSlidePanel :visible=\"aiPanelOpen\" @close=\"aiPanelOpen = false\" />\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport AppHeader from '../components/shell/AppHeader.vue'\nimport AppSidebar from '../components/shell/AppSidebar.vue'\nimport AiFloatingButton from '../components/ai/AiFloatingButton.vue'\nimport AiSlidePanel from '../components/ai/AiSlidePanel.vue'\n\nconst aiPanelOpen = ref(false)\n</script>\n\n<style scoped>\n.app-shell {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n}\n\n.app-body {\n  display: flex;\n  flex: 1;\n  margin-top: 68px;\n  min-height: calc(100vh - 68px);\n}\n\n.app-main {\n  flex: 1;\n  overflow-y: auto;\n  padding: 24px;\n  background: var(--color-bg-alt);\n}\n</style>\n\n\n---\nC:/Users/Administrator/edu-cloud/frontend/src/components/shell/AppHeader.vue:\n<template>\n  <header class=\"app-header\">\n    <div class=\"app-header__left\">\n      <div class=\"app-header__brand\" @click=\"$router.push('/')\">\n        <span class=\"app-header__logo\">\n          <svg width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\">\n            <rect width=\"28\" height=\"28\" rx=\"8\" fill=\"var(--macaron-mint)\"/>\n            <path d=\"M8 10h12M8 14h8M8 18h10\" stroke=\"var(--color-primary)\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n          </svg>\n        </span>\n        <span class=\"app-header__title\">edu-cloud 智能平台</span>\n      </div>\n      <SchoolContext />\n    </div>\n\n    <div class=\"app-header__right\">\n      <!-- Search placeholder -->\n      <div class=\"app-header__search\">\n        <svg class=\"search-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <circle cx=\"7\" cy=\"7\" r=\"5\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n          <path d=\"M11 11l3 3\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n        </svg>\n        <input\n          class=\"search-input\"\n          type=\"text\"\n          placeholder=\"搜索...\"\n          disabled\n        />\n      </div>\n\n      <!-- Notification bell -->\n      <NotificationBell />\n\n      <!-- Role switcher + avatar menu -->\n      <RoleSwitcher compact />\n    </div>\n  </header>\n</template>\n\n<script setup>\nimport SchoolContext from './SchoolContext.vue'\nimport NotificationBell from './NotificationBell.vue'\nimport RoleSwitcher from './RoleSwitcher.vue'\n</script>\n\n<style scoped>\n.app-header {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 68px;\n  background: rgba(255, 255, 255, 0.92);\n  backdrop-filter: blur(12px);\n  border-bottom: 1px solid var(--color-border-light);\n  z-index: 1000;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0 24px;\n}\n\n.app-header__left {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n\n.app-header__brand {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  cursor: pointer;\n  user-select: none;\n}\n\n.app-header__logo {\n  display: flex;\n  align-items: center;\n  flex-shrink: 0;\n}\n\n.app-header__title {\n  font-size: 18px;\n  font-weight: 800;\n  color: var(--color-primary);\n  letter-spacing: -0.02em;\n  white-space: nowrap;\n}\n\n.app-header__right {\n  display: flex;\n  align-items: center;\n  gap: 12px;