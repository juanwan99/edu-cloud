      "text": "\"\"\"\r\nPreToolUse Hook (Bash): 文档同步守卫（通用版）。\r\n\r\n在 git commit 时检测暂存文件中的关键变更，如果同一 commit 未包含\r\n对应项目的 CLAUDE.md，则提醒更新文档。\r\n\r\n覆盖范围（比旧 route_doc_guard.py 大幅扩展）：\r\n1. 路由/端点变更（原 route_doc_guard 功能）\r\n2. 端口号变更\r\n3. 启动命令 / 入口文件变更\r\n4. 依赖文件变更（requirements.txt, package.json, pyproject.toml）\r\n5. 项目结构变更（新增/删除/重命名目录级文件）\r\n6. 配置文件变更（.env.example, config.py, vite.config.*）\r\n7. 设计文档提交（docs/plans/*-design.md）→ 必须同步更新项目 CLAUDE.md\r\n\r\n触发: PreToolUse on Bash commands matching `git commit`\r\n输出: decision: block（硬阻断，必须先更新文档才能 commit）\r\n性能: subprocess + 正则，<20ms\r\n\"\"\"\r\nimport json\r\nimport os\r\nimport re\r\nimport subprocess\r\nimport sys\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\nimport hook_lib  # noqa: E402\r\nimport governance_paths  # noqa: E402\r\n\r\n# ── 变更类别定义 ──\r\n\r\n# 1. 路由文件\r\nROUTE_FILE_PATTERNS = [\r\n    re.compile(r'routers/.*\\.py$'),\r\n    re.compile(r'routes/.*\\.[jt]s$'),\r\n    re.compile(r'router\\.[jt]s$'),\r\n    re.compile(r'api/.*\\.py$'),\r\n]\r\nROUTE_CHANGE_PATTERNS = [\r\n    re.compile(r'^[+-]\\s*@(?:router|app)\\.(get|post|put|delete|patch)', re.MULTILINE | re.IGNORECASE),\r\n    re.compile(r'^[+-]\\s*(?:router|app)\\.(get|post|put|delete|patch)\\s*\\(', re.MULTILINE | re.IGNORECASE),\r\n    re.compile(r'^[+-]\\s*router\\.add_api_route\\s*\\(', re.MULTILINE | re.IGNORECASE),\r\n]\r\n\r\n# 2. 端口变更模式\r\nPORT_CHANGE_PATTERN = re.compile(\r\n    r'^[+-].*(?:--port[= ]\\d+|\\.port\\s*[:=]\\s*\\d+|PORT\\s*[:=]\\s*\\d+|localhost:\\d+)',\r\n    re.MULTILINE | re.IGNORECASE\r\n)\r\n\r\n# 3. 入口/启动文件\r\nENTRY_FILE_PATTERNS = [\r\n    re.compile(r'main\\.py$'),\r\n    re.compile(r'app\\.py$'),\r\n    re.compile(r'server\\.[jt]s$'),\r\n    re.compile(r'index\\.[jt]s$'),\r\n]\r\n\r\n# 4. 依赖文件\r\nDEPENDENCY_FILES = {\r\n    'requirements.txt', 'requirements-dev.txt',\r\n    'pyproject.toml', 'setup.py', 'setup.cfg',\r\n    'package.json', 'package-lock.json',\r\n    'pnpm-lock.yaml', 'yarn.lock',\r\n}\r\n\r\n# 5. 配置文件\r\nCONFIG_FILE_PATTERNS = [\r\n    re.compile(r'\\.env\\.example$'),\r\n    re.compile(r'config\\.py$'),\r\n    re.compile(r'settings\\.py$'),\r\n    re.compile(r'vite\\.config\\.[jt]s$'),\r\n    re.compile(r'next\\.config\\.[jt]s$'),\r\n    re.compile(r'alembic\\.ini$'),\r\n    re.compile(r'docker-compose\\.ya?ml$'),\r\n    re.compile(r'Dockerfile$'),\r\n]\r\n\r\n# 6. 结构变更（新增/删除文件会改变项目结构）\r\nSTRUCTURAL_CHANGE_DIRS = {\r\n    'routers', 'routes', 'api', 'services', 'models',\r\n    'workers', 'vision', 'client', 'components', 'pages',\r\n}\r\n\r\n\r\ndef classify_file(filepath):\r\n    \"\"\"将文件分类，返回变更类别集合。\"\"\"\r\n    categories = set()\r\n    basename = os.path.basename(filepath)\r\n    normalized = filepath.replace('\\\\', '/')\r\n\r\n    # 设计文档（治理目录下 *-design.md，排除 archived/ 子目录）\r\n    if governance_paths.is_governance_path(normalized) and normalized.endswith('-design.md') and '/archived/' not in normalized:\r\n        categories.add('design')\r\n\r\n    # 路由文件\r\n    for pat in ROUTE_FILE_PATTERNS:\r\n        if pat.search(filepath):\r\n            categories.add('route')\r\n            break\r\n\r\n    # 入口文件\r\n    for pat in ENTRY_FILE_PATTERNS:\r\n        if pat.search(filepath):\r\n            categories.add('entry')\r\n            break\r\n\r\n    # 依赖文件\r\n    if basename in DEPENDENCY_FILES:\r\n        categories.add('dependency')\r\n\r\n    # 配置文件\r\n    for pat in CONFIG_FILE_PATTERNS:\r\n        if pat.search(filepath):\r\n            categories.add('config')\r\n            break\r\n\r\n    # 结构变更（目录中新增/删除 .py/.js/.ts 文件）\r\n    parts = normalized.split('/')\r\n    for part in parts:\r\n        if part in STRUCTURAL_CHANGE_DIRS:\r\n            categories.add('structure')\r\n            break\r\n\r\n    return categories\r\n\r\n\r\ndef check_diff_for_signals(diff_text):\r\n    \"\"\"检查 diff 中的关键变更信号。\"\"\"\r\n    signals = set()\r\n\r\n    # 路由定义变更\r\n    for pat in ROUTE_CHANGE_PATTERNS:\r\n        if pat.search(diff_text):\r\n            signals.add('route')\r\n            break\r\n\r\n    # 端口号变更\r\n    if PORT_CHANGE_PATTERN.search(diff_text):\r\n        signals.add('port')\r\n\r\n    # import 变更（可能影响项目结构文档）\r\n    import_change = re.search(\r\n        r'^[+-]\\s*(?:from|import)\\s+\\S+',\r\n        diff_text, re.MULTILINE\r\n    )\r\n    if import_change:\r\n        # 只关注新增 from X import 或 import X（可能表明新模块）\r\n        new_imports = re.findall(\r\n            r'^\\+\\s*(?:from\\s+(\\S+)\\s+import|import\\s+(\\S+))',\r\n            diff_text, re.MULTILINE\r\n        )\r\n        if new_imports:\r\n            signals.add('import')\r\n\r\n    return signals\r\n\r\n\r\ndef check(data, session_state, staged_info=None):\r\n    \"\"\"commit_guards 调度器入口。返回 dict 或 None。\r\n\r\n    staged_info: {\"files\": [...], \"diff\": \"...\"}\r\n    \"\"\"\r\n    command = data.get('tool_input', {}).get('command', '')\r\n    cwd = data.get('cwd', None)\r\n\r\n    if staged_info is None:\r\n        return None\r\n    staged_files = staged_info.get('files', [])\r\n    if not staged_files:\r\n        return None\r\n\r\n    # 获取新增/删除的文件（结构变更信号）\r\n    try:\r\n        result_stat = subprocess.run(\r\n            ['git', 'diff', '--cached', '--diff-filter=AD', '--name-only'],\r\n            capture_output=True, text=True, timeout=10, cwd=cwd,\r\n        )\r\n        added_deleted = result_stat.stdout.strip().split('\\n') if result_stat.stdout.strip() else []\r\n    except Exception:\r\n        added_deleted = []\r\n\r\n    # 分类所有暂存文件\r\n    all_categories = set()\r\n    categorized_files = {}\r\n    for f in staged_files:\r\n        cats = classify_file(f)\r\n        if cats:\r\n            all_categories.update(cats)\r\n            categorized_files[f] = cats\r\n\r\n    # 新增/删除文件 → 结构变更\r\n    structural_changes = []\r\n    for f in added_deleted:\r\n        if f and f.endswith(('.py', '.js', '.ts', '.vue', '.jsx', '.tsx')):\r\n            structural_changes.append(f)\r\n            all_categories.add('structure')\r\n\r\n    # 获取关键文件的 diff 检查端口/路由变更\r\n    key_files = [f for f, cats in categorized_files.items()\r\n                 if cats & {'route', 'entry', 'config'}]\r\n    diff_signals = set()\r\n    if key_files:\r\n        try:\r\n            result = subprocess.run(\r\n                ['git', 'diff', '--cached', '-U0', '--'] + key_files,\r\n                capture_output=True, text=True, timeout=10, cwd=cwd,\r\n            )\r\n            diff_signals = check_diff_for_signals(result.stdout)\r\n        except Exception:\r\n            pass\r\n\r\n    all_categories.update(diff_signals)\r\n    all_categories.discard('import')\r\n\r\n    if not all_categories:\r\n        return None\r\n\r\n    # 检查是否已包含 CLAUDE.md\r\n    has_doc_update = any(f.endswith('CLAUDE.md') for f in staged_files)\r\n    if not has_doc_update and re.search(r'git\\s+add\\s+.*CLAUDE\\.md', command):\r\n        has_doc_update = True\r\n\r\n    # 设计文档提交时：CLAUDE.md 必须包含实质性更新\r\n    if has_doc_update and 'design' in all_categories:\r\n        design_files = [f for f, cats in categorized_files.items() if 'design' in cats]\r\n        if design_files:\r\n            try:\r\n                claude_md_files = [f for f in staged_files if f.endswith('CLAUDE.md')]\r\n                result_claude_diff = subprocess.run(\r\n                    ['git', 'diff', '--cached', '-U0', '--'] + claude_md_files,\r\n                    capture_output=True, text=True, timeout=10, cwd=cwd,\r\n                )\r\n                claude_diff = result_claude_diff.stdout\r\n                has_substantive = False\r\n                for df in design_files:\r\n                    base = os.path.basename(df)\r\n                    topic = re.sub(r'^\\d{4}-\\d{2}-\\d{2}-', '', base)\r\n                    topic = re.sub(r'-design\\.md$', '', topic)\r\n                    if topic and topic in claude_diff:\r\n                        has_substantive = True\r\n                        break\r\n                    if base in claude_diff:\r\n                        has_substantive = True\r\n                        break\r\n                if not has_substantive:\r\n                    has_doc_update = False\r\n            except Exception:\r\n                pass\r\n\r\n    if has_doc_update:\r\n        return None\r\n\r\n    if all_categories == {'dependency'}:\r\n        return None\r\n\r\n    # 构建阻断消息\r\n    category_labels = {\r\n        'design': '设计文档（必须同步更新项目 CLAUDE.md）',\r\n        'route': '路由/端点定义',\r\n        'port': '端口号配置',\r\n        'entry': '入口/启动文件',\r\n        'dependency': '依赖文件',\r\n        'config': '配置文件',\r\n        'structure': '项目结构（新增/删除代码文件）',\r\n    }\r\n\r\n    detected = [category_labels.get(c, c) for c in sorted(all_categories)]\r\n    affected_files = sorted(set(\r\n        list(categorized_files.keys()) + structural_changes\r\n    ))[:8]\r\n\r\n    lines = [\r\n        \"[doc-sync-guard] ⛔ 提交被阻断：检测到关键变更但 CLAUDE.md 未同步更新。\",\r\n        f\"  变更类型: {', '.join(detected)}\",\r\n        f\"  涉及文件: {', '.join(affected_files)}\",\r\n        \"\",\r\n    ]\r\n\r\n    if 'design' in all_categories:\r\n        design_files = [f for f, cats in categorized_files.items() if 'design' in cats]\r\n        lines += [\r\n            \"检测到设计文档提交。必须同步更新项目 CLAUDE.md，从设计文档抽取核心：\",\r\n            \"  - 架构方向/系统定位变化 → 项目定位段\",\r\n            \"  - 新增模块/组件 → 项目结构段\",\r\n            \"  - 接口/端口/协议变更 → 对应段落\",\r\n            \"  - 职责边界变化 → 职责边界表\",\r\n            \"  不抄设计文档，只写结论 + 指向设计文档的引用。\",\r\n            \"\",\r\n            \"⚠️ 设计文档场景不接受空行糊弄：CLAUDE.md diff 必须包含对设计文档的引用。\",\r\n            f\"  设计文档: {', '.join(design_files)}\",\r\n        ]\r\n    else:\r\n        lines += [\r\n            \"必须先更新项目 CLAUDE.md 再提交。检查以下内容是否需要更新：\",\r\n            \"  - 启动命令\",\r\n            \"  - 端口号\",\r\n            \"  - 项目结构（新增/删除的模块、文件）\",\r\n            \"  - API 端点列表\",\r\n            \"  - 依赖关系\",\r\n            \"  - 配置说明\",\r\n        ]\r\n\r\n    lines += [\r\n        \"\",\r\n        \"更新 CLAUDE.md 后，将其加入暂存区（git add CLAUDE.md）再重新提交。\",\r\n    ]\r\n\r\n    return {\"decision\": \"block\", \"reason\": \"\\n\".join(lines)}\r\n\r\n\r\ndef main():\r\n    try:\r\n        data = json.load(sys.stdin)\r\n    except Exception:\r\n        sys.exit(0)\r\n\r\n    if data.get('tool_name') != 'Bash':\r\n        sys.exit(0)\r\n\r\n    command = data.get('tool_input', {}).get('command', '')\r\n    if not re.search(r'\\bgit\\s+commit\\b', command):\r\n        sys.exit(0)\r\n\r\n    cwd = data.get('cwd', None)\r\n\r\n    # 获取暂存文件列表\r\n    try:\r\n        result = subprocess.run(\r\n            ['git', 'diff', '--cached', '--name-only'],\r\n            capture_output=True, text=True, timeout=10, cwd=cwd,\r\n        )\r\n        staged_files = result.stdout.strip().split('\\n') if result.stdout.strip() else []\r\n    except Exception:\r\n        sys.exit(0)\r\n\r\n    staged_info = {\"files\": staged_files, \"diff\": \"\"}\r\n    session_id = data.get(\"session_id\", \"unknown\")\r\n    ss = hook_lib.SessionState(session_id)\r\n\r\n    result = check(data, ss, staged_info=staged_info)\r\n    if result and result.get(\"decision\") == \"block\":\r\n        hook_lib.block(result[\"reason\"], \"doc_sync_guard\", ss)\r\n\r\n\r\nif __name__ == '__main__':\r\n    main()\r\n"
    }
  ],
  "structuredContent": {
    "content": "\"\"\"\r\nPreToolUse Hook (Bash): 文档同步守卫（通用版）。\r\n\r\n在 git commit 时检测暂存文件中的关键变更，如果同一 commit 未包含\r\n对应项目的 CLAUDE.md，则提醒更新文档。\r\n\r\n覆盖范围（比旧 route_doc_guard.py 大幅扩展）：\r\n1. 路由/端点变更（原 route_doc_guard 功能）\r\n2. 端口号变更\r\n3. 启动命令 / 入口文件变更\r\n4. 依赖文件变更（requirements.txt, package.json, pyproject.toml）\r\n5. 项目结构变更（新增/删除/重命名目录级文件）\r\n6. 配置文件变更（.env.example, config.py, vite.config.*）\r\n7. 设计文档提交（docs/plans/*-design.md）→ 必须同步更新项目 CLAUDE.md\r\n\r\n触发: PreToolUse on Bash commands matching `git commit`\r\n输出: decision: block（硬阻断，必须先更新文档才能 commit）\r\n性能: subprocess + 正则，<20ms\r\n\"\"\"\r\nimport json\r\nimport os\r\nimport re\r\nimport subprocess\r\nimport sys\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\nimport hook_lib  # noqa: E402\r\nimport governance_paths  # noqa: E402\r\n\r\n# ── 变更类别定义 ──\r\n\r\n# 1. 路由文件\r\nROUTE_FILE_PATTERNS = [\r\n    re.compile(r'routers/.*\\.py$'),\r\n    re.compile(r'routes/.*\\.[jt]s$'),\r\n    re.compile(r'router\\.[jt]s$'),\r\n    re.compile(r'api/.*\\.py$'),\r\n]\r\nROUTE_CHANGE_PATTERNS = [\r\n    re.compile(r'^[+-]\\s*@(?:router|app)\\.(get|post|put|delete|patch)', re.MULTILINE | re.IGNORECASE),\r\n    re.compile(r'^[+-]\\s*(?:router|app)\\.(get|post|put|delete|patch)\\s*\\(', re.MULTILINE | re.IGNORECASE),\r\n    re.compile(r'^[+-]\\s*router\\.add_api_route\\s*\\(', re.MULTILINE | re.IGNORECASE),\r\n]\r\n\r\n# 2. 端口变更模式\r\nPORT_CHANGE_PATTERN = re.compile(\r\n    r'^[+-].*(?:--port[= ]\\d+|\\.port\\s*[:=]\\s*\\d+|PORT\\s*[:=]\\s*\\d+|localhost:\\d+)',\r\n    re.MULTILINE | re.IGNORECASE\r\n)\r\n\r\n# 3. 入口/启动文件\r\nENTRY_FILE_PATTERNS = [\r\n    re.compile(r'main\\.py$'),\r\n    re.compile(r'app\\.py$'),\r\n    re.compile(r'server\\.[jt]s$'),\r\n    re.compile(r'index\\.[jt]s$'),\r\n]\r\n\r\n# 4. 依赖文件\r\nDEPENDENCY_FILES = {\r\n    'requirements.txt', 'requirements-dev.txt',\r\n    'pyproject.toml', 'setup.py', 'setup.cfg',\r\n    'package.json', 'package-lock.json',\r\n    'pnpm-lock.yaml', 'yarn.lock',\r\n}\r\n\r\n# 5. 配置文件\r\nCONFIG_FILE_PATTERNS = [\r\n    re.compile(r'\\.env\\.example$'),\r\n    re.compile(r'config\\.py$'),\r\n    re.compile(r'settings\\.py$'),\r\n    re.compile(r'vite\\.config\\.[jt]s$'),\r\n    re.compile(r'next\\.config\\.[jt]s$'),\r\n    re.compile(r'alembic\\.ini$'),\r\n    re.compile(r'docker-compose\\.ya?ml$'),\r\n    re.compile(r'Dockerfile$'),\r\n]\r\n\r\n# 6. 结构变更（新增/删除文件会改变项目结构）\r\nSTRUCTURAL_CHANGE_DIRS = {\r\n    'routers', 'routes', 'api', 'services', 'models',\r\n    'workers', 'vision', 'client', 'components', 'pages',\r\n}\r\n\r\n\r\ndef classify_file(filepath):\r\n    \"\"\"将文件分类，返回变更类别集合。\"\"\"\r\n    categories = set()\r\n    basename = os.path.basename(filepath)\r\n    normalized = filepath.replace('\\\\', '/')\r\n\r\n    # 设计文档（治理目录下 *-design.md，排除 archived/ 子目录）\r\n    if governance_paths.is_governance_path(normalized) and normalized.endswith('-design.md') and '/archived/' not in normalized:\r\n        categories.add('design')\r\n\r\n    # 路由文件\r\n    for pat in ROUTE_FILE_PATTERNS:\r\n        if pat.search(filepath):\r\n            categories.add('route')\r\n            break\r\n\r\n    # 入口文件\r\n    for pat in ENTRY_FILE_PATTERNS:\r\n        if pat.search(filepath):\r\n            categories.add('entry')\r\n            break\r\n\r\n    # 依赖文件\r\n    if basename in DEPENDENCY_FILES:\r\n        categories.add('dependency')\r\n\r\n    # 配置文件\r\n    for pat in CONFIG_FILE_PATTERNS:\r\n        if pat.search(filepath):\r\n            categories.add('config')\r\n            break\r\n\r\n    # 结构变更（目录中新增/删除 .py/.js/.ts 文件）\r\n    parts = normalized.split('/')\r\n    for part in parts:\r\n        if part in STRUCTURAL_CHANGE_DIRS:\r\n            categories.add('structure')\r\n            break\r\n\r\n    return categories\r\n\r\n\r\ndef check_diff_for_signals(diff_text):\r\n    \"\"\"检查 diff 中的关键变更信号。\"\"\"\r\n    signals = set()\r\n\r\n    # 路由定义变更\r\n    for pat in ROUTE_CHANGE_PATTERNS:\r\n        if pat.search(diff_text):\r\n            signals.add('route')\r\n            break\r\n\r\n    # 端口号变更\r\n    if PORT_CHANGE_PATTERN.search(diff_text):\r\n        signals.add('port')\r\n\r\n    # import 变更（可能影响项目结构文档）\r\n    import_change = re.search(\r\n        r'^[+-]\\s*(?:from|import)\\s+\\S+',\r\n        diff_text, re.MULTILINE\r\n    )\r\n    if import_change:\r\n        # 只关注新增 from X import 或 import X（可能表明新模块）\r\n        new_imports = re.findall(\r\n            r'^\\+\\s*(?:from\\s+(\\S+)\\s+import|import\\s+(\\S+))',\r\n            diff_text, re.MULTILINE\r\n        )\r\n        if new_imports:\r\n            signals.add('import')\r\n\r\n    return signals\r\n\r\n\r\ndef check(data, session_state, staged_info=None):\r\n    \"\"\"commit_guards 调度器入口。返回 dict 或 None。\r\n\r\n    staged_info: {\"files\": [...], \"diff\": \"...\"}\r\n    \"\"\"\r\n    command = data.get('tool_input', {}).get('command', '')\r\n    cwd = data.get('cwd', None)\r\n\r\n    if staged_info is None:\r\n        return None\r\n    staged_files = staged_info.get('files', [])\r\n    if not staged_files:\r\n        return None\r\n\r\n    # 获取新增/删除的文件（结构变更信号）\r\n    try:\r\n        result_stat = subprocess.run(\r\n            ['git', 'diff', '--cached', '--diff-filter=AD', '--name-only'],\r\n            capture_output=True, text=True, timeout=10, cwd=cwd,\r\n        )\r\n        added_deleted = result_stat.stdout.strip().split('\\n') if result_stat.stdout.strip() else []\r\n    except Exception:\r\n        added_deleted = []\r\n\r\n    # 分类所有暂存文件\r\n    all_categories = set()\r\n    categorized_files = {}\r\n    for f in staged_files:\r\n        cats = classify_file(f)\r\n        if cats:\r\n            all_categories.update(cats)\r\n            categorized_files[f] = cats\r\n\r\n    # 新增/删除文件 → 结构变更\r\n    structural_changes = []\r\n    for f in added_deleted:\r\n        if f and f.endswith(('.py', '.js', '.ts', '.vue', '.jsx', '.tsx')):\r\n            structural_changes.append(f)\r\n            all_categories.add('structure')\r\n\r\n    # 获取关键文件的 diff 检查端口/路由变更\r\n    key_files = [f for f, cats in categorized_files.items()\r\n                 if cats & {'route', 'entry', 'config'}]\r\n    diff_signals = set()\r\n    if key_files:\r\n        try:\r\n            result = subprocess.run(\r\n                ['git', 'diff', '--cached', '-U0', '--'] + key_files,\r\n                capture_output=True, text=True, timeout=10, cwd=cwd,\r\n            )\r\n            diff_signals = check_diff_for_signals(result.stdout)\r\n        except Exception:\r\n            pass\r\n\r\n    all_categories.update(diff_signals)\r\n    all_categories.discard('import')\r\n\r\n    if not all_categories:\r\n        return None\r\n\r\n    # 检查是否已包含 CLAUDE.md\r\n    has_doc_update = any(f.endswith('CLAUDE.md') for f in staged_files)\r\n    if not has_doc_update and re.search(r'git\\s+add\\s+.*CLAUDE\\.md', command):\r\n        has_doc_update = True\r\n\r\n    # 设计文档提交时：CLAUDE.md 必须包含实质性更新\r\n    if has_doc_update and 'design' in all_categories:\r\n        design_files = [f for f, cats in categorized_files.items() if 'design' in cats]\r\n        if design_files:\r\n            try:\r\n                claude_md_files = [f for f in staged_files if f.endswith('CLAUDE.md')]\r\n                result_claude_diff = subprocess.run(\r\n                    ['git', 'diff', '--cached', '-U0', '--'] + claude_md_files,\r\n                    capture_output=True, text=True, timeout=10, cwd=cwd,\r\n                )\r\n                claude_diff = result_claude_diff.stdout\r\n                has_substantive = False\r\n                for df in design_files:\r\n                    base = os.path.basename(df)\r\n                    topic = re.sub(r'^\\d{4}-\\d{2}-\\d{2}-', '', base)\r\n                    topic = re.sub(r'-design\\.md$', '', topic)\r\n                    if topic and topic in claude_diff:\r\n                        has_substantive = True\r\n                        break\r\n                    if base in claude_diff:\r\n                        has_substantive = True\r\n                        break\r\n                if not has_substantive:\r\n                    has_doc_update = False\r\n            except Exception:\r\n                pass\r\n\r\n    if has_doc_update:\r\n        return None\r\n\r\n    if all_categories == {'dependency'}:\r\n        return None\r\n\r\n    # 构建阻断消息\r\n    category_labels = {\r\n        'design': '设计文档（必须同步更新项目 CLAUDE.md）',\r\n        'route': '路由/端点定义',\r\n        'port': '端口号配置',\r\n        'entry': '入口/启动文件',\r\n        'dependency': '依赖文件',\r\n        'config': '配置文件',\r\n        'structure': '项目结构（新增/删除代码文件）',\r\n    }\r\n\r\n    detected = [category_labels.get(c, c) for c in sorted(all_categories)]\r\n    affected_files = sorted(set(\r\n        list(categorized_files.keys()) + structural_changes\r\n    ))[:8]\r\n\r\n    lines = [\r\n        \"[doc-sync-guard] ⛔ 提交被阻断：检测到关键变更但 CLAUDE.md 未同步更新。\",\r\n        f\"  变更类型: {', '.join(detected)}\",\r\n        f\"  涉及文件: {', '.join(affected_files)}\",\r\n        \"\",\r\n    ]\r\n\r\n    if 'design' in all_categories:\r\n        design_files = [f for f, cats in categorized_files.items() if 'design' in cats]\r\n        lines += [\r\n            \"检测到设计文档提交。必须同步更新项目 CLAUDE.md，从设计文档抽取核心：\",\r\n            \"  - 架构方向/系统定位变化 → 项目定位段\",\r\n            \"  - 新增模块/组件 → 项目结构段\",\r\n            \"  - 接口/端口/协议变更 → 对应段落\",\r\n            \"  - 职责边界变化 → 职责边界表\",\r\n            \"  不抄设计文档，只写结论 + 指向设计文档的引用。\",\r\n            \"\",\r\n            \"⚠️ 设计文档场景不接受空行糊弄：CLAUDE.md diff 必须包含对设计文档的引用。\",\r\n            f\"  设计文档: {', '.join(design_files)}\",\r\n        ]\r\n    else:\r\n        lines += [\r\n            \"必须先更新项目 CLAUDE.md 再提交。检查以下内容是否需要更新：\",\r\n            \"  - 启动命令\",\r\n            \"  - 端口号\",\r\n            \"  - 项目结构（新增/删除的模块、文件）\",\r\n            \"  - API 端点列表\",\r\n            \"  - 依赖关系\",\r\n            \"  - 配置说明\",\r\n        ]\r\n\r\n    lines += [\r\n        \"\",\r\n        \"更新 CLAUDE.md 后，将其加入暂存区（git add CLAUDE.md）再重新提交。\",\r\n    ]\r\n\r\n    return {\"decision\": \"block\", \"reason\": \"\\n\".join(lines)}\r\n\r\n\r\ndef main():\r\n    try:\r\n        data = json.load(sys.stdin)\r\n    except Exception:\r\n        sys.exit(0)\r\n\r\n    if data.get('tool_name') != 'Bash':\r\n        sys.exit(0)\r\n\r\n    command = data.get('tool_input', {}).get('command', '')\r\n    if not re.search(r'\\bgit\\s+commit\\b', command):\r\n        sys.exit(0)\r\n\r\n    cwd = data.get('cwd', None)\r\n\r\n    # 获取暂存文件列表\r\n    try:\r\n        result = subprocess.run(\r\n            ['git', 'diff', '--cached', '--name-only'],\r\n            capture_output=True, text=True, timeout=10, cwd=cwd,\r\n        )\r\n        staged_files = result.stdout.strip().split('\\n') if result.stdout.strip() else []\r\n    except Exception:\r\n        sys.exit(0)\r\n\r\n    staged_info = {\"files\": staged_files, \"diff\": \"\"}\r\n    session_id = data.get(\"session_id\", \"unknown\")\r\n    ss = hook_lib.SessionState(session_id)\r\n\r\n    result = check(data, ss, staged_info=staged_info)\r\n    if result and result.get(\"decision\") == \"block\":\r\n        hook_lib.block(result[\"reason\"], \"doc_sync_guard\", ss)\r\n\r\n\r\nif __name__ == '__main__':\r\n    main()\r\n"
  }
