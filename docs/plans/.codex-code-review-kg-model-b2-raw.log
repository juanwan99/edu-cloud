      "text": "<template>\n  <div class=\"graph-panel\">\n    <div class=\"toolbar\">\n      <n-button-group size=\"small\">\n        <n-button @click=\"zoomIn\">+</n-button>\n        <n-button @click=\"zoomOut\">-</n-button>\n        <n-button @click=\"fitView\">居中</n-button>\n      </n-button-group>\n      <n-button size=\"small\" quaternary @click=\"toggleLayout\">\n        {{ layoutType === 'force' ? '径向布局' : '力导向' }}\n      </n-button>\n    </div>\n    <div ref=\"containerRef\" class=\"graph-container\" />\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, onUnmounted, watch, nextTick } from 'vue'\nimport { NButton, NButtonGroup } from 'naive-ui'\nimport { Graph } from '@antv/g6'\n\nconst props = defineProps({\n  nodes: { type: Array, default: () => [] },\n  edges: { type: Array, default: () => [] },\n  selectedModule: { type: String, default: 'all' },\n})\nconst emit = defineEmits(['node-click'])\n\nconst containerRef = ref(null)\nconst layoutType = ref('force')\nlet graph = null\n\n// 掌握度着色（学生模式：选了学生时）\nconst STATE_COLORS = {\n  solid: '#22c55e',\n  fragile: '#eab308',\n  weak: '#ef4444',\n  unseen: '#94a3b8',\n}\n\n// 审核状态着色（教师模式：未选学生时）\nconst REVIEW_COLORS = {\n  ai_draft: '#64748b',\n  teacher_reviewed: '#3b82f6',\n  published: '#22c55e',\n}\n\n// 模块色板 — 提供分组视觉辨识\nconst MODULE_COLORS = {\n  M1: '#6366f1',  // indigo\n  M2: '#8b5cf6',  // violet\n  M3: '#ec4899',  // pink\n  M4: '#f97316',  // orange\n  M5: '#14b8a6',  // teal\n}\n\n// 判断是否有掌握度数据（= 学生模式）\nfunction hasStudentData(nodes) {\n  return nodes.some(n => n.data.mastery_state && n.data.mastery_state !== 'unseen')\n}\n\n// 节点填充色：学生模式→掌握度，教师模式→模块色\nfunction nodeFill(d, studentMode) {\n  if (studentMode) return STATE_COLORS[d.data.mastery_state] || STATE_COLORS.unseen\n  return MODULE_COLORS[d.data.module] || '#64748b'\n}\n\n// 节点描边：审核状态（教师模式可见）\nfunction nodeStroke(d, studentMode) {\n  if (studentMode) return 'rgba(255,255,255,0.3)'\n  const rs = d.data.review_status\n  if (rs === 'published') return '#22c55e'\n  if (rs === 'teacher_reviewed') return '#3b82f6'\n  return 'rgba(255,255,255,0.15)'\n}\n\n// 节点尺寸：基础 24px，教师模式按 difficulty 微调\nfunction nodeSize(d) {\n  const base = 24\n  const diff = d.data.difficulty ?? 3\n  return base + (diff - 1) * 3  // 24-36px\n}\n\nconst EDGE_STYLES = {\n  prerequisite_hard: { stroke: 'rgba(100,116,139,0.5)', lineDash: [0], endArrow: true },\n  bridge_to: { stroke: 'rgba(99,102,241,0.45)', lineDash: [4, 3], endArrow: false },\n  contrast: { stroke: 'rgba(234,179,8,0.45)', lineDash: [2, 2], endArrow: false },\n}\n\nfunction buildGraphData() {\n  const nodes = props.nodes.map(n => ({\n    id: n.id,\n    data: {\n      label: n.name.length > 8 ? n.name.slice(0, 8) + '…' : n.name,\n      fullName: n.name,\n      level: n.level,\n      module: n.module,\n      mastery: n.mastery ?? 0,\n      mastery_state: n.mastery_state ?? 'unseen',\n      da_count: n.da_count ?? 0,\n      review_status: n.review_status,\n      difficulty: n.difficulty,\n      bloom_level: n.bloom_level,\n    },\n  }))\n  const edges = props.edges.map((e, i) => ({\n    id: `edge-${i}`,\n    source: e.source,\n    target: e.target,\n    data: { type: e.type, strength: e.strength },\n  }))\n  return { nodes, edges }\n}\n\nfunction createGraph() {\n  if (!containerRef.value) return\n\n  const data = buildGraphData()\n\n  // 力导向参数适配 ~35 节点/模块（从 1200 节点下调）\n  const nodeCount = data.nodes.length\n  const forceConfig = {\n    type: 'force',\n    animated: true,\n    clustering: true,\n    nodeClusterBy: 'module',\n    nodeStrength: nodeCount < 50 ? -120 : -200,\n    linkDistance: nodeCount < 50 ? 100 : 150,\n  }\n\n  const studentMode = hasStudentData(data.nodes)\n\n  graph = new Graph({\n    container: containerRef.value,\n    data,\n    autoFit: 'view',\n    layout: layoutType.value === 'force' ? forceConfig : { type: 'radial', animated: true },\n    node: {\n      style: {\n        size: d => nodeSize(d),\n        fill: d => nodeFill(d, studentMode),\n        stroke: d => nodeStroke(d, studentMode),\n        lineWidth: d => (d.data.review_status === 'published' || d.data.review_status === 'teacher_reviewed') ? 2.5 : 1,\n        fillOpacity: 0.85,\n        labelText: d => d.data.label,\n        labelFill: '#1e293b',\n        labelFontSize: 11,\n        labelFontWeight: 500,\n        labelPlacement: 'bottom',\n        labelOffsetY: 4,\n        labelBackgroundFill: 'rgba(255,255,255,0.75)',\n        labelBackgroundRadius: 3,\n        labelPadding: [1, 4],\n      },\n    },\n    edge: {\n      style: d => {\n        const style = EDGE_STYLES[d.data.type] || EDGE_STYLES.prerequisite_hard\n        return {\n          stroke: style.stroke,\n          lineDash: style.lineDash,\n          endArrow: style.endArrow,\n          lineWidth: 1.5,\n        }\n      },\n    },\n    behaviors: ['drag-canvas', 'zoom-canvas', 'drag-element', 'click-select'],\n  })\n\n  graph.on('node:click', (evt) => {\n    const nodeData = evt.itemData || evt.target?.id\n    if (nodeData) {\n      const node = props.nodes.find(n => n.id === (nodeData.id || nodeData))\n      if (node) emit('node-click', node)\n    }\n  })\n\n  graph.render()\n}\n\nfunction destroyGraph() {\n  if (graph) {\n    graph.destroy()\n    graph = null\n  }\n}\n\nfunction zoomIn() { graph?.zoom(1.2) }\nfunction zoomOut() { graph?.zoom(0.8) }\nfunction fitView() { graph?.fitView() }\n\nfunction toggleLayout() {\n  layoutType.value = layoutType.value === 'force' ? 'radial' : 'force'\n  destroyGraph()\n  nextTick(createGraph)\n}\n\nwatch(() => [props.nodes, props.edges, props.selectedModule], () => {\n  destroyGraph()\n  nextTick(createGraph)\n}, { deep: true })\n\nonMounted(() => nextTick(createGraph))\nonUnmounted(destroyGraph)\n</script>\n\n<style scoped>\n.graph-panel {\n  position: relative;\n  width: 100%;\n  height: 100%;\n}\n.toolbar {\n  position: absolute;\n  top: 8px;\n  right: 8px;\n  z-index: 10;\n  display: flex;\n  gap: 8px;\n}\n.graph-container {\n  width: 100%;\