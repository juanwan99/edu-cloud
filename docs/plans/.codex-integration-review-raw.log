rror.value = e.message\r\n    } finally {\r\n      isLoading.value = false\r\n    }\r\n  }\r\n\r\n  function clearChat() {\r\n    messages.value = []\r\n    sessionId.value = null\r\n    error.value = null\r\n  }\r\n\r\n  return {\r\n    messages,\r\n    isLoading,\r\n    isAvailable,\r\n    sessionId,\r\n    error,\r\n    checkHealth,\r\n    sendMessage,\r\n    clearChat,\r\n  }\r\n})\r\n\n"
