import ast, pathlib, json
root = pathlib.Path('C:/Users/Administrator/edu-cloud/src/edu_cloud')
files = list(root.rglob('*.py'))
mods = {}
for p in files:
    mod = 'edu_cloud.' + '.'.join(p.relative_to(root).with_suffix('').parts)
    mods[mod] = p
edges = {m:set() for m in mods}
for mod,p in mods.items():
    try:
        tree = ast.parse(p.read_text(encoding='utf-8'))
    except Exception:
        continue
    for n in ast.walk(tree):
        if isinstance(n, ast.Import):
            for a in n.names:
                name = a.name
                if name in mods:
                    edges[mod].add(name)
        elif isinstance(n, ast.ImportFrom):
            if n.level:
                base = mod.split('.')[:-n.level]
                if n.module:
                    target = '.'.join(base + n.module.split('.'))
                else:
                    target = '.'.join(base)
            else:
                target = n.module or ''
            if target in mods:
                edges[mod].add(target)
cycles=[]
seen=set()
path=[]
stack=set()
visited=set()
def dfs(m):
    visited.add(m); stack.add(m); path.append(m)
    for nxt in edges[m]:
        if nxt not in visited:
            dfs(nxt)
        elif nxt in stack:
            i = path.index(nxt)
            cyc = tuple(path[i:]+[nxt])
            key = tuple(sorted(set(cyc)))
            if key not in seen:
                seen.add(key); cycles.append(cyc)
    path.pop(); stack.remove(m)
for m in mods:
    if m not in visited:
        dfs(m)
print(json.dumps({'cycle_count': len(cycles), 'cycles': cycles[:30]}, ensure_ascii=False, indent=2))
