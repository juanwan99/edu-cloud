    74	})
    75	
    76	async function loadConfig() {
    77	  try {
    78	    const data = await api.getScoreSegments()
    79	    defaultBoundaries.value = data.default?.boundaries ?? [85, 70, 60]
    80	    defaultLabels.value = data.default?.labels ?? ['优秀', '良好', '及格', '不及格']
    81	    overrides.value = data.overrides ?? []
    82	  } catch {
    83	    // use defaults
    84	  }
    85	}
    86	
    87	async function saveDefault() {
    88	  await api.upsertSegmentsConfig({
    89	    boundaries: defaultBoundaries.value,
    90	    labels: defaultLabels.value,
    91	  })
    92	  ElMessage.success('默认配置已保存')
    93	}
    94	
    95	async function deleteOverride(subjectCode: string) {
    96	  await api.deleteSegmentOverride(subjectCode)
    97	  overrides.value = overrides.value.filter(o => o.subject_code !== subjectCode)
    98	  ElMessage.success('已删除')
    99	}
   100	
   101	async function addOverride() {
   102	  const boundaries = newOverride.boundariesStr.split(',').map(Number)
   103	  const labels = newOverride.labelsStr.split(',').map(s => s.trim())
   104	  await api.upsertSegmentsConfig({
   105	    subject_code: newOverride.subject_code,
   106	    boundaries,
   107	    labels,
   108	  })
   109	  showAddOverride.value = false
   110	  await loadConfig()
   111	  ElMessage.success('已添加')
   112	}
   113	
   114	onMounted(loadConfig)
   115	</script>
