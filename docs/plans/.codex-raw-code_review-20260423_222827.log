   203	    visible_class_ids: list[str] | None = None,
   204	) -> dict:
   205	    await _verify_exam(db, exam_id, school_id)
   206	    subjects = await _get_subjects(db, exam_id, school_id, visible_subject_codes, subject_id)
   207	
   208	    # 设计意图：年级统计基于全校样本（不用 visible_class_ids 缩分母），
   209	    # visible_class_ids 仅用于标记 my_class=true。与 exam-ai 原始行为一致。
