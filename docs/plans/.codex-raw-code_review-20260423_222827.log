   257	        is_my_class = visible_class_ids is not None and cid in visible_class_ids
   258	        class_entries.append({
   259	            "class_id": cid, "class_name": class_names.get(cid, ""),
   260	            "avg_score": avg, "student_count": count, "my_class": is_my_class,

