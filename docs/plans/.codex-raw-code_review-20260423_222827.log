    10	async def convert_level_score(
    11	    db: AsyncSession,
    12	    school_id: str,
    13	    exam_id: str,
    14	    subject_id: str,
    15	    levels: list[dict],
    16	    class_id: str | None = None,
    17	) -> dict | None:
    18	    # Use StudentAnswer to get per-subject scores (not ExamResult.total_score which is all-subject total)
    19	    stmt = (
    20	        select(
    21	            Student.id.label("student_id"),
    22	            Student.name,
    23	            func.sum(StudentAnswer.score).label("total_score"),
    24	        )
    25	        .join(StudentAnswer, StudentAnswer.student_id == Student.id)
    26	        .where(StudentAnswer.exam_id == exam_id)
    27	        .where(StudentAnswer.subject_id == subject_id)
    28	        .where(StudentAnswer.school_id == school_id)
    29	        .where(StudentAnswer.score.is_not(None))
    30	        .group_by(Student.id, Student.name)
    31	        .order_by(func.sum(StudentAnswer.score).desc())
    32	    )
    33	    if class_id:
    34	        stmt = stmt.where(Student.class_id == class_id)
    35	
    36	    rows = (await db.execute(stmt)).all()
    37	    if not rows:
    38	        return None
    39	
    40	    total = len(rows)
    41	    sorted_levels = sorted(levels, key=lambda lv: lv["start_pct"])
    42	
    43	    students_out = []
    44	    level_buckets: dict[str, list] = {lv["level"]: [] for lv in sorted_levels}
    45	
    46	    # ORC-005: tied scores must be in same level — group by score, use same percentile
    47	    score_groups = []
    48	    current_score = None
    49	    for rank_idx, row in enumerate(rows):
    50	        if row.total_score != current_score:
    51	            current_score = row.total_score
    52	            score_groups.append({"score": current_score, "start_idx": rank_idx, "students": []})
    53	        score_groups[-1]["students"].append(row)
    54	
    55	    for group in score_groups:
    56	        pct = (group["start_idx"] / total) * 100
    57	        assigned_level = sorted_levels[-1]
    58	        for lv in sorted_levels:
    59	            if lv["start_pct"] <= pct < lv["end_pct"]:
    60	                assigned_level = lv
    61	                break
    62	
    63	        for row in group["students"]:
    64	            entry = {
    65	                "student_id": row.student_id,
    66	                "name": row.name,
    67	                "raw_score": row.total_score,
    68	                "level": assigned_level["level"],
    69	                "rank": group["start_idx"] + 1,
    70	                "assigned_score": 0.0,
    71	            }
    72	            level_buckets[assigned_level["level"]].append(entry)
    73	            students_out.append(entry)
    74	
    75	    for lv in sorted_levels:
    76	        bucket = level_buckets[lv["level"]]
    77	        n = len(bucket)
    78	        for i, stu in enumerate(bucket):
    79	            if n <= 1:
    80	                stu["assigned_score"] = round((lv["score_min"] + lv["score_max"]) / 2, 1)
    81	            else:
    82	                stu["assigned_score"] = round(
    83	                    lv["score_max"] - (lv["score_max"] - lv["score_min"]) * i / (n - 1), 1
    84	                )
    85	
    86	    level_stats = []
    87	    for lv in sorted_levels:
    88	        bucket = level_buckets[lv["level"]]
    89	        raw_scores = [s["raw_score"] for s in bucket]
    90	        count = len(bucket)
    91	        level_stats.append({
    92	            "level": lv["level"],
    93	            "count": count,
    94	            "pct": round(count / total * 100, 1) if total else 0,
    95	            "raw_min": min(raw_scores) if raw_scores else None,
    96	            "raw_max": max(raw_scores) if raw_scores else None,
    97	            "assigned_range": [lv["score_min"], lv["score_max"]],
    98	        })
    99	
   100	    def _build_dist(score_list, bins=10):
   101	        if not score_list:
   102	            return {"segments": [], "counts": []}
   103	        lo, hi = min(score_list), max(score_list)
   104	        step = max((hi - lo) / bins, 1)
   105	        segments, counts = [], []
   106	        for i in range(bins):
   107	            seg_lo = lo + step * i
   108	            seg_hi = lo + step * (i + 1)
   109	            segments.append(f"{seg_lo:.0f}-{seg_hi:.0f}")
   110	            if i == bins - 1:
   111	                cnt = sum(1 for s in score_list if seg_lo <= s <= seg_hi)
   112	            else:
   113	                cnt = sum(1 for s in score_list if seg_lo <= s < seg_hi)
   114	            counts.append(cnt)
   115	        return {"segments": segments, "counts": counts}
   116	
   117	    return {
   118	        "total_students": total,
   119	        "level_stats": level_stats,
   120	        "students": students_out,
   121	        "distribution_before": _build_dist([r.total_score for r in rows]),
   122	        "distribution_after": _build_dist([s["assigned_score"] for s in students_out]),
   123	    }

