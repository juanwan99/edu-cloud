    63	def _build_tree(rows) -> dict:
    64	    grade_map: dict[str, dict] = {}
    65	
    66	    for row in rows:
    67	        grade_name = row.grade
    68	        if grade_name not in grade_map:
    69	            grade_map[grade_name] = {}
    70	
    71	        class_id = row.class_id
    72	        if class_id not in grade_map[grade_name]:
    73	            grade_map[grade_name][class_id] = {
    74	                "id": class_id,
    75	                "name": row.class_name,
    76	                "subjects": {},
    77	            }
    78	
    79	        cls = grade_map[grade_name][class_id]
    80	        subj_id = row.subject_id
    81	        if subj_id not in cls["subjects"]:
    82	            cls["subjects"][subj_id] = {
    83	                "id": subj_id,
    84	                "code": row.subject_code,
    85	                "name": row.subject_name,
    86	                "exams": [],
    87	            }
    88	
    89	        cls["subjects"][subj_id]["exams"].append({
    90	            "exam_id": row.exam_id,
    91	            "subject_id": subj_id,
    92	            "name": row.exam_name,
    93	            "exam_date": row.exam_date.isoformat() if row.exam_date else None,
    94	            "student_count": row.student_count,
    95	        })
    96	
    97	    grades = []
    98	    for grade_name, classes_map in grade_map.items():
    99	        real_classes = list(classes_map.values())
   100	
   101	        all_subjects: dict[str, dict] = {}
   102	        for cls in real_classes:
   103	            for subj_id, subj in cls["subjects"].items():
   104	                if subj_id not in all_subjects:
   105	                    all_subjects[subj_id] = {
   106	                        "id": subj["id"],
   107	                        "code": subj["code"],
   108	                        "name": subj["name"],
   109	                        "exams": defaultdict(lambda: {"student_count": 0}),
   110	                    }
   111	                for exam in subj["exams"]:
   112	                    key = exam["exam_id"]
   113	                    entry = all_subjects[subj_id]["exams"][key]
   114	                    entry["exam_id"] = exam["exam_id"]
   115	                    entry["subject_id"] = exam["subject_id"]
   116	                    entry["name"] = exam["name"]
   117	                    entry["exam_date"] = exam["exam_date"]
   118	                    entry["student_count"] += exam["student_count"]
   119	
   120	        all_node = {
   121	            "id": "all",
   122	            "name": "全部班级",
   123	            "subjects": {
   124	                sid: {
   125	                    "id": s["id"],
   126	                    "code": s["code"],
   127	                    "name": s["name"],
   128	                    "exams": list(s["exams"].values()),
   129	                }
   130	                for sid, s in all_subjects.items()
   131	            },
   132	        }
   133	
   134	        for cls in real_classes:
   135	            cls["subjects"] = list(cls["subjects"].values())
   136	        all_node["subjects"] = list(all_node["subjects"].values())
   137	
   138	        grades.append({
   139	            "name": grade_name,
   140	            "classes": [all_node] + real_classes,
   141	        })
   142	
   143	    return {"grades": grades}

