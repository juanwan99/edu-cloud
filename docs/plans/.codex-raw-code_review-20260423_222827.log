    90	@pytest.mark.asyncio
    91	async def test_level_score_basic(client, school_admin_headers, seed_school, db):
    92	    """10 students, 4 levels: verify division and assigned scores."""
    93	    data = await _seed_level_score_data(db, seed_school)
    94	
    95	    resp = await client.post(
    96	        "/api/v1/analytics/level-score/convert",
    97	        json={
    98	            "exam_id": data["exam"].id,
    99	            "subject_id": data["subj"].id,
   100	            "class_id": None,
   101	            "levels": DEFAULT_LEVELS,
   102	        },
   103	        headers=school_admin_headers,
   104	    )
   105	    assert resp.status_code == 200
   106	    result = resp.json()
   107	    assert result["total_students"] == 10
   108	    assert len(result["level_stats"]) == 4
   109	    assert len(result["students"]) == 10
   110	
   111	    # ORC-005: sorted by raw_score descending
   112	    scores = [s["raw_score"] for s in result["students"]]
   113	    assert scores == sorted(scores, reverse=True)
   114	
   115	    # A level should contain top 20% = 2 students
   116	    a_stat = next(s for s in result["level_stats"] if s["level"] == "A")
   117	    assert a_stat["count"] == 2
