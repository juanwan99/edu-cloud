   213	        for s in scores:
   214	            student_scores[s["student_id"]] = student_scores.get(s["student_id"], 0.0) + s["effective_score"]
   215	
   216	    student_ids = list(student_scores.keys())
   217	    student_class_map: dict[str, str] = {}
