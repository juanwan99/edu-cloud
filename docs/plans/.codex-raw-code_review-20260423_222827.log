    24	<script setup lang="ts">
    25	const filterRef = ref()
    26	const po = computed(() => filterRef.value?.po)
    27	const api = useApi()
    28	
    29	const loading = ref(false)
    30	const tableData = ref<any[]>([])
    31	
    32	const allColumns = [
    33	  { prop: 'rank', label: '排名' },
    34	  { prop: 'name', label: '姓名' },
    35	  { prop: 'student_number', label: '学号' },
    36	  { prop: 'class_name', label: '班级' },
    37	  { prop: 'total_score', label: '总分' },
    38	]
    39	const visibleColumns = ref([...allColumns])
    40	
    41	watch(() => po.value?.analysisParams?.value, async (params) => {
    42	  if (!params?.exam_id) return
    43	  loading.value = true
    44	  try {
    45	    const result = await api.queryReport({
    46	      exam_ids: [params.exam_id],
    47	      metrics: ['ranking'],
    48	      class_ids: params.class_id ? [params.class_id] : undefined,
    49	    })
    50	    const ranking = result.metrics?.ranking ?? result.ranking ?? {}
    51	    tableData.value = ranking.students ?? []
    52	  } finally {
    53	    loading.value = false
    54	  }
    55	}, { deep: true })
    56	
    57	function exportCsv() {
    58	  if (!tableData.value.length) return
    59	  const headers = visibleColumns.value.map(c => c.label)
    60	  const rows = tableData.value.map(row =>
    61	    visibleColumns.value.map(c => row[c.prop] ?? '')
    62	  )
    63	  const csv = [headers, ...rows].map(r => r.join(',')).join('\n')
    64	  const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8' })
    65	  const url = URL.createObjectURL(blob)
    66	  const a = document.createElement('a')
    67	  a.href = url
    68	  a.download = '成绩表.csv'
    69	  a.click()
    70	  URL.revokeObjectURL(url)
    71	}
    72	</script>
