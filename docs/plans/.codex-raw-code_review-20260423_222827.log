   135	@pytest.mark.asyncio
   136	async def test_level_score_tied_scores(client, school_admin_headers, seed_school, db):
   137	    """ORC-005: students with same score must be in the same level."""
   138	    school, _ = seed_school
   139	    school_id = school.id
   140	    cls = Class(name="高一(1)班", grade="高一", school_id=school_id)
   141	    db.add(cls)
   142	    await db.flush()
   143	
   144	    exam = Exam(name="并列分测试", status="completed", school_id=school_id,
   145	                exam_date=datetime(2026, 6, 20))
   146	    db.add(exam)
   147	    await db.flush()
   148	
   149	    subj = Subject(exam_id=exam.id, name="数学", code="math", school_id=school_id)
   150	    db.add(subj)
   151	    await db.flush()
   152	
   153	    question = Question(
   154	        subject_id=subj.id, school_id=school_id,
   155	        name="T1", question_type="objective", max_score=100,
   156	    )
   157	    db.add(question)
   158	    await db.flush()
   159	
   160	    # 5 students, scores 100, 95, 95, 80, 70
   161	    raw_scores = [100, 95, 95, 80, 70]
   162	    students = []
   163	    for i, sc in enumerate(raw_scores):
   164	        stu = Student(name=f"并列{i}", student_number=f"T{i:03d}",
   165	                      class_id=cls.id, grade="高一", school_id=school_id)
   166	        db.add(stu)
   167	        students.append((stu, sc))
   168	    await db.flush()
   169	
   170	    for stu, sc in students:
   171	        db.add(ExamResult(exam_id=exam.id, student_id=stu.id,
   172	                          school_id=school_id, total_score=sc))
   173	        db.add(StudentAnswer(exam_id=exam.id, student_id=stu.id,
   174	                             subject_id=subj.id, question_id=question.id,
   175	                             school_id=school_id, score=sc))
   176	    await db.commit()
   177	
   178	    # Top 40% = A (2 students), 2nd/3rd same score 95 should be same level
   179	    levels = [
   180	        {"level": "A", "start_pct": 0, "end_pct": 40, "score_min": 86, "score_max": 100},
   181	        {"level": "B", "start_pct": 40, "end_pct": 100, "score_min": 41, "score_max": 85},
   182	    ]
   183	    resp = await client.post(
   184	        "/api/v1/analytics/level-score/convert",
   185	        json={"exam_id": exam.id, "subject_id": subj.id, "levels": levels},
   186	        headers=school_admin_headers,
   187	    )
   188	    result = resp.json()
   189	    tied = [s for s in result["students"] if s["raw_score"] == 95]
   190	    assert len(tied) == 2
   191	    assert tied[0]["level"] == tied[1]["level"], "ORC-005: tied students must be in same level"

