     1	export interface ExamNode {
     2	  exam_id: string
     3	  subject_id: string
     4	  name: string
     5	  exam_date: string | null
     6	  student_count: number
     7	}
     8	
     9	export interface SubjectNode {
    10	  id: string
    11	  code: string
    12	  name: string
    13	  exams: ExamNode[]
    14	}
    15	
    16	export interface ClassNode {
    17	  id: string
    18	  name: string
    19	  subjects: SubjectNode[]
    20	}
    21	
    22	export interface GradeNode {
    23	  name: string
    24	  classes: ClassNode[]
    25	}
    26	
    27	export function usePowerOptions() {
    28	  const tree = ref<GradeNode[]>([])
    29	  const loading = ref(false)
    30	
    31	  const selectedGrade = ref('')
    32	  const selectedClassId = ref('all')
    33	  const selectedSubjectId = ref('')
    34	  const selectedExamId = ref('')
    35	
    36	  const gradeOptions = computed(() => tree.value.map(g => g.name))
    37	
    38	  const classOptions = computed(() => {
    39	    const grade = tree.value.find(g => g.name === selectedGrade.value)
    40	    return grade?.classes ?? []
    41	  })
    42	
    43	  const subjectOptions = computed(() => {
    44	    const cls = classOptions.value.find(c => c.id === selectedClassId.value)
    45	    return cls?.subjects ?? []
    46	  })
    47	
    48	  const examOptions = computed(() => {
    49	    const subj = subjectOptions.value.find(s => s.id === selectedSubjectId.value)
    50	    return subj?.exams ?? []
    51	  })
    52	
    53	  watch(selectedGrade, () => {
    54	    selectedClassId.value = classOptions.value[0]?.id ?? 'all'
    55	  })
    56	  watch(selectedClassId, () => {
    57	    selectedSubjectId.value = subjectOptions.value[0]?.id ?? ''
    58	  })
    59	  watch(selectedSubjectId, () => {
    60	    selectedExamId.value = examOptions.value[0]?.exam_id ?? ''
    61	  })
    62	
    63	  const analysisParams = computed(() => ({
    64	    exam_id: selectedExamId.value,
    65	    subject_id: selectedSubjectId.value,
    66	    class_id: selectedClassId.value === 'all' ? null : selectedClassId.value,
    67	  }))
    68	
    69	  const hasSelection = computed(() => !!selectedExamId.value)
    70	
    71	  async function load(examType?: string, year?: number) {
    72	    loading.value = true
    73	    try {
    74	      const api = useApi()
    75	      const data = await api.getPowerOptions({
    76	        exam_type: examType,
    77	        year,
    78	      })
    79	      tree.value = data.grades
    80	      if (tree.value.length) {
    81	        selectedGrade.value = tree.value[0].name
    82	      }
    83	    } finally {
    84	      loading.value = false
    85	    }
    86	  }
    87	
    88	  return {
    89	    load, tree, loading,
    90	    selectedGrade, selectedClassId, selectedSubjectId, selectedExamId,
    91	    gradeOptions, classOptions, subjectOptions, examOptions,
    92	    analysisParams, hasSelection,
    93	  }
    94	}

