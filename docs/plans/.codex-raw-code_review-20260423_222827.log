    88	async def test_power_options_tree_structure(client, school_admin_headers, seed_school, db):
    89	    """Multi-grade multi-class multi-subject: verify tree + all node."""
    90	    await _seed_exam_data(db, seed_school)
    91	
    92	    resp = await client.get("/api/v1/analytics/power-options", headers=school_admin_headers)
    93	    assert resp.status_code == 200
    94	    result = resp.json()
    95	
    96	    grades = result["grades"]
    97	    grade_names = [g["name"] for g in grades]
    98	    assert "高一" in grade_names
    99	    assert "高二" in grade_names
   100	
   101	    g1 = next(g for g in grades if g["name"] == "高一")
   102	    class_ids = [c["id"] for c in g1["classes"]]
   103	    assert "all" in class_ids
   104	
   105	    all_node = next(c for c in g1["classes"] if c["id"] == "all")
   106	    assert len(all_node["subjects"]) >= 1
   107	
   108	    # ORC-002: all student_count == sum of real classes
   109	    for subj in all_node["subjects"]:
   110	        for exam in subj["exams"]:
   111	            total = 0
   112	            for cls in g1["classes"]:
   113	                if cls["id"] == "all":
   114	                    continue
   115	                for s in cls["subjects"]:
   116	                    if s["id"] == subj["id"]:
   117	                        for e in s["exams"]:
   118	                            if e["exam_id"] == exam["exam_id"]:
   119	                                total += e["student_count"]
   120	            assert exam["student_count"] == total, (
   121	                f"ORC-002: all.student_count({exam['student_count']}) != sum({total})"
   122	            )
