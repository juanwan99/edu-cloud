    32	async def _seed_level_score_data(db, seed_school):
    33	    """10 students, scores from 100 to 91."""
    34	    school, _ = seed_school
    35	    school_id = school.id
    36	    cls = Class(name="高一(1)班", grade="高一", school_id=school_id)
    37	    db.add(cls)
    38	    await db.flush()
    39	
    40	    exam = Exam(name="期末考试", status="completed", school_id=school_id,
    41	                exam_date=datetime(2026, 6, 20))
    42	    db.add(exam)
    43	    await db.flush()
    44	
    45	    subj = Subject(exam_id=exam.id, name="物理", code="physics", school_id=school_id)
    46	    db.add(subj)
    47	    await db.flush()
    48	
    49	    students = []
    50	    for i in range(10):
    51	        stu = Student(name=f"学生{i}", student_number=f"L{i:03d}",
    52	                      class_id=cls.id, grade="高一", school_id=school_id)
    53	        db.add(stu)
    54	        students.append(stu)
    55	    await db.flush()
    56	
    57	    for i, stu in enumerate(students):
    58	        db.add(ExamResult(
    59	            exam_id=exam.id, student_id=stu.id,
    60	            school_id=school_id, total_score=100 - i,
    61	        ))
    62	    await db.flush()
    63	
    64	    # LevelScoreService reads from StudentAnswer (per-subject scores), not ExamResult.total_score
    65	    question = Question(
    66	        subject_id=subj.id, school_id=school_id,
    67	        name="T1", question_type="objective", max_score=100,
    68	    )
    69	    db.add(question)
    70	    await db.flush()
    71	
    72	    for i, stu in enumerate(students):
    73	        db.add(StudentAnswer(
    74	            exam_id=exam.id, student_id=stu.id, subject_id=subj.id,
    75	            question_id=question.id, school_id=school_id,
    76	            score=100 - i,
    77	        ))
    78	    await db.commit()
    79	    return {"exam": exam, "subj": subj, "cls": cls, "students": students}
