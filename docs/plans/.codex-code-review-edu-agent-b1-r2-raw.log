import asyncio
import inspect
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_context import ToolContext, ToolResult

async def execute_no_except(self, name, arguments, ctx_or_none=None, **injected):
    spec = self._tools.get(name)
    if spec is None:
        if isinstance(ctx_or_none, ToolContext):
            return ToolResult(success=False, error=f'Unknown tool: {name}')
        return {'error': f'Unknown tool: {name}'}
    if isinstance(ctx_or_none, ToolContext):
        result = spec.func(arguments, ctx_or_none)
        if inspect.isawaitable(result):
            result = await result
        return result
    func = spec.func
    sig = inspect.signature(func)
    kwargs = {}
    for param_name, param in sig.parameters.items():
        if param_name.startswith('_'):
            if param_name in injected:
                kwargs[param_name] = injected[param_name]
        elif param_name in arguments:
            kwargs[param_name] = arguments[param_name]
    if inspect.iscoroutinefunction(func):
        return await func(**kwargs)
    return func(**kwargs)

async def main():
    reg = ToolRegistry()
    reg.execute = execute_no_except.__get__(reg, ToolRegistry)

    @reg.register(name='boom', description='Boom', parameters={}, is_read_only=True, sensitivity='public')
    async def boom(input: dict, ctx: ToolContext) -> ToolResult:
        raise RuntimeError('tool exploded')

    ctx = ToolContext(db=None, school_id='S1', user_id='U1', role='teacher')
    try:
        await reg.execute('boom', {}, ctx)
    except Exception as exc:
        print('new_style_exception_without_handler:', type(exc).__name__, exc)

    reg2 = ToolRegistry()
    reg2.execute = execute_no_except.__get__(reg2, ToolRegistry)

    @reg2.register(name='legacy_boom', description='Boom', parameters={}, is_read_only=True, sensitivity='public')
    async def legacy_boom(x: int, _db=None) -> dict:
        raise ValueError('bad input')

    try:
        await reg2.execute('legacy_boom', {'x': 1}, _db='mock')
    except Exception as exc:
        print('legacy_exception_without_handler:', type(exc).__name__, exc)

asyncio.run(main())
