import asyncio
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_context import ToolContext, ToolResult

async def main():
    # Simulate removing wrapping logic: return raw parameters unchanged.
    def raw_get_schemas(self, categories=None):
        result = []
        for spec in self._tools.values():
            if categories is not None and spec.category not in categories:
                continue
            result.append({
                'type': 'function',
                'function': {
                    'name': spec.name,
                    'description': spec.description,
                    'parameters': spec.parameters,
                },
            })
        return result

    reg = ToolRegistry()
    reg.get_schemas = raw_get_schemas.__get__(reg, ToolRegistry)

    @reg.register(name='t1', description='Tool 1', parameters={'x': {'type': 'int'}}, sensitivity='student', is_read_only=True)
    async def t1(input: dict, ctx: ToolContext) -> ToolResult:
        return ToolResult(success=True, data=None)

    params = reg.get_schemas()[0]['function']['parameters']
    print('new_style_raw:', params)
    try:
        assert params['type'] == 'object'
    except Exception as exc:
        print('new_style_test_would_fail:', type(exc).__name__, exc)

    legacy_params = {
        'type': 'object',
        'properties': {'a': {'type': 'number'}, 'b': {'type': 'number'}},
        'required': ['a', 'b'],
    }
    reg2 = ToolRegistry()
    reg2.get_schemas = raw_get_schemas.__get__(reg2, ToolRegistry)

    @reg2.register(name='legacy', description='Legacy tool', parameters=legacy_params, is_read_only=True, sensitivity='school')
    async def legacy(input: dict, ctx: ToolContext) -> ToolResult:
        return ToolResult(success=True, data=None)

    params2 = reg2.get_schemas()[0]['function']['parameters']
    print('legacy_raw:', params2)
    print('legacy_assertions_hold:', params2['type'] == 'object' and 'a' in params2['properties'] and 'required' in params2)

asyncio.run(main())
