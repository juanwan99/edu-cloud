import asyncio, time
from edu_cloud.ai.registry import ToolRegistry
from edu_cloud.ai.tool_executor import ToolOrchestrator
from edu_cloud.ai.schemas import ToolCall
from edu_cloud.ai.tool_context import ToolContext, ToolResult

async def main():
    reg = ToolRegistry()
    order = []
    @reg.register(name='slow1', description='s1', is_read_only=True, sensitivity='school')
    async def slow1(input: dict, ctx: ToolContext) -> ToolResult:
        order.append('start1')
        await asyncio.sleep(0.05)
        order.append('end1')
        return ToolResult(success=True, data={'n':1})
    @reg.register(name='slow2', description='s2', is_read_only=True, sensitivity='school')
    async def slow2(input: dict, ctx: ToolContext) -> ToolResult:
        order.append('start2')
        await asyncio.sleep(0.05)
        order.append('end2')
        return ToolResult(success=True, data={'n':2})
    orch = ToolOrchestrator(reg)
    calls=[ToolCall(id='1', name='slow1', arguments={}, _raw={}), ToolCall(id='2', name='slow2', arguments={}, _raw={})]
    batches=orch.partition(calls)
    t0=time.monotonic(); await orch.execute(batches, ToolContext(db=None, school_id='S1', user_id='U1', role='admin')); t1=time.monotonic()-t0
    print(f'no_db_elapsed_ms={t1*1000:.1f} order={order}')
    order.clear()
    t0=time.monotonic(); await orch.execute(batches, ToolContext(db='fake', school_id='S1', user_id='U1', role='admin')); t2=time.monotonic()-t0
    print(f'with_db_elapsed_ms={t2*1000:.1f} order={order}')

    reg2 = ToolRegistry()
    @reg2.register(name='legacy_add', description='Add', parameters={}, is_read_only=True, sensitivity='school')
    async def legacy_add(a: int, b: int, _db=None, _school_id=None, _user_id=None):
        return {'sum': a+b, 'db': _db, 'school': _school_id, 'user': _user_id}
    ctx=ToolContext(db='DB', school_id='S1', user_id='U1', role='admin')
    res = await reg2.execute('legacy_add', {'a':3,'b':5}, ctx)
    print(f'legacy_result={res}')

asyncio.run(main())
