# ====== 环境 ======
ENVIRONMENT=development  # development / staging / production

# ====== 数据库（生产必须用 PostgreSQL） ======
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/edu_cloud
# 本地开发可改为: DATABASE_URL=sqlite+aiosqlite:///edu_cloud.db

# ====== Redis（后台任务队列 + token 撤销） ======
REDIS_URL=redis://localhost:6379/0

# ====== 安全（生产环境必须修改） ======
SECRET_KEY=change-me-to-a-random-string
ENCRYPTION_KEY=change-me-in-production
SEED_DEFAULT_PASSWORD=change-me-seed-password
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24h
ALGORITHM=HS256

# ====== 存储 ======
UPLOAD_DIR=./uploads
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=10

# ====== 日志 ======
LOG_LEVEL=DEBUG
LOG_DIR=./logs
LOG_FILE_LEVEL=INFO

# ====== CORS ======
CORS_ORIGINS=["http://localhost:5173"]

# ====== LLM（通用 httpx 兼容端点） ======
LLM_API_URL=http://localhost:8100
LLM_API_KEY=not-needed-for-local-proxy
LLM_MODEL=gemini-3-pro-preview
LLM_SLOT=grading-vision
LLM_TIMEOUT=180
LLM_MAX_RETRIES=3

# ====== Gemini 官方 SDK ======
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ====== DeepSeek（作文锚点评分） ======
DEEPSEEK_API_KEY=

# ====== Vertex AI（可选） ======
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=global

# ====== 评分 ======
GRADING_BATCH_SIZE=40

# ====== AI 代理 ======
AI_SESSION_TTL=7200
# TIER_CONTEXT_THRESHOLDS=[100000, 30000]
# MODEL_ROUTER_ADVANCED_KEYWORDS=  # None = 使用代码默认值

# ====== 知识库 ======
KNOWLEDGE_ENABLED=true
KNOWLEDGE_BASE_DIR=./edu-knowledge-base/subjects/biology_senior
KNOWLEDGE_DB_PATH=./edu-knowledge-base/knowledge.db
KNOWLEDGE_DRAFT_VISIBLE=true

# ====== 外部服务 ======
PAPER_SKILL_URL=http://localhost:9103
